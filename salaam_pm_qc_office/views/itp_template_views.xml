<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_itp_template" model="ir.actions.act_window">
        <field name="name">ITP / ITR Templates</field>
        <field name="res_model">salaam.pm.qc.itp.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_itp_template_list" model="ir.ui.view">
        <field name="name">salaam.pm.qc.itp.template.list</field>
        <field name="model">salaam.pm.qc.itp.template</field>
        <field name="arch" type="xml">
            <list string="ITP / ITR Templates">
                <field name="code"/>
                <field name="name"/>
                <field name="template_type"/>
                <field name="discipline"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_itp_template_form" model="ir.ui.view">
        <field name="name">salaam.pm.qc.itp.template.form</field>
        <field name="model">salaam.pm.qc.itp.template</field>
        <field name="arch" type="xml">
            <form string="ITP / ITR Template">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Template Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="template_type"/>
                            <field name="discipline"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

</odoo>
