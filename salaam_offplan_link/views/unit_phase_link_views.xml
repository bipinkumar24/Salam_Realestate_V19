<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ═══ UNIT PHASE LINK FORM ═══ -->
  <record id="view_unit_phase_link_form" model="ir.ui.view">
    <field name="name">salaam.unit.phase.link.form</field>
    <field name="model">salaam.unit.phase.link</field>
    <field name="arch" type="xml">
      <form string="Unit — Construction Phase Link">
        <sheet>
          <div class="alert alert-info" role="alert">
            <strong>Progress Reference:</strong> Customer sees this phase's progress % — visibility only, no gate.
            <br/>
            <strong>Practical Completion Gate:</strong> When this phase hits 100%, unit advances to Practically Complete.
            Only one practical completion link allowed per unit.
          </div>
          <group>
            <group string="Unit">
              <field name="property_id"/>
              <field name="project_id"/>
            </group>
            <group string="Phase Link">
              <field name="phase_id"/>
              <field name="link_type" widget="radio"/>
            </group>
          </group>
          <group string="Live Status (read-only)">
            <field name="phase_progress" readonly="1" widget="progressbar"/>
            <field name="phase_state" readonly="1"/>
            <field name="phase_planned_end" readonly="1"/>
          </group>
          <field name="notes"/>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_unit_phase_link_list" model="ir.ui.view">
    <field name="name">salaam.unit.phase.link.list</field>
    <field name="model">salaam.unit.phase.link</field>
    <field name="arch" type="xml">
      <list string="Unit-Phase Links" editable="bottom">
        <field name="property_id"/>
        <field name="project_id"/>
        <field name="phase_id"/>
        <field name="link_type"/>
        <field name="phase_progress" widget="progressbar"/>
        <field name="phase_state"/>
        <field name="phase_planned_end"/>
        <field name="notes"/>
      </list>
    </field>
  </record>

  <record id="action_unit_phase_link" model="ir.actions.act_window">
    <field name="name">Unit-Phase Construction Links</field>
    <field name="res_model">salaam.unit.phase.link</field>
    <field name="view_mode">list,form</field>
  </record>

