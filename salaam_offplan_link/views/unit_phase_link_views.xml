  <!-- ═══ CONSTRUCTION PHASE INHERIT — shows linked units ═══ -->
  <record id="view_construction_phase_unit_inherit" model="ir.ui.view">
    <field name="name">salaam.construction.phase.unit.inherit</field>
    <field name="model">salaam.construction.phase</field>
    <field name="inherit_id" ref="salaam_construction_mgmt.view_construction_phase_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet" position="inside">
        <separator string="Linked Units"/>
        <group>
          <field name="linked_unit_count" readonly="1" string="Total Units Linked"/>
          <field name="practical_completion_unit_count" readonly="1"
                 string="Units Gated on This Phase"/>
        </group>
      </xpath>
    </field>
  </record>

  <!-- ═══ MENUS ═══ -->
  <menuitem id="menu_offplan_link_config"
            name="Unit-Phase Links"
            parent="salaam_construction_mgmt.menu_construction_config"
            action="action_unit_phase_link"
            sequence="20"/>

