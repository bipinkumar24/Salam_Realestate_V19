<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Minimal base view for property.details — ensures inherit views load without error.
         The post_init_hook replaces the inherit with the actual rental_management form view. -->
        <record id="view_property_details_base_fallback" model="ir.ui.view">
            <field name="name">property.details.form.base.fallback.offplan</field>
            <field name="model">property.details</field>
            <field name="priority">999</field>
            <field name="arch" type="xml">
                <form string="Property">
                    <div class="oe_button_box" name="button_box" />
                    <button name="action_open_phase_links" type="object" class="oe_stat_button" icon="fa-building">
                        <div class="o_stat_info">
                            <span class="o_stat_value">
                                <field name="construction_progress" />%</span>
                            <span class="o_stat_text">Built</span>
                        </div>
                    </button>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" />
                            </h1>
                        </div>
                        <field name="price" />
                        <separator string="Construction Status" />
                        <group>
                            <group>
                                <field name="construction_project_id" />
                                <field name="construction_status" />
                                <field name="construction_phase_name" readonly="1" />
                                <field name="construction_progress" readonly="1" widget="progressbar" />
                                <field name="expected_completion_date" readonly="1" />
                            </group>
                            <group>
                                <field name="practical_completion_date" readonly="1" />
                                <field name="snag_list_closed" readonly="1" />
                                <field name="handover_ready" readonly="1" />
                            </group>
                        </group>
                        <field name="unit_phase_link_ids">
                            <list editable="bottom" string="Construction Phase Links">
                                <field name="project_id" />
                                <field name="phase_id" />
                                <field name="link_type" />
                                <field name="phase_progress" widget="progressbar" readonly="1" />
                                <field name="phase_state" readonly="1" />
                                <field name="phase_planned_end" readonly="1" />
                            </list>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>