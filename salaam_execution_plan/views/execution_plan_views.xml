<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_execution_phase" model="ir.actions.act_window">
        <field name="name">Execution Phases</field>
        <field name="res_model">salaam.execution.phase</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_execution_phase_list" model="ir.ui.view">
        <field name="name">salaam.execution.phase.list</field>
        <field name="model">salaam.execution.phase</field>
        <field name="arch" type="xml">
            <list string="Phases">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_execution_phase_form" model="ir.ui.view">
        <field name="name">salaam.execution.phase.form</field>
        <field name="model">salaam.execution.phase</field>
        <field name="arch" type="xml">
            <form string="Phase">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lots">
                            <field name="lot_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_execution_lot" model="ir.actions.act_window">
        <field name="name">Execution Lots</field>
        <field name="res_model">salaam.execution.lot</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_execution_lot_list" model="ir.ui.view">
        <field name="name">salaam.execution.lot.list</field>
        <field name="model">salaam.execution.lot</field>
        <field name="arch" type="xml">
            <list string="Lots">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="phase_id"/>
            </list>
        </field>
    </record>

    <record id="view_execution_lot_form" model="ir.ui.view">
        <field name="name">salaam.execution.lot.form</field>
        <field name="model">salaam.execution.lot</field>
        <field name="arch" type="xml">
            <form string="Lot">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="phase_id"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Decision Gates">
                            <field name="gate_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="gate_number"/>
                                    <field name="name"/>
                                    <field name="target_date"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

</odoo>
