<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_buruuj_snag_list" model="ir.ui.view">
        <field name="name">buruuj.snag.list</field>
        <field name="model">buruuj.snag</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_id"/>
                <field name="location"/>
                <field name="discipline"/>
                <field name="priority"/>
                <field name="responsible_id"/>
                <field name="target_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>
    <record id="view_buruuj_snag_form" model="ir.ui.view">
        <field name="name">buruuj.snag.form</field>
        <field name="model">buruuj.snag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                <field name="project_id"/>
                <field name="location"/>
                <field name="discipline"/>
                <field name="priority"/>
                <field name="responsible_id"/>
                <field name="target_date"/>
                <field name="state"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_buruuj_snag" model="ir.actions.act_window">
        <field name="name">Snag List</field>
        <field name="res_model">buruuj.snag</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
