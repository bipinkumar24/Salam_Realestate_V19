<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_worker" model="ir.sequence">
            <field name="name">Worker Code</field>
            <field name="code">buruuj.worker</field>
            <field name="prefix">W/</field>
            <field name="padding">5</field>
        </record>
        <record id="seq_wage_run" model="ir.sequence">
            <field name="name">Wage Run</field>
            <field name="code">buruuj.wage.run</field>
            <field name="prefix">WR/%(year)s/</field>
            <field name="padding">5</field>
        </record>
    </data>
</odoo>
