<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action: portal users -->
    <record id="action_portal_users" model="ir.actions.act_window">
        <field name="name">Portal Users</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('groups_id','in',[ref('base.group_portal')])]</field>
    </record>

    <menuitem id="menu_portal_root" name="Portal Users"
              parent="buruuj_base.menu_buruuj_config" sequence="60"
              groups="buruuj_base.group_buruuj_manager"/>
    <menuitem id="menu_portal_users" name="Portal Users"
              parent="menu_portal_root" action="action_portal_users"
              sequence="10"/>
</odoo>
