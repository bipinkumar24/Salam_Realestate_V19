        <record id="demo_emp_storekeeper_2" model="hr.employee">
            <field name="name">Bilal Hassan</field>
            <field name="job_title">Site Storekeeper - Marina</field>
            <field name="work_email">storekeeper.marina@buruuj.example</field>
            <field name="work_phone">+966-50-555-1101</field>
        </record>

        <record id="demo_emp_surveyor" model="hr.employee">
            <field name="name">Khalid Rashid</field>
            <field name="job_title">Senior Surveyor</field>
            <field name="work_email">surveyor@buruuj.example</field>
            <field name="work_phone">+966-50-555-1200</field>
        </record>

        <record id="demo_emp_foreman_1" model="hr.employee">
            <field name="name">Ahmad Saeed</field>
            <field name="job_title">Concrete Foreman</field>
            <field name="work_email">foreman.concrete@buruuj.example</field>
            <field name="work_phone">+966-50-555-1300</field>
        </record>

        <record id="demo_emp_foreman_2" model="hr.employee">
