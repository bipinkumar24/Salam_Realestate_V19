<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_buruuj_workorder_list" model="ir.ui.view">
        <field name="name">buruuj.workorder.list</field>
        <field name="model">buruuj.workorder</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="title"/>
                <field name="subcontract_id"/>
                <field name="project_id"/>
                <field name="partner_id"/>
                <field name="date"/>
                <field name="amount" sum="Total"/>
                <field name="progress" widget="progressbar"/>
                <field name="state" widget="badge"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>
    <record id="view_buruuj_workorder_form" model="ir.ui.view">
        <field name="name">buruuj.workorder.form</field>
        <field name="model">buruuj.workorder</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_issue" string="Issue" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_start" string="Start" type="object"
                            invisible="state != 'issued'"/>
                    <button name="action_complete" string="Complete" type="object"
                            invisible="state != 'in_progress'"/>
                    <button name="action_sign_off" string="Digital Sign-Off" type="object"
                            class="oe_highlight" invisible="state != 'completed'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('signed_off','cancelled')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <h3><field name="title"/></h3>
                    </div>
                    <group>
                        <group>
                            <field name="subcontract_id"/>
                            <field name="project_id"/>
                            <field name="partner_id"/>
                            <field name="location"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="amount"/>
                            <field name="progress"/>
                            <field name="signed_off_by" readonly="1"/>
                            <field name="sign_off_date" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_buruuj_workorder" model="ir.actions.act_window">
        <field name="name">Work Orders</field>
        <field name="res_model">buruuj.workorder</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
