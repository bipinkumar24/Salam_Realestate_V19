<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tender_budget_quote_list" model="ir.ui.view">
        <field name="name">tender.budget.quote.list</field>
        <field name="model">tender.budget.quote</field>
        <field name="arch" type="xml">
            <list decoration-success="is_selected" decoration-muted="not is_selected">
                <field name="opportunity_id"/>
                <field name="item_name"/>
                <field name="supplier_id"/>
                <field name="rank"/>
                <field name="amount" widget="monetary"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="validity_to"/>
                <field name="is_selected"/>
            </list>
        </field>
    </record>

    <record id="view_tender_budget_quote_form" model="ir.ui.view">
        <field name="name">tender.budget.quote.form</field>
        <field name="model">tender.budget.quote</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="opportunity_id"/>
                            <field name="item_name"/>
                            <field name="supplier_id"/>
                            <field name="rank"/>
                            <field name="is_selected"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="currency_id"/>
                            <field name="received_date"/>
                            <field name="validity_to"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Attachments" name="attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tender_budget_quote" model="ir.actions.act_window">
        <field name="name">Budget Quotes</field>
        <field name="res_model">tender.budget.quote</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
