<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tender_partner_agreement_list" model="ir.ui.view">
        <field name="name">tender.partner.agreement.list</field>
        <field name="model">tender.partner.agreement</field>
        <field name="arch" type="xml">
            <list decoration-success="sign_status == 'signed'" decoration-warning="sign_status == 'sent'" decoration-danger="sign_status in ('expired','terminated')">
                <field name="name"/>
                <field name="opportunity_id"/>
                <field name="partner_id"/>
                <field name="agreement_type"/>
                <field name="sign_status" widget="badge"/>
                <field name="validity_to"/>
            </list>
        </field>
    </record>

    <record id="view_tender_partner_agreement_form" model="ir.ui.view">
        <field name="name">tender.partner.agreement.form</field>
        <field name="model">tender.partner.agreement</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="sign_status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="opportunity_id"/>
                            <field name="partner_id"/>
                            <field name="agreement_type"/>
                        </group>
                        <group>
                            <field name="validity_from"/>
                            <field name="validity_to"/>
                            <field name="revenue_share_pct"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <field name="scope_of_work" nolabel="1" placeholder="Scope split, exclusivity, deliverables…"/>
                    </group>
                    <group string="Attachments">
                        <field name="attachment_ids" nolabel="1" widget="many2many_binary"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_tender_partner_agreement" model="ir.actions.act_window">
        <field name="name">Partner Agreements</field>
        <field name="res_model">tender.partner.agreement</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
