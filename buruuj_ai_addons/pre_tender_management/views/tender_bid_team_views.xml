<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tender_bid_team_member_list" model="ir.ui.view">
        <field name="name">tender.bid.team.member.list</field>
        <field name="model">tender.bid.team.member</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="opportunity_id"/>
                <field name="employee_id"/>
                <field name="role"/>
                <field name="allocation_pct"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="is_key_personnel"/>
            </list>
        </field>
    </record>

    <record id="view_tender_bid_team_member_form" model="ir.ui.view">
        <field name="name">tender.bid.team.member.form</field>
        <field name="model">tender.bid.team.member</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="opportunity_id"/>
                            <field name="employee_id"/>
                            <field name="role"/>
                            <field name="is_key_personnel"/>
                        </group>
                        <group>
                            <field name="allocation_pct"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tender_bid_team" model="ir.actions.act_window">
        <field name="name">Bid Team</field>
        <field name="res_model">tender.bid.team.member</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
