<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_employee_form_tender" model="ir.ui.view">
        <field name="name">hr.employee.form.tender</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Tender / Bid" name="tender_profile">
                    <group>
                        <group>
                            <field name="bid_availability_state"/>
                            <field name="is_key_personnel"/>
                            <field name="cv_attachment_id"/>
                        </group>
                    </group>
                    <group string="Bid Skills Summary">
                        <field name="bid_skill_summary" nolabel="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
