<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tender_kickoff_gate_list" model="ir.ui.view">
        <field name="name">tender.kickoff.gate.list</field>
        <field name="model">tender.kickoff.gate</field>
        <field name="arch" type="xml">
            <list decoration-success="decision == 'proceed'" decoration-warning="decision == 'rework'" decoration-danger="decision == 'halt'">
                <field name="name"/>
                <field name="opportunity_id"/>
                <field name="gate_type"/>
                <field name="gate_date"/>
                <field name="chairperson_id"/>
                <field name="decision" widget="badge"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_tender_kickoff_gate_form" model="ir.ui.view">
        <field name="name">tender.kickoff.gate.form</field>
        <field name="model">tender.kickoff.gate</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="opportunity_id"/>
                            <field name="gate_type"/>
                            <field name="chairperson_id"/>
                        </group>
                        <group>
                            <field name="gate_date"/>
                            <field name="decision"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <field name="attendee_ids" widget="many2many_tags"/>
                    </group>
                    <notebook>
                        <page string="Decision" name="decision">
                            <field name="decision_notes" nolabel="1"/>
                        </page>
                        <page string="Action Items" name="actions">
                            <field name="action_item_ids">
                                <list editable="bottom" decoration-success="state == 'done'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="description"/>
                                    <field name="owner_id"/>
                                    <field name="deadline"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_tender_kickoff_gate" model="ir.actions.act_window">
        <field name="name">Review Gates</field>
        <field name="res_model">tender.kickoff.gate</field>
        <field name="view_mode">list,form,calendar</field>
    </record>

</odoo>
