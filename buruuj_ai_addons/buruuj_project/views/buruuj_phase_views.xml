<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_buruuj_phase_list" model="ir.ui.view">
        <field name="name">buruuj.phase.list</field>
        <field name="model">buruuj.phase</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="project_id"/>
                <field name="planned_start"/>
                <field name="planned_end"/>
                <field name="progress"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_buruuj_phase_form" model="ir.ui.view">
        <field name="name">buruuj.phase.form</field>
        <field name="model">buruuj.phase</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                <field name="code"/>
                <field name="project_id"/>
                <field name="planned_start"/>
                <field name="planned_end"/>
                <field name="progress"/>
                <field name="state"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_buruuj_phase" model="ir.actions.act_window">
        <field name="name">Phases</field>
        <field name="res_model">buruuj.phase</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
