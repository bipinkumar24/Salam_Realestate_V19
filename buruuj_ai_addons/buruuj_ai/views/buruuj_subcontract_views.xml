<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_buruuj_subcontract_form_ai" model="ir.ui.view">
        <field name="name">buruuj.subcontract.form.ai</field>
        <field name="model">buruuj.subcontract</field>
        <field name="inherit_id" ref="buruuj_subcontractor.view_buruuj_subcontract_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_ai_recommend_subcontractor" type="object"
                        string="AI: Recommend Subcontractor"
                        class="btn-secondary" icon="fa-magic"
                        invisible="state != 'draft' or not trade_id"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="AI Recommendation" name="ai_recommendation"
                      invisible="not ai_recommendation_text">
                    <field name="ai_recommendation_text" readonly="1" nolabel="1"/>
                    <field name="ai_last_task_id" readonly="1"/>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
