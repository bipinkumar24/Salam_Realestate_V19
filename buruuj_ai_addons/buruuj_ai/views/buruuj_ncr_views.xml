<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_buruuj_ncr_form_ai" model="ir.ui.view">
        <field name="name">buruuj.ncr.form.ai</field>
        <field name="model">buruuj.ncr</field>
        <field name="inherit_id" ref="buruuj_site_ops.view_buruuj_ncr_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_ai_draft_ncr" type="object"
                        string="Draft from Photo (AI)"
                        class="btn-secondary" icon="fa-magic"
                        invisible="state != 'draft' or not ai_source_photo"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="AI Photo Draft" name="ai_photo">
                    <group>
                        <group>
                            <field name="ai_source_photo"
                                   filename="ai_source_photo_name"
                                   widget="image" options="{'size': [400, 300]}"/>
                            <field name="ai_source_photo_name" invisible="1"/>
                        </group>
                        <group>
                            <field name="ai_last_task_id" readonly="1"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <strong>How this works:</strong> Take a photo of the defect on your phone,
                        attach it here, then click "Draft from Photo". The AI will fill in the
                        Description, Root Cause, and Corrective Action tabs. Always review before
                        clicking Issue.
                    </div>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
