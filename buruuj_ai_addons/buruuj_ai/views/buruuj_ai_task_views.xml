<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_buruuj_ai_task_list" model="ir.ui.view">
        <field name="name">buruuj.ai.task.list</field>
        <field name="model">buruuj.ai.task</field>
        <field name="arch" type="xml">
            <list decoration-success="state=='done'"
                  decoration-danger="state=='failed'"
                  decoration-warning="state=='running'">
                <field name="create_date"/>
                <field name="task_type"/>
                <field name="model"/>
                <field name="user_id"/>
                <field name="ref_display"/>
                <field name="input_tokens" sum="In"/>
                <field name="output_tokens" sum="Out"/>
                <field name="estimated_cost_usd" widget="monetary" sum="Cost"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_buruuj_ai_task_form" model="ir.ui.view">
        <field name="name">buruuj.ai.task.form</field>
        <field name="model">buruuj.ai.task</field>
        <field name="arch" type="xml">
            <form create="false" edit="false">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_source" type="object"
                                class="oe_stat_button" icon="fa-link"
                                invisible="not ref_id">
                            <span>Open Source</span>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="task_type"/>
                            <field name="model"/>
                            <field name="user_id"/>
                            <field name="create_date"/>
                        </group>
                        <group>
                            <field name="input_tokens"/>
                            <field name="output_tokens"/>
                            <field name="estimated_cost_usd" widget="monetary"/>
                            <field name="ref_display"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="System Prompt">
                            <field name="system_prompt" widget="text" readonly="1"/>
                        </page>
                        <page string="Response">
                            <field name="response_text" widget="text" readonly="1"/>
                        </page>
                        <page string="Error" invisible="state != 'failed'">
                            <field name="error_message" widget="text" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_buruuj_ai_task_search" model="ir.ui.view">
        <field name="name">buruuj.ai.task.search</field>
        <field name="model">buruuj.ai.task</field>
        <field name="arch" type="xml">
            <search>
                <field name="task_type"/>
                <field name="user_id"/>
                <field name="model"/>
                <filter string="Done" name="state_done"
                        domain="[('state','=','done')]"/>
                <filter string="Failed" name="state_failed"
                        domain="[('state','=','failed')]"/>
                <filter string="Running" name="state_running"
                        domain="[('state','=','running')]"/>
                <separator/>
                <filter string="This Month" name="this_month"
                        domain="[('create_date','&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter string="Task Type" name="g_type"
                            context="{'group_by': 'task_type'}"/>
                    <filter string="State" name="g_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="User" name="g_user"
                            context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_buruuj_ai_task" model="ir.actions.act_window">
        <field name="name">AI Tasks</field>
        <field name="res_model">buruuj.ai.task</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_this_month': 1}</field>
    </record>

</odoo>
