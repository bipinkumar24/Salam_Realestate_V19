            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!-- CRON 6: Weekly cleanup of old AI task logs -->
        <record id="cron_clean_ai_tasks" model="ir.cron">
            <field name="name">Buruuj AI: Clean old task logs</field>
            <field name="model_id" ref="model_buruuj_ai_task"/>
            <field name="state">code</field>
            <field name="code">model.cron_clean_ai_tasks()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
