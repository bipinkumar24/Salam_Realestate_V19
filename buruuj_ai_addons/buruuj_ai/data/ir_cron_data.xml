<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- CRON 1: Daily license & insurance expiry scan (8 AM) -->
        <record id="cron_license_expiry_scan" model="ir.cron">
            <field name="name">Buruuj AI: Daily license &amp; insurance expiry scan</field>
            <field name="model_id" ref="model_buruuj_ai_client"/>
            <field name="state">code</field>
            <field name="code">model.cron_license_expiry_scan()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!-- CRON 2: Daily contract / bond key dates scan -->
        <record id="cron_contract_key_dates_scan" model="ir.cron">
            <field name="name">Buruuj AI: Daily contract key dates scan</field>
            <field name="model_id" ref="model_buruuj_ai_client"/>
            <field name="state">code</field>
            <field name="code">model.cron_contract_key_dates_scan()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!-- CRON 3: Daily overdue RFI scan -->
        <record id="cron_overdue_rfi_scan" model="ir.cron">
            <field name="name">Buruuj AI: Daily overdue RFI scan</field>
            <field name="model_id" ref="model_buruuj_ai_client"/>
            <field name="state">code</field>
            <field name="code">model.cron_overdue_rfi_scan()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!-- CRON 4: Weekly portfolio risk scan (AI narrative) -->
        <record id="cron_portfolio_risk_scan" model="ir.cron">
            <field name="name">Buruuj AI: Weekly portfolio risk scan (AI narrative)</field>
            <field name="model_id" ref="model_buruuj_ai_client"/>
            <field name="state">code</field>
            <field name="code">model.cron_portfolio_risk_scan()</field>
            <field name="user_id" ref="base.user_root"/>
