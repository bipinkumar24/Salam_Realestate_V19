            <field name="active" eval="True"/>
        </record>

        <!-- CRON 5: Weekly scorecard reminder -->
        <record id="cron_scorecard_reminder" model="ir.cron">
            <field name="name">Buruuj AI: Weekly subcontractor scorecard reminder</field>
            <field name="model_id" ref="model_buruuj_ai_client"/>
            <field name="state">code</field>
            <field name="code">model.cron_scorecard_reminder()</field>
            <field name="user_id" ref="base.user_root"/>
