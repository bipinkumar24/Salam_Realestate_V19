<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Default model — empty until admin configures -->
        <record id="param_ai_model" model="ir.config_parameter">
            <field name="key">buruuj_ai.model</field>
            <field name="value">claude-opus-4-7</field>
        </record>

        <record id="param_ai_budget" model="ir.config_parameter">
            <field name="key">buruuj_ai.monthly_budget_usd</field>
            <field name="value">500.0</field>
        </record>

        <record id="param_ai_enable_boq" model="ir.config_parameter">
            <field name="key">buruuj_ai.enable_boq_draft</field>
            <field name="value">True</field>
        </record>

        <record id="param_ai_enable_ncr" model="ir.config_parameter">
            <field name="key">buruuj_ai.enable_ncr_draft</field>
            <field name="value">True</field>
        </record>

        <record id="param_ai_enable_sub" model="ir.config_parameter">
            <field name="key">buruuj_ai.enable_sub_recommend</field>
            <field name="value">True</field>
        </record>

        <record id="param_ai_enable_vo" model="ir.config_parameter">
            <field name="key">buruuj_ai.enable_vo_draft</field>
            <field name="value">True</field>
        </record>

        <!-- Cron toggles -->
        <record id="param_cron_license" model="ir.config_parameter">
            <field name="key">buruuj_ai.cron_license_scan_enabled</field>
            <field name="value">True</field>
        </record>
        <record id="param_cron_contract" model="ir.config_parameter">
            <field name="key">buruuj_ai.cron_contract_scan_enabled</field>
            <field name="value">True</field>
        </record>
        <record id="param_cron_rfi" model="ir.config_parameter">
            <field name="key">buruuj_ai.cron_rfi_scan_enabled</field>
            <field name="value">True</field>
        </record>
        <record id="param_cron_portfolio" model="ir.config_parameter">
            <field name="key">buruuj_ai.cron_portfolio_scan_enabled</field>
            <field name="value">True</field>
        </record>
        <record id="param_cron_scorecard" model="ir.config_parameter">
            <field name="key">buruuj_ai.cron_scorecard_reminder_enabled</field>
            <field name="value">True</field>
        </record>
        <record id="param_license_window" model="ir.config_parameter">
            <field name="key">buruuj_ai.license_warning_days</field>
            <field name="value">30</field>
        </record>
        <record id="param_contract_window" model="ir.config_parameter">
            <field name="key">buruuj_ai.contract_warning_days</field>
            <field name="value">30</field>
        </record>
    </data>
</odoo>
