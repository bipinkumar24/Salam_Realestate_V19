<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tool_loss_list" model="ir.ui.view">
        <field name="name">buruuj.tool.loss.list</field>
        <field name="model">buruuj.tool.loss</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'recovered'"
                  decoration-warning="state in ('investigating','disputed')"
                  decoration-danger="incident_type == 'stolen'">
                <field name="tool_id"/>
                <field name="date"/>
                <field name="incident_type"/>
                <field name="responsible_employee_id"/>
                <field name="responsible_subcontractor_id"/>
                <field name="estimated_value" sum="Loss"/>
                <field name="recovery_amount" sum="Recovered"/>
                <field name="state" widget="badge"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_tool_loss_form" model="ir.ui.view">
        <field name="name">buruuj.tool.loss.form</field>
        <field name="model">buruuj.tool.loss</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_investigate" string="Start Investigation"
                            type="object" class="oe_highlight"
                            invisible="state != 'reported'"/>
                    <button name="action_create_backcharge"
                            string="Raise Back-charge" type="object"
                            invisible="state in ('recovered','written_off') or not responsible_subcontractor_id or backcharge_id"/>
                    <button name="action_recover" string="Mark Recovered"
                            type="object" class="oe_highlight"
                            invisible="state in ('recovered','written_off')"/>
                    <button name="action_writeoff" string="Write Off" type="object"
                            invisible="state in ('recovered','written_off')"/>
                    <button name="action_dispute" string="Mark Disputed"
                            type="object"
                            invisible="state in ('recovered','written_off','disputed')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="tool_id"/>
                            <field name="incident_type"/>
                            <field name="date"/>
                            <field name="project_id"/>
                            <field name="location"/>
                        </group>
                        <group>
                            <field name="responsible_employee_id"/>
                            <field name="responsible_subcontractor_id"/>
                            <field name="estimated_value"/>
                            <field name="recovery_amount"/>
                            <field name="recovery_method"/>
                            <field name="backcharge_id" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="description" placeholder="What happened, when, who was involved..."/>
                    <field name="incident_report_attachment"
                           filename="incident_report_filename"/>
                    <field name="incident_report_filename" invisible="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_tool_loss" model="ir.actions.act_window">
        <field name="name">Loss / Damage</field>
        <field name="res_model">buruuj.tool.loss</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
