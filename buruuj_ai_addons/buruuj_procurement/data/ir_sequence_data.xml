            <field name="code">buruuj.po</field>
            <field name="prefix">PO/%(year)s/</field>
            <field name="padding">5</field>
        </record>
        <record id="seq_grn" model="ir.sequence">
            <field name="name">Goods Receipt Note</field>
            <field name="code">buruuj.grn</field>
            <field name="prefix">GRN/%(year)s/</field>
            <field name="padding">5</field>
        </record>
        <record id="seq_iss" model="ir.sequence">
            <field name="name">Material Issuance</field>
            <field name="code">buruuj.material.issuance</field>
            <field name="prefix">MIS/%(year)s/</field>
