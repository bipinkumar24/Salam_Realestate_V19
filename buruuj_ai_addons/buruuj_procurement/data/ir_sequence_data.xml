        <record id="seq_mr" model="ir.sequence">
            <field name="name">Material Requisition</field>
            <field name="code">buruuj.material.requisition</field>
            <field name="prefix">MR/%(year)s/</field>
            <field name="padding">5</field>
        </record>
        <record id="seq_rfq" model="ir.sequence">
            <field name="name">Request for Quotation</field>
            <field name="code">buruuj.rfq</field>
            <field name="prefix">RFQ/%(year)s/</field>
            <field name="padding">5</field>
        </record>
        <record id="seq_po" model="ir.sequence">
