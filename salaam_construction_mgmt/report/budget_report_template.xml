<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Budget Report PDF Action -->
    <record id="action_report_budget_summary" model="ir.actions.report">
        <field name="name">Budget Summary Report</field>
        <field name="model">salaam.construction.project</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">salaam_construction_mgmt.report_budget_summary</field>
        <field name="report_file">salaam_construction_mgmt.report_budget_summary</field>
        <field name="paperformat_id" ref="paperformat_construction_a4"/>
        <field name="binding_model_id" ref="model_salaam_construction_project"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_budget_summary">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- HEADER -->
                        <div style="background:#1A1A2E;color:#fff;padding:14px 18px;margin-bottom:18px;border-bottom:4px solid #C9A84C;">
                            <table width="100%"><tr>
                                <td>
                                    <h2 style="margin:0;color:#C9A84C;font-size:17px;">SALAAM INVESTMENT BANK</h2>
                                    <div style="font-size:11px;color:#aaa;">IAFAO — Construction Management</div>
                                </td>
                                <td style="text-align:right;vertical-align:top;">
                                    <div style="font-size:13px;font-weight:bold;color:#C9A84C;"><t t-esc="doc.code"/> — <t t-esc="doc.name"/></div>
                                    <div style="font-size:11px;color:#ccc;">Budget Summary Report</div>
                                    <div style="font-size:10px;color:#aaa;">Generated: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d %b %Y')"/></div>
                                </td>
                            </tr></table>
                        </div>

                        <!-- PROJECT KPIs -->
                        <h3 style="color:#1A1A2E;border-bottom:2px solid #C9A84C;padding-bottom:4px;">Project Overview</h3>
                        <table class="table table-sm" width="100%">
                            <tr>
                                <td width="25%"><strong>Main Contractor</strong></td>
                                <td><t t-esc="doc.contractor_id.name or 'N/A'"/></td>
                                <td width="25%"><strong>Project Manager</strong></td>
                                <td><t t-esc="doc.project_manager_id.name"/></td>
                            </tr>
                            <tr>
                                <td><strong>Planned Start</strong></td>
                                <td><t t-esc="doc.date_start_planned"/></td>
                                <td><strong>Planned Completion</strong></td>
                                <td><t t-esc="doc.date_end_planned"/></td>
                            </tr>
                            <tr>
                                <td><strong>Overall Progress</strong></td>
                                <td colspan="3">
                                    <strong style="color:#C9A84C;font-size:15px;"><t t-esc="'{:.1f}%'.format(doc.overall_progress or 0)"/></strong>
                                </td>
                            </tr>
                        </table>

                        <!-- BUDGET KPIs -->
                        <h3 style="color:#1A1A2E;border-bottom:2px solid #C9A84C;padding-bottom:4px;margin-top:16px;">Budget Summary</h3>
                        <table class="table" width="100%">
                            <tr style="background:#1A1A2E;color:#fff;">
                                <th>Item</th>
                                <th class="text-right">Amount (USD)</th>
                            </tr>
                            <tr>
                                <td><strong>Istisna Contract Value</strong></td>
                                <td class="text-right">
                                    <t t-esc="doc.contract_value" t-options='{"widget":"monetary","display_currency":doc.currency_id}'/>
                                </td>
                            </tr>
                            <tr style="background:#f5f5f5;">
                                <td><strong>Approved Project Budget</strong></td>
                                <td class="text-right">
                                    <strong><t t-esc="doc.approved_budget" t-options='{"widget":"monetary","display_currency":doc.currency_id}'/></strong>
                                </td>
                            </tr>
                            <tr>
                                <td>Total Committed (Sub-Contracts)</td>
                                <td class="text-right">
                                    <t t-esc="doc.total_committed" t-options='{"widget":"monetary","display_currency":doc.currency_id}'/>
                                </td>
                            </tr>
                            <tr style="background:#f5f5f5;">
                                <td>Total Spent / Paid</td>
                                <td class="text-right">
                                    <t t-esc="doc.total_spent" t-options='{"widget":"monetary","display_currency":doc.currency_id}'/>
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Budget Variance (Remaining)</strong></td>
                                <td class="text-right">
                                    <strong style="color:#10B981;">
                                        <t t-esc="doc.budget_variance" t-options='{"widget":"monetary","display_currency":doc.currency_id}'/>
                                    </strong>
                                </td>
                            </tr>
                            <tr style="background:#f5f5f5;">
                                <td>% Budget Spent</td>
                                <td class="text-right">
                                    <t t-esc="'{:.1f}%'.format(doc.budget_pct_spent or 0)"/>
                                </td>
                            </tr>
                        </table>

                        <!-- BUDGET LINES BY CATEGORY -->
                        <h3 style="color:#1A1A2E;border-bottom:2px solid #C9A84C;padding-bottom:4px;margin-top:16px;">Budget by Cost Category</h3>
                        <table class="table table-sm table-striped" width="100%">
                            <thead style="background:#1A1A2E;color:#fff;">
                                <tr>
                                    <th>Category</th>
                                    <th>Cost Item</th>
                                    <th>Phase</th>
                                    <th class="text-right">Budget</th>
                                    <th class="text-right">Committed</th>
                                    <th class="text-right">Spent</th>
                                    <th class="text-right">Variance</th>
                                    <th class="text-right">%</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.budget_line_ids" t-as="line">
                                    <tr>
                                        <td><t t-esc="dict(line._fields['category'].selection).get(line.category,'')"/></td>
                                        <td><t t-esc="line.name"/></td>
                                        <td><t t-esc="line.phase_id.name if line.phase_id else ''"/></td>
                                        <td class="text-right">
                                            <t t-esc="line.budgeted_amount" t-options='{"widget":"monetary","display_currency":doc.currency_id}'/>
                                        </td>
                                        <td class="text-right">
                                            <t t-esc="line.committed_amount" t-options='{"widget":"monetary","display_currency":doc.currency_id}'/>
                                        </td>
                                        <td class="text-right">
                                            <t t-esc="line.spent_amount" t-options='{"widget":"monetary","display_currency":doc.currency_id}'/>
                                        </td>
                                        <td class="text-right">
                                            <t t-esc="line.variance" t-options='{"widget":"monetary","display_currency":doc.currency_id}'/>
                                        </td>
                                        <td class="text-right"><t t-esc="'{:.1f}%'.format(line.pct_spent or 0)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- PHASE PROGRESS SUMMARY -->
                        <t t-if="doc.phase_ids">
                            <h3 style="color:#1A1A2E;border-bottom:2px solid #C9A84C;padding-bottom:4px;margin-top:16px;">Phase Progress Summary</h3>
                            <table class="table table-sm table-striped" width="100%">
                                <thead style="background:#1A1A2E;color:#fff;">
                                    <tr>
                                        <th>Phase</th>
                                        <th>Type</th>
                                        <th>Planned Start</th>
                                        <th>Planned End</th>
                                        <th class="text-right">Weight</th>
                                        <th class="text-right">Progress</th>
                                        <th class="text-right">Delay (days)</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.phase_ids" t-as="phase">
                                        <tr>
                                            <td><t t-esc="phase.name"/></td>
                                            <td><t t-esc="phase.phase_type or ''"/></td>
                                            <td><t t-esc="phase.date_start_planned"/></td>
                                            <td><t t-esc="phase.date_end_planned"/></td>
                                            <td class="text-right"><t t-esc="'{:.1f}%'.format(phase.weight or 0)"/></td>
                                            <td class="text-right"><strong><t t-esc="'{:.1f}%'.format(phase.progress or 0)"/></strong></td>
                                            <td class="text-right">
                                                <t t-if="phase.delay_days &gt; 0">
                                                    <span style="color:#EF4444;"><t t-esc="phase.delay_days"/></span>
                                                </t>
                                                <t t-else="">0</t>
                                            </td>
                                            <td><t t-esc="dict(phase._fields['state'].selection).get(phase.state,'')"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <div style="margin-top:24px;padding-top:8px;border-top:1px solid #ccc;font-size:9px;color:#888;">
                            CONFIDENTIAL · <t t-esc="doc.code"/> · <t t-esc="doc.company_id.name"/> ·
                            Project Manager: <t t-esc="doc.project_manager_id.name"/> ·
                            Generated: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d %b %Y %H:%M')"/>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
