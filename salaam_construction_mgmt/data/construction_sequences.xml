<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_construction_project" model="ir.sequence">
            <field name="name">Construction Project</field>
            <field name="code">salaam.construction.project</field>
            <field name="prefix">PROJ-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_site_report" model="ir.sequence">
            <field name="name">Site Report</field>
            <field name="code">salaam.site.report</field>
            <field name="prefix">SR-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_governance_doc" model="ir.sequence">
            <field name="name">Governance Document</field>
            <field name="code">salaam.governance.document</field>
            <field name="prefix">GOV-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
