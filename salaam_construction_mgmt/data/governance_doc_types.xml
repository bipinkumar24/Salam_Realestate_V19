        <!-- Constitutional -->
        <record id="doctype_moa" model="salaam.governance.doc.type">
            <field name="name">Memorandum of Association (MOA)</field>
            <field name="code">MOA</field>
            <field name="category">constitutional</field>
        </record>
        <record id="doctype_aoa" model="salaam.governance.doc.type">
            <field name="name">Articles of Association (AOA)</field>
