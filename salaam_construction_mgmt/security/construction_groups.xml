<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_construction" model="ir.module.category">
            <field name="name">Construction Management</field>
            <field name="sequence">101</field>
        </record>

        <!-- Privilege -->
        <record id="privilege_construction" model="res.groups.privilege">
            <field name="name">Construction Management</field>
            <field name="category_id" ref="module_category_construction"/>
            <field name="sequence">10</field>
        </record>

        <record id="group_construction_viewer" model="res.groups">
            <field name="name">Viewer</field>
            <field name="privilege_id" ref="privilege_construction"/>
        </record>

        <record id="group_construction_site_engineer" model="res.groups">
            <field name="name">Site Engineer</field>
            <field name="privilege_id" ref="privilege_construction"/>
            <field name="implied_ids" eval="[(4, ref('group_construction_viewer'))]"/>
            <!-- <field name="comment">Can create/submit site reports and update task progress</field> -->
        </record>

        <record id="group_construction_officer" model="res.groups">
            <field name="name">Officer</field>
            <field name="privilege_id" ref="privilege_construction"/>
            <field name="implied_ids" eval="[(4, ref('group_construction_site_engineer'))]"/>
            <!-- <field name="comment">Full project management — cannot approve governance docs</field> -->
        </record>

        <record id="group_construction_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="privilege_construction"/>
            <field name="implied_ids" eval="[(4, ref('group_construction_officer'))]"/>
            <!-- <field name="comment">Full access including site report approval and governance docs</field> -->
        </record>

        <record id="group_construction_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="privilege_id" ref="privilege_construction"/>
            <field name="implied_ids" eval="[(4, ref('group_construction_manager'))]"/>
            <!-- <field name="comment">Configuration and full delete rights</field> -->
        </record>

    </data>
</odoo>
