<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="report_tender">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="o">
        <t t-call="web.external_layout">
          <div class="page">
            <h2>Tender Evaluation Report</h2>
            <h3><t t-esc="o.name"/> — <t t-esc="o.title"/></h3>
            <table class="table table-sm"><tr><td><b>Project</b></td><td><t t-esc="o.project_id.name"/></td><td><b>Type</b></td><td><t t-esc="o.tender_type"/></td></tr>
            <tr><td><b>Est. Value</b></td><td><t t-esc="o.estimated_value"/> <t t-esc="o.currency_id.symbol"/></td><td><b>Status</b></td><td><t t-esc="o.state"/></td></tr></table>
            <h4>Tenderer Evaluation</h4>
            <table class="table table-bordered table-sm">
              <thead><tr><th>Rank</th><th>Tenderer</th><th>Bid Amount</th><th>Technical</th><th>Commercial</th><th>Sharia</th><th>HSE</th><th>Weighted Score</th><th>Recommendation</th></tr></thead>
              <tbody>
                <t t-foreach="o.invitee_ids.sorted(key=lambda r: r.evaluation_rank)" t-as="inv">
                  <tr><td><t t-esc="inv.evaluation_rank"/></td><td><t t-esc="inv.partner_id.name"/></td>
                  <td><t t-esc="inv.bid_amount"/></td><td><t t-esc="inv.score_technical"/></td>
                  <td><t t-esc="inv.score_commercial"/></td><td><t t-esc="inv.score_sharia"/></td>
                  <td><t t-esc="inv.score_hse"/></td><td><t t-esc="inv.weighted_score"/>%</td>
                  <td><t t-esc="inv.recommendation"/></td></tr>
                </t>
              </tbody>
            </table>
            <t t-if="o.state == 'awarded'"><p><b>AWARDED TO:</b> <t t-esc="o.awarded_invitee_id.partner_id.name"/> — <t t-esc="o.awarded_amount"/> <t t-esc="o.currency_id.symbol"/></p></t>
          </div>
        </t>
      </t>
    </t>
  </template>
  <record id="action_report_tender" model="ir.actions.report">
    <field name="name">Tender Report</field><field name="model">salaam.tender</field>
    <field name="report_type">qweb-pdf</field><field name="report_name">salaam_procurement.report_tender</field>
    <field name="binding_model_id" ref="model_salaam_tender"/><field name="binding_type">report</field>
  </record>
</odoo>