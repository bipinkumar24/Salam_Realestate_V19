<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_property_sector_list" model="ir.ui.view">
        <field name="name">property.sector.list</field>
        <field name="model">property.sector</field>
        <field name="arch" type="xml">
            <list string="Business Sectors" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_property_sector_form" model="ir.ui.view">
        <field name="name">property.sector.form</field>
        <field name="model">property.sector</field>
        <field name="arch" type="xml">
            <form string="Business Sector">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_property_sector" model="ir.actions.act_window">
        <field name="name">Business Sectors</field>
        <field name="res_model">property.sector</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
