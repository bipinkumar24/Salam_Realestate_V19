<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Module category -->
        <record id="module_category_property_investment" model="ir.module.category">
            <field name="name">Property Investment</field>
            <field name="description">Property Investment Appraisal</field>
            <field name="sequence">90</field>
        </record>

        <!-- Privilege -->
        <record id="privilege_property_investment_appraisal" model="res.groups.privilege">
            <field name="name">Property Investment Appraisal</field>
            <field name="category_id" ref="property_investment_appraisal.module_category_property_investment"/>
            <field name="sequence">10</field>
        </record>

        <!-- Credit Officer: can create and edit applications -->
        <record id="group_credit_officer" model="res.groups">
            <field name="name">Credit Officer</field>
            <field name="privilege_id" ref="property_investment_appraisal.privilege_property_investment_appraisal"/>
            <field name="comment">Can create, view and submit investment applications.</field>
        </record>

        <!-- Credit Manager: can approve/reject -->
        <record id="group_credit_manager" model="res.groups">
            <field name="name">Credit Manager</field>
            <field name="privilege_id" ref="property_investment_appraisal.privilege_property_investment_appraisal"/>
            <field name="implied_ids" eval="[(4, ref('group_credit_officer'))]"/>
            <field name="comment">Can approve, reject or conditionally approve applications.</field>
        </record>

        <!-- Admin: full access -->
        <record id="group_credit_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="privilege_id" ref="property_investment_appraisal.privilege_property_investment_appraisal"/>
            <field name="implied_ids" eval="[(4, ref('group_credit_manager'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
