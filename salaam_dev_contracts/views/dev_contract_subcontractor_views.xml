<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── SUBCONTRACTOR ── -->
    <record id="view_dev_contract_subcontractor_form" model="ir.ui.view">
        <field name="name">dev.contract.subcontractor.form</field>
        <field name="model">dev.contract.subcontractor</field>
        <field name="arch" type="xml">
            <form string="Subcontractor Agreement">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_under_review" string="Under Review" type="object"
                            invisible="state != 'submitted'"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary"
                            groups="salaam_dev_contracts.group_dev_contracts_manager"
                            invisible="state != 'under_review'"/>
                    <button name="action_sign" string="Mark Signed" type="object"
                            invisible="state != 'approved'"/>
                    <button name="action_activate" string="Activate" type="object"
                            invisible="state != 'signed'"/>
                    <button name="action_complete" string="Complete" type="object"
                            invisible="state != 'active'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                           invisible="state in ['completed','cancelled']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,under_review,approved,signed,active,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_milestones" type="object"
                                class="oe_stat_button" icon="fa-flag">
                            <field name="milestone_count" widget="statinfo" string="Milestones"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <h3>Subcontractor Agreement</h3>
                    </div>
                    <group>
                        <group string="Parties">
                            <field name="main_contractor_id"/>
                            <field name="subcontractor_id"/>
                            <field name="parent_istisna_id"/>
                            <field name="officer_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Financial">
                            <field name="currency_id"/>
                            <field name="subcontract_value"/>
                            <field name="contract_value"/>
                            <field name="retention_rate"/>
                            <field name="payment_terms_days"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Scope of Works">
                            <group>
                                <field name="works_category"/>
                                <field name="date_start"/>
                                <field name="date_end"/>
                            </group>
                            <separator string="Detailed Scope"/>
                            <field name="scope_of_works"/>
                        </page>
                        <page string="Site &amp; Legal">
                            <group>
                                <group>
                                    <field name="insurance_required"/>
                                    <field name="insurance_value" required="insurance_required"/>
                                </group>
                            </group>
                            <separator string="Site Access &amp; HSE"/>
                            <field name="site_access_conditions"/>
                            <separator string="Variation Order Procedure"/>
                            <field name="variation_order_procedure"/>
                        </page>
                        <page string="Milestones">
                            <field name="milestone_ids" context="{'default_res_model': 'dev.contract.subcontractor', 'default_res_id': id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="planned_date"/>
                                    <field name="payment_amount"/>
                                    <field name="retention_held"/>
                                    <field name="net_payable" readonly="1"/>
                                    <field name="state"/>
                                    <field name="res_model" invisible="1"/>
                                    <field name="res_id" invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Clauses">
                            <field name="clause_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_dev_contract_subcontractor_tree" model="ir.ui.view">
        <field name="name">dev.contract.subcontractor.tree</field>
        <field name="model">dev.contract.subcontractor</field>
        <field name="arch" type="xml">
            <list string="Subcontractor Agreements"
                  decoration-success="state in ('signed','active','completed')"
                  decoration-warning="state=='under_review'">
                <field name="name"/>
                <field name="main_contractor_id"/>
                <field name="subcontractor_id"/>
                <field name="works_category"/>
                <field name="parent_istisna_id"/>
                <field name="subcontract_value" sum="Total"/>
                <field name="currency_id" invisible="1"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('signed','active','completed')"
                       decoration-warning="state=='under_review'"
                       decoration-danger="state=='cancelled'"/>
            </list>
        </field>
    </record>

    <record id="action_dev_contract_subcontractor" model="ir.actions.act_window">
        <field name="name">Subcontractor Agreements</field>
        <field name="res_model">dev.contract.subcontractor</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'default_contract_type': 'subcontractor'}</field>
    </record>

</odoo>
