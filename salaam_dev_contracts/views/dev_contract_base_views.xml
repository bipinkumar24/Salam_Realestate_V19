<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── CLAUSE LIBRARY VIEWS ── -->
    <record id="view_dev_contract_clause_form" model="ir.ui.view">
        <field name="name">dev.contract.clause.form</field>
        <field name="model">dev.contract.clause</field>
        <field name="arch" type="xml">
            <form string="Contract Clause">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="clause_code"/>
                            <field name="contract_types" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="sharia_applicable"/>
                            <field name="is_mandatory"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Clause Text">
                            <field name="content"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dev_contract_clause_tree" model="ir.ui.view">
        <field name="name">dev.contract.clause.list</field>
        <field name="model">dev.contract.clause</field>
        <field name="arch" type="xml">
            <list string="Clause Library">
                <field name="clause_code"/>
                <field name="name"/>
                <field name="contract_types" widget="many2many_tags"/>
                <field name="sharia_applicable"/>
                <field name="is_mandatory"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_dev_contract_clause" model="ir.actions.act_window">
        <field name="name">Clause Library</field>
        <field name="res_model">dev.contract.clause</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ── MILESTONE VIEWS ── -->
    <record id="view_dev_contract_milestone_form" model="ir.ui.view">
        <field name="name">dev.contract.milestone.form</field>
        <field name="model">dev.contract.milestone</field>
        <field name="arch" type="xml">
            <form string="Milestone">
                <header>
                    <button name="action_mark_completed" string="Mark Completed"
                            type="object" class="btn-primary" invisible="state in ['completed','paid']"/>
                    <button name="action_mark_paid" string="Mark Paid"
                            type="object" invisible="state != 'completed'"/>
                    <button name="action_create_invoice" string="Create Invoice"
                            type="object" invisible="not invoice_id"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,in_progress,completed,paid"/>
                </header>
                <sheet>
                    <group>
                        <group string="Milestone Details">
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="planned_date"/>
                            <field name="actual_date"/>
                            <field name="verified_by"/>
                        </group>
                        <group string="Payment">
                            <field name="currency_id" invisible="1"/>
                            <field name="payment_amount"/>
                            <field name="payment_pct" readonly="1"/>
                            <field name="retention_held"/>
                            <field name="net_payable" readonly="1"/>
                            <field name="invoice_id" readonly="1"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Milestone completion notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dev_contract_milestone_tree" model="ir.ui.view">
        <field name="name">dev.contract.milestone.tree</field>
        <field name="model">dev.contract.milestone</field>
        <field name="arch" type="xml">
            <list string="Milestones" editable="bottom"
                  decoration-success="state=='paid'"
                  decoration-warning="state=='overdue'"
                  decoration-muted="state=='pending'">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="planned_date"/>
                <field name="actual_date"/>
                <field name="currency_id" invisible="1"/>
                <field name="payment_amount"/>
                <field name="payment_pct" readonly="1"/>
                <field name="retention_held"/>
                <field name="net_payable" readonly="1"/>
                <field name="state"/>
                <field name="invoice_id"/>
            </list>
        </field>
    </record>

    <record id="action_dev_contract_milestone_all" model="ir.actions.act_window">
        <field name="name">All Milestones</field>
        <field name="res_model">dev.contract.milestone</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
    </record>

</odoo>
