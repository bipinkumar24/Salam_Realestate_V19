<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dev_contract_sale_form" model="ir.ui.view">
        <field name="name">dev.contract.sale.form</field>
        <field name="model">dev.contract.sale</field>
        <field name="arch" type="xml">
            <form string="Sale Contract">
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_under_review" string="Under Review" type="object"
                            invisible="state != 'submitted'"/>
                    <button name="action_approve" string="Approve" type="object"
                            class="btn-primary"
                            groups="salaam_dev_contracts.group_dev_contracts_manager"
                            invisible="state != 'under_review'"/>
                    <button name="action_sign" string="Mark Signed" type="object"
                            invisible="state != 'approved'"/>
                    <button name="action_activate" string="Activate" type="object"
                            invisible="state != 'signed'"/>
                    <button name="action_complete" string="Complete" type="object"
                            invisible="state != 'active'"/>
                    <button name="action_certify_sharia" string="☽ Certify Sharia" type="object"
                            groups="salaam_dev_contracts.group_dev_contracts_sharia"
                            invisible="not sharia_required or sharia_certified"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ['completed','cancelled']"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state not in ['submitted','cancelled']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,under_review,approved,signed,active,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_milestones" type="object"
                                class="oe_stat_button" icon="fa-flag">
                            <field name="milestone_count" widget="statinfo" string="Milestones"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <h3><field name="contract_type" readonly="1"/></h3>
                    </div>
                    <group>
                        <group string="Parties">
                            <field name="buyer_id"/>
                            <field name="seller_id"/>
                            <field name="officer_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Sharia">
                            <field name="sharia_required"/>
                            <field name="sharia_certified" readonly="1"/>
                            <field name="sharia_ref" invisible="not sharia_required"/>
                            <field name="sharia_certified_by" readonly="1" invisible="not sharia_required"/>
                            <field name="sharia_certified_date" readonly="1" invisible="not sharia_required"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="General">
                            <group>
                                <group string="Property">
                                    <field name="property_id"/>
                                    <field name="title_file_no" readonly="1"/>
                                    <field name="bre_application_id"/>
                                    <field name="transfer_date"/>
                                </group>
                                <group string="Dates">
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                </group>
                            </group>
                            <group string="Property Condition">
                                <field name="property_condition" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Financial">
                            <group>
                                <group>
                                    <field name="currency_id"/>
                                    <field name="purchase_price"/>
                                    <field name="contract_value"/>
                                    <field name="down_payment"/>
                                    <field name="down_payment_date"/>
                                    <field name="balance_due" readonly="1"/>
                                </group>
                                <group>
                                    <field name="warranty_period"/>
                                    <field name="penalty_rate"/>
                                    <field name="governing_law"/>
                                </group>
                            </group>
                        </page>
                        <page string="Milestones">
                            <field name="milestone_ids" context="{'default_res_model': 'dev.contract.sale', 'default_res_id': id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="planned_date"/>
                                    <field name="payment_amount"/>
                                    <field name="payment_pct" readonly="1"/>
                                    <field name="retention_held"/>
                                    <field name="net_payable" readonly="1"/>
                                    <field name="state"/>
                                    <field name="res_model" invisible="1"/>
                                    <field name="res_id" invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Clauses">
                            <field name="clause_ids" widget="many2many_tags"/>
                            <separator string="Clause Content"/>
                            <field name="clause_ids">
                                <list>
                                    <field name="clause_code"/>
                                    <field name="name"/>
                                    <field name="sharia_applicable"/>
                                    <field name="is_mandatory"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_dev_contract_sale_tree" model="ir.ui.view">
        <field name="name">dev.contract.sale.tree</field>
        <field name="model">dev.contract.sale</field>
        <field name="arch" type="xml">
            <list string="Sale Contracts"
                  decoration-success="state in ('signed','active','completed')"
                  decoration-warning="state=='under_review'"
                  decoration-muted="state=='cancelled'">
                <field name="name"/>
                <field name="buyer_id"/>
                <field name="property_id"/>
                <field name="purchase_price" sum="Total"/>
                <field name="currency_id" invisible="1"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="sharia_required" widget="boolean_toggle"/>
                <field name="sharia_certified" widget="boolean_toggle"/>
                <field name="officer_id"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('signed','active','completed')"
                       decoration-warning="state=='under_review'"
                       decoration-danger="state=='cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_dev_contract_sale_kanban" model="ir.ui.view">
        <field name="name">dev.contract.sale.kanban</field>
        <field name="model">dev.contract.sale</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="buyer_id"/>
                <field name="purchase_price"/>
                <field name="currency_id"/>
                <field name="state"/>
                <field name="sharia_certified"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div><field name="buyer_id"/></div>
                                <div><field name="purchase_price"/> <field name="currency_id"/></div>
                                <div t-if="record.sharia_certified.value">
                                    <span class="badge badge-success">☽ Sharia Certified</span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_dev_contract_sale_search" model="ir.ui.view">
        <field name="name">dev.contract.sale.search</field>
        <field name="model">dev.contract.sale</field>
        <field name="arch" type="xml">
            <search string="Sale Contracts">
                <field name="name" string="Reference"/>
                <field name="buyer_id"/>
                <field name="property_id"/>
                <filter string="My Contracts" name="my_contracts"
                        domain="[('officer_id','=',uid)]"/>
                <filter string="Sharia Required" name="sharia_required"
                        domain="[('sharia_required','=',True)]"/>
                <filter string="Pending Certification" name="pending_cert"
                        domain="[('sharia_required','=',True),('sharia_certified','=',False)]"/>
                <filter string="Active" name="active"
                        domain="[('state','=','active')]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Under Review" name="under_review" domain="[('state','=','under_review')]"/>
                <filter string="Completed" name="completed" domain="[('state','=','completed')]"/>
                <group>
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    <filter string="Branch" name="group_company" context="{'group_by':'company_id'}"/>
                    <filter string="Officer" name="group_officer" context="{'group_by':'officer_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_dev_contract_sale" model="ir.actions.act_window">
        <field name="name">Sale Contracts</field>
        <field name="res_model">dev.contract.sale</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_dev_contract_sale_search"/>
        <field name="context">{'default_contract_type': 'sale'}</field>
    </record>

</odoo>
