<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Paper Format -->
    <record id="paperformat_dev_contract_a4" model="report.paperformat">
        <field name="name">Salaam Contract — A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">25</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">20</field>
        <field name="margin_right">20</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">10</field>
        <field name="dpi">90</field>
    </record>

    <!-- Sale Contract Report -->
    <record id="action_report_dev_contract_sale" model="ir.actions.report">
        <field name="name">Sale Contract</field>
        <field name="model">dev.contract.sale</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">salaam_dev_contracts.report_dev_contract_sale</field>
        <field name="report_file">salaam_dev_contracts.report_dev_contract_sale</field>
        <field name="paperformat_id" ref="paperformat_dev_contract_a4"/>
        <field name="binding_model_id" ref="model_dev_contract_sale"/>
        <field name="binding_type">report</field>
    </record>

