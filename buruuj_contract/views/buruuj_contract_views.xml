<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_buruuj_contract_list" model="ir.ui.view">
        <field name="name">buruuj.contract.list</field>
        <field name="model">buruuj.contract</field>
        <field name="arch" type="xml">
            <list>
                <field name="reference"/>
                <field name="name"/>
                <field name="type"/>
                <field name="counterparty_id"/>
                <field name="project_id"/>
                <field name="commencement_date"/>
                <field name="completion_date"/>
                <field name="contract_value" sum="Total"/>
                <field name="state" widget="badge"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>
    <record id="view_buruuj_contract_form" model="ir.ui.view">
        <field name="name">buruuj.contract.form</field>
        <field name="model">buruuj.contract</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" string="Activate" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_complete" string="Complete" type="object"
                            invisible="state != 'active'"/>
                    <button name="action_terminate" string="Terminate" type="object"
                            invisible="state in ('completed','terminated','expired','draft')"/>
                    <button name="action_expire" string="Mark Expired" type="object"
                            invisible="state in ('completed','terminated','expired','draft')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <h3><field name="reference"/></h3>
                    </div>
                    <group>
                        <group>
                            <field name="type"/>
                            <field name="counterparty_id"/>
                            <field name="project_id"/>
                            <field name="contract_value"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="commencement_date"/>
                            <field name="completion_date"/>
                            <field name="dlp_end_date"/>
                        </group>
                    </group>
                    <group string="Bonds &amp; Insurance">
                        <group>
                            <field name="performance_bond_amount"/>
                            <field name="performance_bond_expiry"/>
                        </group>
                        <group>
                            <field name="advance_bond_amount"/>
                            <field name="advance_bond_expiry"/>
                            <field name="insurance_expiry"/>
                        </group>
                    </group>
                    <field name="notes"/>
                    <field name="attachment_ids" widget="many2many_binary"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_buruuj_contract" model="ir.actions.act_window">
        <field name="name">Contracts</field>
        <field name="res_model">buruuj.contract</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_buruuj_claim_list" model="ir.ui.view">
        <field name="name">buruuj.claim.list</field>
        <field name="model">buruuj.claim</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_id"/>
                <field name="type"/>
                <field name="direction"/>
                <field name="date"/>
                <field name="eot_days"/>
                <field name="cost_amount" sum="Claimed"/>
                <field name="awarded_amount" sum="Awarded"/>
                <field name="state" widget="badge"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>
    <record id="view_buruuj_claim_form" model="ir.ui.view">
        <field name="name">buruuj.claim.form</field>
        <field name="model">buruuj.claim</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_negotiate" string="Mark Negotiating" type="object"
                            invisible="state != 'submitted'"/>
                    <button name="action_award" string="Mark Awarded" type="object"
                            class="oe_highlight" invisible="state not in ('submitted','negotiating')"/>
                    <button name="action_reject" string="Mark Rejected" type="object"
                            invisible="state not in ('submitted','negotiating')"/>
                    <button name="action_withdraw" string="Withdraw" type="object"
                            invisible="state in ('awarded','rejected','withdrawn','draft')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="contract_id"/>
                            <field name="type"/>
                            <field name="direction"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="claim_period_start"/>
                            <field name="claim_period_end"/>
                            <field name="eot_days"/>
                            <field name="cost_amount"/>
                            <field name="awarded_days"/>
                            <field name="awarded_amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description"><field name="description"/></page>
                        <page string="Contractual Basis"><field name="contractual_basis"/></page>
                        <page string="Supporting Evidence">
                            <field name="supporting_evidence"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_buruuj_claim" model="ir.actions.act_window">
        <field name="name">Claims</field>
        <field name="res_model">buruuj.claim</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
