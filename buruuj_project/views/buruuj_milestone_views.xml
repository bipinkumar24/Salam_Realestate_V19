<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_buruuj_milestone_list" model="ir.ui.view">
        <field name="name">buruuj.milestone.list</field>
        <field name="model">buruuj.milestone</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_id"/>
                <field name="planned_date"/>
                <field name="actual_date"/>
                <field name="amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_buruuj_milestone_form" model="ir.ui.view">
        <field name="name">buruuj.milestone.form</field>
        <field name="model">buruuj.milestone</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                <field name="project_id"/>
                <field name="planned_date"/>
                <field name="actual_date"/>
                <field name="amount"/>
                <field name="state"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_buruuj_milestone" model="ir.actions.act_window">
        <field name="name">Milestones</field>
        <field name="res_model">buruuj.milestone</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
