<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_buruuj_risk_list" model="ir.ui.view">
        <field name="name">buruuj.risk.list</field>
        <field name="model">buruuj.risk</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_id"/>
                <field name="category"/>
                <field name="likelihood"/>
                <field name="impact"/>
                <field name="severity"/>
                <field name="owner_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_buruuj_risk_form" model="ir.ui.view">
        <field name="name">buruuj.risk.form</field>
        <field name="model">buruuj.risk</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                <field name="project_id"/>
                <field name="category"/>
                <field name="likelihood"/>
                <field name="impact"/>
                <field name="severity"/>
                <field name="owner_id"/>
                <field name="state"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_buruuj_risk" model="ir.actions.act_window">
        <field name="name">Project Risks</field>
        <field name="res_model">buruuj.risk</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
