<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_buruuj_subcontract_list" model="ir.ui.view">
        <field name="name">buruuj.subcontract.list</field>
        <field name="model">buruuj.subcontract</field>
        <field name="arch" type="xml">
            <list decoration-success="state in ('completed','closed')"
                  decoration-danger="state=='terminated'"
                  decoration-info="state=='in_progress'">
                <field name="name"/>
                <field name="title"/>
                <field name="project_id"/>
                <field name="partner_id"/>
                <field name="trade_id"/>
                <field name="contract_value" sum="Total"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="view_buruuj_subcontract_form" model="ir.ui.view">
        <field name="name">buruuj.subcontract.form</field>
        <field name="model">buruuj.subcontract</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" string="Approve" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_sign" string="Mark Signed" type="object"
                            class="oe_highlight" invisible="state != 'approved'"/>
                    <button name="action_start" string="Start Work" type="object"
                            class="oe_highlight" invisible="state != 'signed'"/>
                    <button name="action_complete" string="Practically Complete"
                            type="object" invisible="state != 'in_progress'"/>
                    <button name="action_enter_dlp" string="Enter DLP" type="object"
                            invisible="state != 'completed'"/>
                    <button name="action_close" string="Close" type="object"
                            invisible="state != 'dlp'"/>
                    <button name="action_terminate" string="Terminate" type="object"
                            invisible="state in ('draft','closed','terminated')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,approved,signed,in_progress,completed,dlp,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_workorders" type="object"
                                class="oe_stat_button" icon="fa-list">
                            <field name="workorder_count" widget="statinfo"
                                   string="Work Orders"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <h3><field name="title"/></h3>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="partner_id"/>
                            <field name="trade_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="dlp_months"/>
                            <field name="dlp_end"/>
                            <field name="payment_terms"/>
                        </group>
                    </group>
                    <group>
                        <group string="Financial">
                            <field name="contract_value"/>
                            <field name="advance_percent"/>
                            <field name="advance_amount"/>
                            <field name="retention_percent"/>
                            <field name="retention_amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Bonds &amp; Insurance">
                            <field name="performance_bond_amount"/>
                            <field name="performance_bond_expiry"/>
                            <field name="insurance_expiry"/>
                            <field name="ld_percent_per_day"/>
                            <field name="ld_cap_percent"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Scope of Work">
                            <field name="scope_of_work"/>
                        </page>
                        <page string="BOQ Lines">
                            <field name="line_ids" context="{'default_project_id': project_id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="project_id" column_invisible="1"/>
                                    <field name="boq_line_id"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="item_no"/>
                                    <field name="description"/>
                                    <field name="uom_id"/>
                                    <field name="quantity"/>
                                    <field name="unit_rate"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Work Orders">
                            <field name="workorder_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="title"/>
                                    <field name="date"/>
                                    <field name="amount"/>
                                    <field name="progress" widget="progressbar"/>
                                    <field name="state" widget="badge"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_buruuj_subcontract" model="ir.actions.act_window">
        <field name="name">Subcontracts</field>
        <field name="res_model">buruuj.subcontract</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
