<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_buruuj_rate_list" model="ir.ui.view">
        <field name="name">buruuj.rate.list</field>
        <field name="model">buruuj.rate</field>
        <field name="arch" type="xml">
            <list string="Master Rates">
                <field name="code"/>
                <field name="name"/>
                <field name="category"/>
                <field name="trade_id"/>
                <field name="uom_id"/>
                <field name="unit_rate" sum="Total"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="valid_from"/>
                <field name="active" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_buruuj_rate_form" model="ir.ui.view">
        <field name="name">buruuj.rate.form</field>
        <field name="model">buruuj.rate</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="category"/>
                            <field name="trade_id"/>
                        </group>
                        <group>
                            <field name="uom_id"/>
                            <field name="unit_rate"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="valid_from"/>
                            <field name="valid_to"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes about this rate..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_buruuj_rate_search" model="ir.ui.view">
        <field name="name">buruuj.rate.search</field>
        <field name="model">buruuj.rate</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name"/>
                <field name="trade_id"/>
                <filter string="Labor" name="cat_labor" domain="[('category','=','labor')]"/>
                <filter string="Material" name="cat_material" domain="[('category','=','material')]"/>
                <filter string="Equipment" name="cat_equipment" domain="[('category','=','equipment')]"/>
                <filter string="Subcontractor" name="cat_sub" domain="[('category','=','subcontractor')]"/>
                <group>
                    <filter string="Category" name="g_cat" context="{'group_by': 'category'}"/>
                    <filter string="Trade" name="g_trade" context="{'group_by': 'trade_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_buruuj_rate" model="ir.actions.act_window">
        <field name="name">Master Rates</field>
        <field name="res_model">buruuj.rate</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
