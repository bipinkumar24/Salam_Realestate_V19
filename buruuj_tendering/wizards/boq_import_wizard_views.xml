<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_buruuj_boq_import_wizard_form" model="ir.ui.view">
            <field name="name">buruuj.boq.import.wizard.form</field>
            <field name="model">buruuj.boq.import.wizard</field>
            <field name="arch" type="xml">
                <form string="Import BOQ from CSV">
                    <sheet>
                        <group invisible="state == 'done'">
                            <group string="Source">
                                <field name="boq_id" readonly="1"/>
                                <field name="csv_file" filename="csv_filename" widget="binary"/>
                                <field name="csv_filename" invisible="1"/>
                            </group>
                            <group string="Alignment Options">
                                <field name="auto_align"/>
                                <field name="match_threshold" invisible="not auto_align"/>
                                <field name="use_ai"/>
                                <field name="replace_existing"/>
                            </group>
                        </group>

                        <div class="alert alert-info" role="alert" invisible="state == 'done'">
                            <strong>Expected CSV columns</strong> (case-insensitive, others ignored):
                            <code>section_code, section_name, item_no, description, uom, quantity, unit_rate</code><br/>
                            <strong>Optional:</strong>
                            <code>labor_cost, material_cost, equipment_cost, subcontract_cost, wastage_percent, trade, notes</code><br/>
                            Sections are auto-created from <code>section_code</code> + <code>section_name</code>.
                        </div>

                        <group string="Result" invisible="state == 'draft'">
                            <field name="rows_imported" readonly="1"/>
                            <field name="rows_matched" readonly="1"/>
                            <field name="rows_ai_matched" readonly="1" invisible="rows_ai_matched == 0"/>
                            <field name="rows_unmatched" readonly="1"/>
                        </group>
                        <field name="result_message" readonly="1" nolabel="1" widget="text"
                               invisible="state == 'draft'"/>
                    </sheet>
                    <footer>
                        <button name="action_import" string="Import"
                                type="object" class="btn-primary"
                                invisible="state == 'done'"/>
                        <button name="action_open_boq" string="Open BOQ"
                                type="object" class="btn-primary"
                                invisible="state == 'draft'"/>
                        <button string="Close" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_buruuj_boq_import_wizard" model="ir.actions.act_window">
            <field name="name">Import BOQ from CSV</field>
            <field name="res_model">buruuj.boq.import.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_buruuj_boq"/>
            <field name="binding_view_types">form</field>
        </record>

    </data>
</odoo>