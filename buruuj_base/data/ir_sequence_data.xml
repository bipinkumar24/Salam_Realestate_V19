<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_buruuj_tender" model="ir.sequence">
            <field name="name">Buruuj Tender Reference</field>
            <field name="code">buruuj.tender</field>
            <field name="prefix">TND/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_buruuj_project_code" model="ir.sequence">
            <field name="name">Buruuj Project Code</field>
            <field name="code">buruuj.project.code</field>
            <field name="prefix">PRJ/%(year)s/</field>
            <field name="padding">4</field>
        </record>

        <record id="seq_buruuj_subcontract" model="ir.sequence">
            <field name="name">Subcontract Number</field>
            <field name="code">buruuj.subcontract</field>
            <field name="prefix">SC/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_buruuj_work_order" model="ir.sequence">
            <field name="name">Subcontractor Work Order</field>
            <field name="code">buruuj.work.order</field>
            <field name="prefix">WO/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_buruuj_ipc_client" model="ir.sequence">
            <field name="name">Client IPC</field>
            <field name="code">buruuj.ipc.client</field>
            <field name="prefix">CIPC/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_buruuj_ipc_sub" model="ir.sequence">
            <field name="name">Subcontractor IPC</field>
            <field name="code">buruuj.ipc.subcontractor</field>
            <field name="prefix">SIPC/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_buruuj_dpr" model="ir.sequence">
            <field name="name">Daily Progress Report</field>
            <field name="code">buruuj.dpr</field>
            <field name="prefix">DPR/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
        </record>

        <record id="seq_buruuj_rfi" model="ir.sequence">
            <field name="name">Request for Information</field>
            <field name="code">buruuj.rfi</field>
            <field name="prefix">RFI/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_buruuj_ncr" model="ir.sequence">
            <field name="name">Non-Conformance Report</field>
            <field name="code">buruuj.ncr</field>
            <field name="prefix">NCR/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_buruuj_variation" model="ir.sequence">
            <field name="name">Variation Order</field>
            <field name="code">buruuj.variation</field>
            <field name="prefix">VO/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_buruuj_incident" model="ir.sequence">
            <field name="name">HSE Incident</field>
            <field name="code">buruuj.hse.incident</field>
            <field name="prefix">INC/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_buruuj_ptw" model="ir.sequence">
            <field name="name">Permit to Work</field>
            <field name="code">buruuj.ptw</field>
            <field name="prefix">PTW/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_buruuj_drawing" model="ir.sequence">
            <field name="name">Drawing Number</field>
            <field name="code">buruuj.drawing</field>
            <field name="prefix">DWG/</field>
            <field name="padding">5</field>
        </record>

    </data>
</odoo>
