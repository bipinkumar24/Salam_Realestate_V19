<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Top-level category -->
        <record id="module_category_buruuj" model="ir.module.category">
            <field name="name">Buruuj Construction</field>
            <field name="description">Roles for Buruuj 360° Construction Management</field>
            <field name="sequence">20</field>
        </record>
    <record id="privilege_buruuj_base" model="res.groups.privilege">
      <field name="name">buruuj_base</field>
      <field name="category_id" ref="module_category_buruuj"/>
      <field name="sequence">30</field>
    </record>

        <!-- Site User (data entry on site) -->
        <record id="group_buruuj_site_user" model="res.groups">
            <field name="name">Site User</field>
            <field name="privilege_id" ref="privilege_buruuj_base"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Site Engineer -->
        <record id="group_buruuj_site_engineer" model="res.groups">
            <field name="name">Site Engineer</field>
            <field name="privilege_id" ref="privilege_buruuj_base"/>
            <field name="implied_ids" eval="[(4, ref('group_buruuj_site_user'))]"/>
        </record>

        <!-- QS / Quantity Surveyor -->
        <record id="group_buruuj_qs" model="res.groups">
            <field name="name">Quantity Surveyor</field>
            <field name="privilege_id" ref="privilege_buruuj_base"/>
            <field name="implied_ids" eval="[(4, ref('group_buruuj_site_engineer'))]"/>
        </record>

        <!-- Project Manager -->
        <record id="group_buruuj_pm" model="res.groups">
            <field name="name">Project Manager</field>
            <field name="privilege_id" ref="privilege_buruuj_base"/>
            <field name="implied_ids" eval="[(4, ref('group_buruuj_qs'))]"/>
        </record>

        <!-- HSE Officer -->
        <record id="group_buruuj_hse" model="res.groups">
            <field name="name">HSE Officer</field>
            <field name="privilege_id" ref="privilege_buruuj_base"/>
            <field name="implied_ids" eval="[(4, ref('group_buruuj_site_user'))]"/>
        </record>

        <!-- Storekeeper -->
        <record id="group_buruuj_storekeeper" model="res.groups">
            <field name="name">Storekeeper</field>
            <field name="privilege_id" ref="privilege_buruuj_base"/>
            <field name="implied_ids" eval="[(4, ref('group_buruuj_site_user'))]"/>
        </record>

        <!-- Director / Executive -->
        <record id="group_buruuj_director" model="res.groups">
            <field name="name">Director / Executive</field>
            <field name="privilege_id" ref="privilege_buruuj_base"/>
            <field name="implied_ids" eval="[(4, ref('group_buruuj_pm'))]"/>
        </record>

        <!-- Manager (full access for the Buruuj suite) -->
        <record id="group_buruuj_manager" model="res.groups">
            <field name="name">Construction Manager / Admin</field>
            <field name="privilege_id" ref="privilege_buruuj_base"/>
            <field name="implied_ids" eval="[(4, ref('group_buruuj_director'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
