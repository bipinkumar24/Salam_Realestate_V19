<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_buruuj_trade_list" model="ir.ui.view">
        <field name="name">buruuj.trade.list</field>
        <field name="model">buruuj.trade</field>
        <field name="arch" type="xml">
            <list string="Trades">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="parent_id"/>
                <field name="active" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_buruuj_trade_form" model="ir.ui.view">
        <field name="name">buruuj.trade.form</field>
        <field name="model">buruuj.trade</field>
        <field name="arch" type="xml">
            <form string="Trade">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="parent_id"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Description of this trade..."/>
                    <notebook>
                        <page string="Sub-trades">
                            <field name="child_ids">
                                <list editable="bottom">
                                    <field name="code"/>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_buruuj_trade" model="ir.actions.act_window">
        <field name="name">Trades</field>
        <field name="res_model">buruuj.trade</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
