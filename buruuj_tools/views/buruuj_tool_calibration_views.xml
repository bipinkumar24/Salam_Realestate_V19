<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tool_calibration_list" model="ir.ui.view">
        <field name="name">buruuj.tool.calibration.list</field>
        <field name="model">buruuj.tool.calibration</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'done'"
                  decoration-danger="state == 'failed'"
                  decoration-info="state == 'in_progress'">
                <field name="tool_id"/>
                <field name="calibration_date"/>
                <field name="next_due_date"/>
                <field name="certificate_no"/>
                <field name="calibration_lab"/>
                <field name="cost" sum="Total"/>
                <field name="result"/>
                <field name="state" widget="badge"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_tool_calibration_form" model="ir.ui.view">
        <field name="name">buruuj.tool.calibration.form</field>
        <field name="model">buruuj.tool.calibration</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" string="Start Calibration"
                            type="object" class="oe_highlight"
                            invisible="state != 'scheduled'"/>
                    <button name="action_complete" string="Complete"
                            type="object" class="oe_highlight"
                            invisible="state != 'in_progress'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="tool_id"/>
                            <field name="calibration_date"/>
                            <field name="next_due_date"/>
                            <field name="certificate_no"/>
                        </group>
                        <group>
                            <field name="calibration_lab"/>
                            <field name="cost"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="result"/>
                        </group>
                    </group>
                    <field name="certificate_attachment"
                           filename="certificate_filename"/>
                    <field name="certificate_filename" invisible="1"/>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_tool_calibration" model="ir.actions.act_window">
        <field name="name">Calibrations</field>
        <field name="res_model">buruuj.tool.calibration</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
