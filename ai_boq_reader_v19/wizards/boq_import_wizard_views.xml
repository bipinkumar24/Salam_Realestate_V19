<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_boq_import_wizard_form" model="ir.ui.view">
        <field name="name">boq.import.wizard.form</field>
        <field name="model">boq.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Import Drawings">
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="project_id"/>
                        </group>
                        <group>
                            <field name="auto_analyze"/>
                        </group>
                    </group>
                    <separator string="Drawings"/>
                    <field name="attachment_ids" widget="many2many_binary"/>
                </sheet>
                <footer>
                    <button name="action_import" type="object" string="Import"
                            class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_boq_import_wizard" model="ir.actions.act_window">
        <field name="name">Bulk Import Drawings</field>
        <field name="res_model">boq.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
