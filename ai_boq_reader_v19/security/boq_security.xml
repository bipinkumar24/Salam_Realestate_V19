<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Module category (still used as the visual app grouping) -->
        <record id="module_category_boq" model="ir.module.category">
            <field name="name">BOQ AI Reader</field>
            <field name="description">Bill of Quantities with AI extraction</field>
            <field name="sequence">20</field>
        </record>

        <!-- v19: groups must reference a res.groups.privilege, which itself references the category. -->
        <record id="boq_privilege" model="res.groups.privilege">
            <field name="name">BOQ AI Reader</field>
            <field name="sequence">20</field>
            <field name="category_id" ref="module_category_boq"/>
        </record>

        <record id="group_boq_user" model="res.groups">
            <field name="name">User</field>
            <field name="sequence">10</field>
            <field name="privilege_id" ref="boq_privilege"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_boq_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="sequence">20</field>
            <field name="privilege_id" ref="boq_privilege"/>
            <field name="implied_ids" eval="[(4, ref('group_boq_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- BOQ project: users see their own; managers see everything -->
        <record id="rule_boq_project_user" model="ir.rule">
            <field name="name">BOQ: own records</field>
            <field name="model_id" ref="model_ai_boq_project"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_boq_user'))]"/>
        </record>

        <record id="rule_boq_project_manager" model="ir.rule">
            <field name="name">BOQ: all records (manager)</field>
            <field name="model_id" ref="model_ai_boq_project"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_boq_manager'))]"/>
        </record>

        <!-- Sequence -->
        <record id="seq_ai_boq_project" model="ir.sequence">
            <field name="name">BOQ Project Sequence</field>
            <field name="code">ai.boq.project</field>
            <field name="prefix">BOQ/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
