<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_tender_bid_decision" model="ir.sequence">
            <field name="name">Bid / No-Bid Decision</field>
            <field name="code">tender.bid.decision</field>
            <field name="prefix">BD/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_tender_bid_bond" model="ir.sequence">
            <field name="name">Bid Bond</field>
            <field name="code">tender.bid.bond</field>
            <field name="prefix">BB/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_tender_site_survey" model="ir.sequence">
            <field name="name">Site Survey</field>
            <field name="code">tender.site.survey</field>
            <field name="prefix">SS/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_tender_partner_agreement" model="ir.sequence">
            <field name="name">Partner Agreement</field>
            <field name="code">tender.partner.agreement</field>
            <field name="prefix">PA/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="cron_certificate_expiry" model="ir.cron">
            <field name="name">Pre-Tender: Certificate Expiry Check</field>
            <field name="model_id" ref="model_tender_compliance_certificate"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_expiring_certificates()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
