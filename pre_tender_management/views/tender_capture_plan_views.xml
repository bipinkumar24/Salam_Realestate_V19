<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tender_capture_plan_list" model="ir.ui.view">
        <field name="name">tender.capture.plan.list</field>
        <field name="model">tender.capture.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="opportunity_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_tender_capture_plan_form" model="ir.ui.view">
        <field name="name">tender.capture.plan.form</field>
        <field name="model">tender.capture.plan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" type="object" string="Activate" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_lock" type="object" string="Lock" invisible="state != 'active'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="opportunity_id"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <notebook>
                        <page string="Win Strategy" name="win_strategy">
                            <field name="win_strategy" nolabel="1"/>
                        </page>
                        <page string="Value Proposition" name="value_prop">
                            <field name="value_proposition" nolabel="1"/>
                        </page>
                        <page string="Win Themes &amp; Discriminators" name="themes">
                            <field name="win_theme_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="is_discriminator"/>
                                    <field name="addressed_in_volume"/>
                                    <field name="proof_points"/>
                                </list>
                            </field>
                        </page>
                        <page string="Milestones" name="milestones">
                            <field name="milestone_ids">
                                <list editable="bottom" decoration-success="state == 'done'" decoration-warning="state == 'in_progress'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="owner_id"/>
                                    <field name="deadline"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ghost / Counter-Strategy" name="ghost">
                            <field name="ghost_strategy" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_tender_capture_plan" model="ir.actions.act_window">
        <field name="name">Capture Plans</field>
        <field name="res_model">tender.capture.plan</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
