<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tender_alert_subscription_list" model="ir.ui.view">
        <field name="name">tender.alert.subscription.list</field>
        <field name="model">tender.alert.subscription</field>
        <field name="arch" type="xml">
            <list decoration-muted="not is_active">
                <field name="name"/>
                <field name="source"/>
                <field name="endpoint"/>
                <field name="keywords"/>
                <field name="last_polled"/>
                <field name="last_alert_count"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_tender_alert_subscription_form" model="ir.ui.view">
        <field name="name">tender.alert.subscription.form</field>
        <field name="model">tender.alert.subscription</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="source"/>
                            <field name="endpoint"/>
                            <field name="keywords"/>
                            <field name="is_active"/>
                        </group>
                        <group>
                            <field name="last_polled" readonly="1"/>
                            <field name="last_alert_count" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="country_ids" widget="many2many_tags"/>
                        <field name="sector_ids" widget="many2many_tags"/>
                    </group>
                    <group>
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_tender_alert_subscription" model="ir.actions.act_window">
        <field name="name">Lead Alert Subscriptions</field>
        <field name="res_model">tender.alert.subscription</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
