<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tender_opportunity_form" model="ir.ui.view">
        <field name="name">crm.lead.tender.form</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <field name="tender_state" widget="statusbar" statusbar_visible="draft,qualified,bid_decision,capture,kickoff,submitted,won" invisible="not is_tender"/>
                <button name="action_set_qualified" type="object" string="Mark Qualified" class="oe_highlight" invisible="not is_tender or tender_state != 'draft'"/>
                <button name="action_set_bid_decision" type="object" string="Enter Bid Decision" invisible="not is_tender or tender_state != 'qualified'"/>
                <button name="action_set_capture" type="object" string="Enter Capture" invisible="not is_tender or tender_state != 'bid_decision'"/>
                <button name="action_set_no_bid" type="object" string="No-Bid" invisible="not is_tender or tender_state not in ('qualified','bid_decision')"/>
            </xpath>

            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button class="oe_stat_button" name="action_open_compliance_matrix" type="object" icon="fa-check-square-o" invisible="not is_tender">
                    <field name="compliance_progress" widget="statinfo" string="Compliance %"/>
                </button>
                <button class="oe_stat_button" name="action_view_bid_decisions" type="object" icon="fa-gavel" invisible="not is_tender">
                    <field name="tier1_progress" widget="statinfo" string="Tier 1 %"/>
                </button>
                <button class="oe_stat_button" name="action_view_site_surveys" type="object" icon="fa-map-marker" invisible="not is_tender">
                    <field name="site_survey_count" widget="statinfo" string="Surveys"/>
                </button>
                <button class="oe_stat_button" name="action_view_bid_bonds" type="object" icon="fa-shield" invisible="not is_tender">
                    <field name="bid_bond_count" widget="statinfo" string="Bonds"/>
                </button>
                <button class="oe_stat_button" name="action_open_capture_plan" type="object" icon="fa-trophy" invisible="not is_tender">
                    <field name="tier2_progress" widget="statinfo" string="Tier 2 %"/>
                </button>
                <button class="oe_stat_button" name="action_view_risks" type="object" icon="fa-exclamation-triangle" invisible="not is_tender">
                    <field name="risk_count" widget="statinfo" string="Risks"/>
                </button>
                <button class="oe_stat_button" name="action_view_stakeholders" type="object" icon="fa-users" invisible="not is_tender">
                    <field name="stakeholder_count" widget="statinfo" string="Stakeholders"/>
                </button>
                <button class="oe_stat_button" name="action_view_competitors" type="object" icon="fa-flag-checkered" invisible="not is_tender">
                    <field name="competitor_count" widget="statinfo" string="Competitors"/>
                </button>
                <button class="oe_stat_button" name="action_view_kickoff_gates" type="object" icon="fa-flag" invisible="not is_tender">
                    <field name="kickoff_gate_count" widget="statinfo" string="Gates"/>
                </button>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Tender" name="tender" invisible="not is_tender">
                    <group>
                        <group string="Identification">
                            <field name="is_tender" invisible="1"/>
                            <field name="tender_reference"/>
                            <field name="client_id"/>
                            <field name="incumbent_id"/>
                            <field name="funding_source"/>
                        </group>
                        <group string="Submission">
                            <field name="submission_deadline"/>
                            <field name="submission_method"/>
                            <field name="tender_value_estimate"/>
                            <field name="company_currency" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Qualification">
                            <field name="eligibility_state"/>
                            <field name="pwin_manual"/>
                            <field name="pwin_ai" readonly="1"/>
                            <field name="qualification_complete" readonly="1"/>
                        </group>
                        <group string="Wired Tender">
                            <field name="is_wired_tender"/>
                            <field name="wired_tender_justification" invisible="not is_wired_tender" required="is_wired_tender"/>
                        </group>
                    </group>
                    <group string="Tier 1 Progress">
                        <field name="tier1_progress" widget="progressbar"/>
                        <field name="tier1_complete" readonly="1"/>
                    </group>
                    <group string="Compliance">
                        <field name="compliance_matrix_id" readonly="1"/>
                        <field name="compliance_progress" widget="progressbar" readonly="1"/>
                        <field name="required_certificate_ids" widget="many2many_tags"/>
                    </group>
                    <group string="Bid Decisions">
                        <field name="bid_decision_ids" nolabel="1" readonly="1">
                            <list>
                                <field name="name"/>
                                <field name="decision_date"/>
                                <field name="decision"/>
                                <field name="total_score"/>
                                <field name="state" widget="badge"/>
                            </list>
                        </field>
                    </group>
                </page>
                <page string="Site Survey" name="site_survey" invisible="not is_tender">
                    <field name="site_survey_ids" nolabel="1">
                        <list>
                            <field name="name"/>
                            <field name="survey_date"/>
                            <field name="team_lead_id"/>
                            <field name="line_count"/>
                            <field name="risk_count"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </page>
                <page string="Bonds" name="bonds" invisible="not is_tender">
                    <field name="bid_bond_ids" nolabel="1">
                        <list>
                            <field name="name"/>
                            <field name="bond_type"/>
                            <field name="required_amount" widget="monetary"/>
                            <field name="currency_id" column_invisible="True"/>
                            <field name="issuer_id"/>
                            <field name="validity_to"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </page>
                <page string="Capture &amp; Strategy" name="capture" invisible="not is_tender">
                    <group>
                        <field name="capture_plan_id"/>
                        <field name="tier2_progress" widget="progressbar"/>
                    </group>
                    <group string="Win Themes">
                        <field name="swot_ids" nolabel="1">
                            <list>
                                <field name="name"/>
                                <field name="competitor_id"/>
                            </list>
                        </field>
                    </group>
                </page>
                <page string="Risk Register" name="risks" invisible="not is_tender">
                    <field name="risk_ids" nolabel="1">
                        <list decoration-danger="severity == 'critical'" decoration-warning="severity == 'high'">
                            <field name="name"/>
                            <field name="category"/>
                            <field name="probability"/>
                            <field name="impact"/>
                            <field name="score"/>
                            <field name="severity" widget="badge"/>
                            <field name="owner_id"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </page>
                <page string="Bid Team" name="team" invisible="not is_tender">
                    <field name="bid_team_member_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="employee_id"/>
                            <field name="role"/>
                            <field name="allocation_pct"/>
                            <field name="is_key_personnel"/>
                        </list>
                    </field>
                </page>
                <page string="Partners &amp; Quotes" name="partners" invisible="not is_tender">
                    <group string="Partner Agreements">
                        <field name="partner_agreement_ids" nolabel="1">
                            <list>
                                <field name="name"/>
                                <field name="partner_id"/>
                                <field name="agreement_type"/>
                                <field name="sign_status" widget="badge"/>
                                <field name="validity_to"/>
                            </list>
                        </field>
                    </group>
                    <group string="Budget Quotes (3-Quote Rule)">
                        <field name="budget_quote_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="item_name"/>
                                <field name="supplier_id"/>
                                <field name="rank"/>
                                <field name="amount" widget="monetary"/>
                                <field name="currency_id" column_invisible="True"/>
                                <field name="is_selected"/>
                            </list>
                        </field>
                    </group>
                </page>
                <page string="Stakeholders &amp; Engagement" name="engagement" invisible="not is_tender">
                    <group string="Stakeholder Map">
                        <field name="stakeholder_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="partner_id"/>
                                <field name="role"/>
                                <field name="title_position"/>
                                <field name="relationship_strength" widget="badge"/>
                                <field name="last_contact_date"/>
                            </list>
                        </field>
                    </group>
                    <group string="Pre-Bid Meetings">
                        <field name="prebid_meeting_ids" nolabel="1">
                            <list>
                                <field name="name"/>
                                <field name="meeting_type"/>
                                <field name="meeting_date"/>
                                <field name="location"/>
                                <field name="state" widget="badge"/>
                            </list>
                        </field>
                    </group>
                    <group string="Clarifications">
                        <field name="clarification_ids" nolabel="1">
                            <list>
                                <field name="direction"/>
                                <field name="question"/>
                                <field name="asked_date"/>
                                <field name="response_deadline"/>
                                <field name="state" widget="badge"/>
                            </list>
                        </field>
                    </group>
                </page>
                <page string="Competitors" name="competitors" invisible="not is_tender">
                    <field name="competitor_link_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="competitor_id"/>
                            <field name="estimated_pwin"/>
                            <field name="threat_level" widget="badge"/>
                            <field name="is_incumbent"/>
                        </list>
                    </field>
                </page>
                <page string="Kickoff &amp; Reviews" name="kickoff" invisible="not is_tender">
                    <group>
                        <field name="tier3_progress" widget="progressbar"/>
                    </group>
                    <field name="kickoff_gate_ids" nolabel="1">
                        <list>
                            <field name="name"/>
                            <field name="gate_type"/>
                            <field name="gate_date"/>
                            <field name="chairperson_id"/>
                            <field name="decision" widget="badge"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </page>
                <page string="Lead Source" name="lead_source" invisible="not is_tender">
                    <group>
                        <field name="alert_subscription_id"/>
                    </group>
                </page>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="is_tender"/>
            </xpath>

        </field>
    </record>

    <record id="view_tender_opportunity_search" model="ir.ui.view">
        <field name="name">crm.lead.tender.search</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_opportunities_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter string="Tenders" name="is_tender" domain="[('is_tender', '=', True)]"/>
                <filter string="Tier 1 Complete" name="tier1_done" domain="[('tier1_complete', '=', True)]"/>
                <filter string="Wired" name="wired" domain="[('is_wired_tender', '=', True)]"/>
                <filter string="Deadline Next 7 Days" name="deadline_7" domain="[('submission_deadline', '&lt;=', (context_today() + relativedelta(days=7)).strftime('%Y-%m-%d 23:59:59')), ('submission_deadline', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter string="Tender State" name="group_tender_state" context="{'group_by': 'tender_state'}"/>
                    <filter string="Funding Source" name="group_funding" context="{'group_by': 'funding_source'}"/>
                    <filter string="Issuing Entity" name="group_client" context="{'group_by': 'client_id'}"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="action_tender_opportunity" model="ir.actions.act_window">
        <field name="name">Tenders</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form,calendar,pivot,graph</field>
        <field name="domain">[('is_tender', '=', True), ('type', '=', 'opportunity')]</field>
        <field name="context">{'default_is_tender': True, 'default_type': 'opportunity', 'search_default_is_tender': 1}</field>
    </record>

</odoo>
