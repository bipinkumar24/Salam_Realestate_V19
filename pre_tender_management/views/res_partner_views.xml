<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_tender" model="ir.ui.view">
        <field name="name">res.partner.form.tender</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='internal_notes']" position="before">
                <page string="Tender Profile" name="tender_profile">
                    <group>
                        <group>
                            <field name="is_tender_client"/>
                            <field name="is_competitor"/>
                            <field name="is_subcontractor"/>
                        </group>
                        <group>
                            <field name="bid_partner_rating"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
