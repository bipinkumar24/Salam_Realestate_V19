<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="seq_cash_payment_plan" model="ir.sequence">
        <field name="name">Cash Payment Plan</field>
        <field name="code">cash.payment.plan</field>
        <field name="prefix">CPP/%(year)s/%(month)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- ═══ BRE APPLICATION FORM inherit — all conditions use financing_type ═══ -->
    <record id="view_bre_application_cash_purchase" model="ir.ui.view">
        <field name="name">bre.application.form.cash</field>
        <field name="model">bre.customer.application</field>
        <field name="inherit_id" ref="bank_realestate_collab.view_customer_application_form"/>
        <field name="arch" type="xml">

            <!-- Cash purchase banner before the main groups -->
            <xpath expr="//sheet//group[1]" position="before">
                <div class="alert alert-warning mb-3" role="alert"
                     invisible="financing_type != 'cash'">
                    <strong>💵 Cash Purchase</strong> —
                    Financing fields are hidden. Five Cs appraisal is not required.
                    Generate a payment plan using the button above.
                    <span class="ml-3" invisible="cash_plan_state not in  ['confirmed','in_progress','completed']">
                        | Plan Status:
                        <field name="cash_plan_state" readonly="1" widget="badge"
                               decoration-success="cash_plan_state in ('confirmed','in_progress','completed')"
                               decoration-warning="cash_plan_state == 'draft'"/>
                    </span>
                </div>
            </xpath>

            <!-- Action buttons in header -->
            <xpath expr="//header/button[last()]" position="after">
                <button name="action_create_cash_plan"
                        string="💵 Create Payment Plan"
                        type="object"
                        class="btn-primary" invisible="financing_type != 'cash'"
                        confirm="Generate a cash payment plan for this application?"/>
                <button name="action_view_cash_plans"
                        string="📋 View Payment Plans"
                        type="object"
                        class="btn-secondary"
                        invisible ="(financing_type != 'cash') or (cash_plan_count == 0)"/>
            </xpath>

            <!-- Hide Five Cs appraisal button for cash -->
           <xpath expr="//page[@name='financing']" position="attributes">
                <attribute name="invisible">financing_type == 'cash'</attribute>
            </xpath>

            <!-- Invisible helper fields -->
            <xpath expr="//group[1]/field[1]" position="before">
                <field name="skip_appraisal" invisible="1"/>
                <field name="cash_plan_count" invisible="1"/>
                <field name="cash_plan_state" invisible="1"/>
            </xpath>

            <!-- Cash plan type selector in Application Info group -->
            <xpath expr="//group[1]" position="inside">
                <field name="cash_plan_type" invisible="financing_type !=  'cash'" required="financing_type == 'cash'"/>
            </xpath>

            <!-- Hide financing tab for cash purchases -->
            <xpath expr="//page[@name='financing']" position="attributes">
                <attribute name="invisible">financing_type == 'cash'</attribute>
            </xpath>

            <!-- Cash payment plan tab -->
            <xpath expr="//notebook" position="inside">
                <page string="💵 Payment Plan" name="cash_payment_tab"
                      invisible="financing_type !=  'cash'">
                    <div class="alert alert-info mb-3" role="alert"
                       invisible = "cash_plan_count !=  0">
                        <b>Before clicking Create Payment Plan:</b><br/>
                        1. Select the <b>Cash Plan Type</b> below.<br/>
                        2. Make sure the property has a <b>listed price</b>.<br/>
                        3. Click <b>💵 Create Payment Plan</b> at the top.
                    </div>
                    <group string="Cash Purchase Details">
                        <field name="cash_plan_type" required="financing_type == 'cash'"/>
                        <field name="cash_payment_plan_id" readonly="1"/>
                        <field name="cash_plan_state" readonly="1" widget="badge"
                               decoration-success="cash_plan_state in ('confirmed','in_progress','completed')"
                               decoration-warning="cash_plan_state == 'draft'"
                               decoration-muted="not cash_plan_state"/>
                        <field name="skip_appraisal" readonly="1"/>
                    </group>
                    <div class="mt-3" invisible ="cash_plan_count == 0">
                        <button name="action_view_cash_plans"
                                string="Open Full Payment Schedule →"
                                type="object" class="btn-primary"/>
                    </div>
                    <div class="text-muted mt-3"
                         invisible ="cash_plan_count != 0">
                        <i>No payment plan created yet. Click "💵 Create Payment Plan" above.</i>
                    </div>
                </page>
            </xpath>

        </field>
    </record>


    <!-- ═══ CASH PAYMENT PLAN — Form View ═══ -->
    <record id="view_cash_payment_plan_form" model="ir.ui.view">
        <field name="name">cash.payment.plan.form</field>
        <field name="model">cash.payment.plan</field>
        <field name="arch" type="xml">
            <form string="Cash Payment Plan">
                <header>
                    <button name="action_generate_schedule"
                            string="⚙ Regenerate Schedule"
                            type="object" class="btn-secondary"
                            invisible="state != 'draft'"
                            confirm="This will delete existing lines and regenerate. Continue?"/>
                    <button name="action_confirm" string="✅ Confirm Plan"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            class="btn-secondary"
                            invisible="state in ['cancelled','completed']"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <div class="row mb-3">
                        <div class="col-3">
                            <div class="bg-light rounded p-3 text-center">
                                <div class="text-muted small">Total Price</div>
                                <div class="h5 mb-0"><field name="total_amount" readonly="1"/></div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="bg-light rounded p-3 text-center">
                                <div class="text-muted small">Total Paid</div>
                                <div class="h5 mb-0 text-success"><field name="total_paid" readonly="1"/></div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="bg-light rounded p-3 text-center">
                                <div class="text-muted small">Outstanding</div>
                                <div class="h5 mb-0 text-danger"><field name="total_outstanding" readonly="1"/></div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="bg-light rounded p-3 text-center">
                                <div class="text-muted small">Completion</div>
                                <div class="h5 mb-0"><field name="completion_pct" readonly="1" widget="percentage"/></div>
                            </div>
                        </div>
                    </div>
                    <group>
                        <group string="Plan Details">
                            <field name="application_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="property_id" readonly="1"/>
                            <field name="plan_type"/>
                            <field name="template_id"
                                   domain="[('plan_type', '=', plan_type)]"
                                   options="{'no_create': True}"/>
                        </group>
                        <group string="Financials">
                            <field name="currency_id" readonly="1"/>
                            <field name="total_amount"/>
                            <field name="booking_date"/>
                            <field name="next_due_date" readonly="1"/>
                            <field name="next_due_amount" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payment Schedule" name="schedule_tab">
                            <field name="line_ids" widget="one2many">
                                <list editable="bottom"
                                      decoration-success="status == 'paid'"
                                      decoration-danger="status == 'overdue'"
                                      decoration-warning="status == 'due'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="milestone" optional="show"/>
                                    <field name="percentage"/>
                                    <field name="amount"/>
                                    <field name="due_date"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'paid'"
                                           decoration-danger="status == 'overdue'"
                                           decoration-warning="status == 'due'"
                                           decoration-muted="status == 'pending'"/>
                                    <field name="paid"/>
                                    <field name="paid_date" optional="show"/>
                                    <field name="paid_amount" optional="show"/>
                                    <field name="receipt_ref" optional="show"/>
                                    <button name="action_mark_paid" string="Mark Paid"
                                            type="object" icon="fa-check-circle"
                                            invisible="paid"
                                            class="btn-sm btn-success"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Special conditions, client instructions..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Payment Plan List View -->
    <record id="view_cash_payment_plan_tree" model="ir.ui.view">
        <field name="name">cash.payment.plan.tree</field>
        <field name="model">cash.payment.plan</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'completed'"
                  decoration-warning="state == 'draft'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="property_id"/>
                <field name="plan_type"/>
                <field name="total_amount"/>
                <field name="total_paid"/>
                <field name="total_outstanding"/>
                <field name="completion_pct" widget="progressbar"/>
                <field name="next_due_date"/>
                <field name="next_due_amount"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('confirmed','in_progress','completed')"
                       decoration-warning="state == 'draft'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Template Views -->
    <record id="view_cash_plan_template_form" model="ir.ui.view">
        <field name="name">cash.payment.plan.template.form</field>
        <field name="model">cash.payment.plan.template</field>
        <field name="arch" type="xml">
            <form string="Payment Plan Template">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="plan_type"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="total_percentage" widget="percentage" readonly="1"/>
                            <field name="description"/>
                        </group>
                    </group>
                    <field name="instalment_ids" widget="one2many">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="percentage"/>
                            <field name="trigger_type"/>
                            <field name="offset_value"
                                  invisible="trigger_type in ['on_booking','on_handover','custom_date']"/>
                            <field name="milestone_description" invisible="trigger_type != 'milestone'"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cash_plan_template_tree" model="ir.ui.view">
        <field name="name">cash.payment.plan.template.tree</field>
        <field name="model">cash.payment.plan.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="plan_type"/>
                <field name="total_percentage"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_cash_payment_plans" model="ir.actions.act_window">
        <field name="name">Cash Payment Plans</field>
        <field name="res_model">cash.payment.plan</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_cash_plan_templates" model="ir.actions.act_window">
        <field name="name">Payment Plan Templates</field>
        <field name="res_model">cash.payment.plan.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_cash_payment_plans"
              name="Cash Payment Plans"
              parent="bank_realestate_collab.menu_bre_bank"
              action="action_cash_payment_plans"
              sequence="25"/>
    <menuitem id="menu_cash_plan_templates"
              name="Payment Plan Templates"
              parent="bank_realestate_collab.menu_bre_config"
              action="action_cash_plan_templates"
              sequence="30"/>

</odoo>
