<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rinv_list" model="ir.ui.view">
        <field name="name">buruuj.rental.invoice.list</field>
        <field name="model">buruuj.rental.invoice</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'paid'"
                  decoration-warning="state == 'under_review'"
                  decoration-danger="state == 'disputed'"
                  decoration-info="state == 'approved'">
                <field name="name"/>
                <field name="contract_id"/>
                <field name="vendor_id"/>
                <field name="invoice_date"/>
                <field name="period_from"/>
                <field name="period_to"/>
                <field name="amount" sum="Invoiced"/>
                <field name="expected_amount" sum="Expected"/>
                <field name="variance" sum="Variance"
                       decoration-danger="variance > 0"
                       decoration-success="variance &lt;= 0"/>
                <field name="variance_percent" widget="percentage"/>
                <field name="state" widget="badge"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_rinv_form" model="ir.ui.view">
        <field name="name">buruuj.rental.invoice.form</field>
        <field name="model">buruuj.rental.invoice</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_review" string="Start Review"
                            type="object" class="oe_highlight"
                            invisible="state != 'received'"/>
                    <button name="action_approve" string="Approve for Payment"
                            type="object" class="oe_highlight"
                            invisible="state != 'under_review'"/>
                    <button name="action_dispute" string="Mark Disputed"
                            type="object"
                            invisible="state in ('paid','rejected')"/>
                    <button name="action_mark_paid" string="Mark Paid"
                            type="object" class="oe_highlight"
                            invisible="state != 'approved'"/>
                    <button name="action_reject" string="Reject" type="object"
                            invisible="state in ('paid','rejected')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Vendor invoice number..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="contract_id"/>
                            <field name="vendor_id"/>
                            <field name="invoice_date"/>
                        </group>
                        <group>
                            <field name="period_from"/>
                            <field name="period_to"/>
                        </group>
                    </group>
                    <group string="Reconciliation">
                        <group>
                            <field name="amount"/>
                            <field name="expected_amount" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="variance" readonly="1"/>
                            <field name="variance_percent" widget="percentage"
                                   readonly="1"/>
                        </group>
                    </group>
                    <group string="Dispute" invisible="state != 'disputed' and not disputed_amount">
                        <field name="disputed_amount"/>
                        <field name="dispute_reason"/>
                    </group>
                    <field name="invoice_attachment" filename="invoice_filename"/>
                    <field name="invoice_filename" invisible="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_rinv" model="ir.actions.act_window">
        <field name="name">Vendor Invoices</field>
        <field name="res_model">buruuj.rental.invoice</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_rinv_disputed" model="ir.actions.act_window">
        <field name="name">Disputed Invoices</field>
        <field name="res_model">buruuj.rental.invoice</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','disputed')]</field>
    </record>
</odoo>
