<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Portal home tiles ───────────────────────────────────────────── -->
    <template id="portal_my_home_bre" name="BRE Portal Home Entry"
              inherit_id="portal.portal_my_home" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">My Applications</t>
                <t t-set="text"> Follow, view or your Application</t>
                <t t-set="url" t-value="'/my/applications'"/>
                <t t-set="config_card" t-value="True"/>
                <t t-set="placeholder_count" t-value="'bre_application_count'"/>
            </t>
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Available Properties</t>
                <t t-set="text"> Follow, view or your Available Properties</t>
                <t t-set="url" t-value="'/properties'"/>
                <t t-set="placeholder_count" t-value="'bre_property_count'"/>
            </t>
        </xpath>
    </template>

    <!-- ── Applications list ───────────────────────────────────────────── -->
    <template id="portal_applications_list" name="My Applications">
        <t t-call="portal.portal_layout">
            <div style="display:flex;justify-content:flex-end;margin-bottom:12px">
                <a href="/my/applications/new"
                   style="display:inline-flex;align-items:center;gap:6px;padding:10px 20px;background:#0d2b45;color:#fff;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none">
                    + New Application
                </a>
            </div>
            <div id="bre-list-root" t-att-data-records="records_json"/>
            <t t-if="pager" t-call="portal.pager"/>
        </t>
    </template>

    <!-- ── Application detail ──────────────────────────────────────────── -->
    <template id="portal_application_detail" name="Application Detail">
        <t t-call="portal.portal_layout">
            <div id="bre-detail-root" t-att-data-app="app_json"/>
        </t>
    </template>

    <!-- ── Available properties list ───────────────────────────────────── -->
    <template id="portal_properties_list" name="Available Properties">
        <t t-call="portal.portal_layout">

            <!-- Page header -->
            <div class="bre-page-header" style="margin-bottom:20px">
                <div>
                    <h2 class="bre-page-title" style="font-size:22px;font-weight:600;color:#0d2b45;margin:0">
                        Available Properties
                    </h2>
                    <p style="font-size:13px;color:#5d6d7e;margin:4px 0 0">
                        Browse and select a property — you need a Prioritization Number to apply.
                    </p>
                </div>
                <a href="/my/applications" class="bre-btn-outline"
                   style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;border:1px solid #dce3ec;font-size:13px;font-weight:500;color:#0d2b45;text-decoration:none">
                    My Applications
                </a>
            </div>

            <!-- Prio banner -->
            <t t-if="request.env.user.id != request.env.ref('base.public_user').id">
                <t t-if="has_prio">
                    <div style="background:#d4edda;border-left:4px solid #1e8449;border-radius:0 8px 8px 0;padding:12px 16px;margin-bottom:20px;font-size:13px;color:#155724">
                        ✓ You have Prioritization # <strong t-esc="prio_number"/> — you can select a property below.
                    </div>
                </t>
                <t t-else="">
                    <div style="background:#fff3cd;border-left:4px solid #d68910;border-radius:0 8px 8px 0;padding:12px 16px;margin-bottom:20px;font-size:13px;color:#856404">
                        ⚠ You do not have a Prioritization Number yet. Contact your agent to obtain one before selecting a property.
                    </div>
                </t>
            </t>
            <t t-else="">
                <div style="background:#cce5ff;border-left:4px solid #2471a3;border-radius:0 8px 8px 0;padding:12px 16px;margin-bottom:20px;font-size:13px;color:#004085">
                    Please <a href="/web/login">log in</a> to select a property.
                </div>
            </t>

            <!-- No properties -->
            <t t-if="not properties">
                <div style="text-align:center;padding:60px 24px;color:#5d6d7e">
                    <div style="font-size:48px;margin-bottom:16px">🏠</div>
                    <h4 style="margin-bottom:8px">No available properties at the moment</h4>
                    <p>Please check back later.</p>
                </div>
            </t>

            <!-- Property cards -->
            <t t-if="properties">
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px;margin-bottom:24px">
                    <t t-foreach="properties" t-as="p">
                        <a t-attf-href="/properties/#{p.id}"
                           style="background:#fff;border-radius:12px;border:1.5px solid #dce3ec;overflow:hidden;text-decoration:none;color:inherit;display:flex;flex-direction:column;transition:all .2s">
                            <!-- Image -->
                            <div style="height:160px;background:#f0f4f8;overflow:hidden;position:relative">
                                <t t-if="p.image">
                                    <img t-att-src="'/web/image/property.details/' + str(p.id) + '/image/400x200'"
                                         style="width:100%;height:100%;object-fit:cover" alt=""/>
                                </t>
                                <t t-else="">
                                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:40px">🏠</div>
                                </t>
                                <!-- Type badge -->
                                <span t-esc="p.type"
                                      style="position:absolute;top:10px;left:10px;background:rgba(13,43,69,.8);color:#fff;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;padding:3px 10px;border-radius:12px"/>
                            </div>
                            <!-- Body -->
                            <div style="padding:14px 16px;flex:1">
                                <div style="font-size:15px;font-weight:700;color:#0d2b45;margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"
                                     t-esc="p.name"/>
                                <div style="font-size:12px;color:#5d6d7e;margin-bottom:12px">
                                    <t t-if="p.property_project_id">
                                        <span t-esc="p.property_project_id.name"/> ·
                                    </t>
                                    <span t-esc="p.city"/>
                                </div>
                                <!-- Specs row -->
                                <div style="display:flex;gap:12px;font-size:11px;color:#5d6d7e;margin-bottom:12px;flex-wrap:wrap">
                                    <t t-if="p.total_area">
                                        <span>📐 <t t-esc="int(p.total_area)"/> m²</span>
                                    </t>
                                    <t t-if="p.bed">
                                        <span>🛏 <t t-esc="p.bed"/> rooms</span>
                                    </t>
                                    <t t-if="p.bathroom">
                                        <span>🚿 <t t-esc="p.bathroom"/> bath</span>
                                    </t>
                                </div>
                                <!-- Price -->
                                <div style="font-size:16px;font-weight:700;color:#2471a3">
                                    <span t-field="p.price" t-options='{"widget":"monetary","display_currency":p.currency_id}'/>
                                </div>
                            </div>
                            <!-- Footer -->
                            <div style="padding:10px 16px;background:#f0f4f8;border-top:1px solid #dce3ec;display:flex;justify-content:space-between;align-items:center;font-size:12px;font-weight:600;color:#2471a3">
                                <span>View Details</span>
                                <span>→</span>
                            </div>
                        </a>
                    </t>
                </div>
                <t t-if="pager" t-call="portal.pager"/>
            </t>

        </t>
    </template>

    <!-- ── Property detail ──────────────────────────────────────────────── -->
    <template id="portal_property_detail" name="Property Detail">
        <t t-call="portal.portal_layout">

            <!-- Breadcrumb -->
            <div style="display:flex;align-items:center;gap:8px;font-size:13px;color:#5d6d7e;margin-bottom:20px;flex-wrap:wrap">
                <a href="/properties" style="color:#2471a3;text-decoration:none">Available Properties</a>
                <span style="color:#dce3ec">/</span>
                <span style="color:#0d2b45;font-weight:600" t-esc="prop.name"/>
            </div>

            <div style="display:grid;grid-template-columns:1fr 340px;gap:24px;align-items:start">

                <!-- Left: property info -->
                <div>
                    <!-- Image -->
                    <div style="border-radius:12px;overflow:hidden;margin-bottom:20px;height:280px;background:#f0f4f8">
                        <t t-if="prop.image">
                            <img t-att-src="'/web/image/property.details/' + str(prop.id) + '/image/800x400'"
                                 style="width:100%;height:100%;object-fit:cover" alt=""/>
                        </t>
                        <t t-else="">
                            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:64px">🏠</div>
                        </t>
                    </div>

                    <!-- Details card -->
                    <div style="background:#fff;border-radius:12px;border:1px solid #dce3ec;padding:20px;margin-bottom:16px">
                        <h3 style="font-size:20px;font-weight:700;color:#0d2b45;margin:0 0 4px">
                            <span t-esc="prop.name"/>
                        </h3>
                        <p style="font-size:13px;color:#5d6d7e;margin:0 0 16px">
                            <t t-if="prop.property_project_id">
                                <span t-esc="prop.property_project_id.name"/> ·
                            </t>
                            <t t-if="prop.subproject_id">
                                <span t-esc="prop.subproject_id.name"/> ·
                            </t>
                            <span t-esc="prop.city"/>
                        </p>

                        <!-- Specs grid -->
                        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px 20px;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid #dce3ec">
                            <t t-if="prop.type">
                                <div><div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e">Type</div>
                                <div style="font-size:14px;font-weight:500;color:#0d2b45"><span t-esc="prop.type"/></div></div>
                            </t>
                            <t t-if="prop.property_subtype_id">
                                <div><div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e">Subtype</div>
                                <div style="font-size:14px;font-weight:500;color:#0d2b45"><span t-esc="prop.property_subtype_id.name"/></div></div>
                            </t>
                            <t t-if="prop.total_area">
                                <div><div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e">Total Area</div>
                                <div style="font-size:14px;font-weight:500;color:#0d2b45"><t t-esc="int(prop.total_area)"/> m²</div></div>
                            </t>
                            <t t-if="prop.bed">
                                <div><div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e">Rooms</div>
                                <div style="font-size:14px;font-weight:500;color:#0d2b45"><t t-esc="prop.bed"/></div></div>
                            </t>
                            <t t-if="prop.bathroom">
                                <div><div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e">Bathrooms</div>
                                <div style="font-size:14px;font-weight:500;color:#0d2b45"><t t-esc="prop.bathroom"/></div></div>
                            </t>
                            <t t-if="prop.parking">
                                <div><div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e">Parking</div>
                                <div style="font-size:14px;font-weight:500;color:#0d2b45"><t t-esc="prop.parking"/></div></div>
                            </t>
                            <t t-if="prop.floor">
                                <div><div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e">Floor</div>
                                <div style="font-size:14px;font-weight:500;color:#0d2b45"><t t-esc="prop.floor"/></div></div>
                            </t>
                            <t t-if="prop.zone">
                                <div><div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e">Zone</div>
                                <div style="font-size:14px;font-weight:500;color:#0d2b45"><span t-esc="prop.zone.name"/></div></div>
                            </t>
                            <t t-if="prop.lot">
                                <div><div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e">Lot</div>
                                <div style="font-size:14px;font-weight:500;color:#0d2b45"><span t-esc="prop.lot.name"/></div></div>
                            </t>
                            <t t-if="prop.block">
                                <div><div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e">Block</div>
                                <div style="font-size:14px;font-weight:500;color:#0d2b45"><span t-esc="prop.block.name"/></div></div>
                            </t>
                            <t t-if="prop.tf_no">
                                <div><div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e">TF N#</div>
                                <div style="font-size:14px;font-weight:500;color:#0d2b45"><t t-esc="prop.tf_no"/></div></div>
                            </t>
                            <t t-if="prop.property_sequence_no">
                                <div><div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e">Property ID</div>
                                <div style="font-size:14px;font-weight:500;color:#0d2b45"><t t-esc="prop.property_sequence_no"/></div></div>
                            </t>
                        </div>

                        <!-- Landlord -->
                        <t t-if="prop.landlord_id">
                            <div style="font-size:12px;color:#5d6d7e">
                                Owner: <strong style="color:#0d2b45" t-esc="prop.landlord_id.name"/>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- Right: action card -->
                <div style="position:sticky;top:80px">
                    <div style="background:#fff;border-radius:12px;border:1px solid #dce3ec;padding:24px">

                        <!-- Price -->
                        <div style="font-size:26px;font-weight:700;color:#2471a3;margin-bottom:4px">
                            <span t-field="prop.price" t-options='{"widget":"monetary","display_currency":prop.currency_id}'/>
                        </div>
                        <div style="font-size:12px;color:#5d6d7e;margin-bottom:20px">
                            <span t-esc="prop.sale_lease"/>
                        </div>

                        <div style="border-top:1px solid #dce3ec;padding-top:16px;margin-bottom:20px">
                            <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:8px">Property Code</div>
                            <div style="font-size:14px;font-weight:600;color:#0d2b45" t-esc="prop.property_seq"/>
                        </div>

                        <!-- Already applied -->
                        <t t-if="existing_app">
                            <div style="background:#d4edda;border-radius:8px;padding:12px;font-size:13px;color:#155724;margin-bottom:16px">
                                ✓ You have already applied for this property.
                            </div>
                            <a t-attf-href="/my/applications/#{existing_app.id}"
                               style="display:block;text-align:center;padding:12px;background:#1a5276;color:#fff;border-radius:8px;font-weight:600;font-size:14px;text-decoration:none">
                                View My Application
                            </a>
                        </t>

                        <!-- Has prio — can apply -->
                        <t t-elif="has_prio">
                            <div style="background:#d4edda;border-radius:8px;padding:12px;font-size:13px;color:#155724;margin-bottom:16px">
                                ✓ Your Prio # <strong t-esc="prio_number"/> is active.
                            </div>
                            <form t-attf-action="/properties/#{prop.id}/select" method="POST">
                                <input type="hidden" name="csrf_token"
                                       t-att-value="request.csrf_token()"/>
                                <button type="submit"
                                        style="width:100%;padding:14px;background:linear-gradient(135deg,#0d2b45,#1a5276);color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:700;cursor:pointer">
                                    Select This Property
                                </button>
                            </form>
                            <p style="font-size:11px;color:#5d6d7e;text-align:center;margin-top:10px">
                                This will create a financing application pre-filled with this property.
                            </p>
                        </t>

                        <!-- No prio — disabled -->
                        <t t-elif="request.env.user.id != request.env.ref('base.public_user').id">
                            <div style="background:#fff3cd;border-radius:8px;padding:12px;font-size:13px;color:#856404;margin-bottom:16px">
                                ⚠ You need a Prioritization Number to select this property.
                            </div>
                            <button disabled="1"
                                    style="width:100%;padding:14px;background:#b0bec5;color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:700;cursor:not-allowed">
                                Select This Property
                            </button>
                            <p style="font-size:11px;color:#5d6d7e;text-align:center;margin-top:10px">
                                Contact your agent to get a Prioritization Number.
                            </p>
                        </t>

                        <!-- Not logged in -->
                        <t t-else="">
                            <a href="/web/login"
                               style="display:block;text-align:center;padding:14px;background:#1a5276;color:#fff;border-radius:8px;font-size:15px;font-weight:700;text-decoration:none">
                                Log In to Apply
                            </a>
                        </t>

                        <a href="/properties"
                           style="display:block;text-align:center;margin-top:12px;font-size:13px;color:#5d6d7e;text-decoration:none">
                            ← Back to Properties
                        </a>
                    </div>
                </div>

            </div>
        </t>
    </template>


    <!-- ── No prioritization page ──────────────────────────────────────── -->
    <template id="portal_application_no_prio" name="No Prioritization">
        <t t-call="portal.portal_layout">
            <div style="max-width:560px;margin:40px auto;text-align:center;padding:40px 24px;background:#fff;border-radius:14px;border:1px solid #dce3ec">
                <div style="font-size:52px;margin-bottom:16px">⚠</div>
                <h3 style="font-size:20px;font-weight:600;color:#0d2b45;margin-bottom:12px">No Prioritization Number Found</h3>
                <p style="font-size:14px;color:#5d6d7e;margin-bottom:24px">
                    You need a Prioritization Number linked to your CRM opportunity before you can create a financing application. Please contact your real estate agent.
                </p>
                <a href="/my/applications" style="display:inline-block;padding:10px 24px;background:#1a5276;color:#fff;border-radius:8px;font-weight:600;text-decoration:none">
                    Back to My Applications
                </a>
            </div>
        </t>
    </template>

    <!-- ── New application form ─────────────────────────────────────────── -->
    <template id="portal_application_new" name="New Application">
        <t t-call="portal.portal_layout">
            <div style="max-width:760px;margin:0 auto;padding:24px 0 48px">

                <!-- Header -->
                <div style="margin-bottom:24px">
                    <a href="/my/applications" style="font-size:13px;color:#2471a3;text-decoration:none">← My Applications</a>
                    <h2 style="font-size:22px;font-weight:700;color:#0d2b45;margin:8px 0 4px">New Financing Application</h2>
                    <div style="font-size:13px;color:#5d6d7e">
                        Prioritization # <strong t-esc="prio.prioritization_number"/> ·
                        File # <strong t-esc="prio.file_number or '—'"/>
                    </div>
                </div>

                <!-- Errors -->
                <t t-if="errors">
                    <div style="background:#f8d7da;border-left:4px solid #c0392b;border-radius:0 8px 8px 0;padding:12px 16px;margin-bottom:20px">
                        <strong style="color:#721c24">Please fix the following:</strong>
                        <ul style="margin:6px 0 0 16px;color:#721c24;font-size:13px">
                            <t t-foreach="errors" t-as="err">
                                <li t-esc="err"/>
                            </t>
                        </ul>
                    </div>
                </t>

                <form action="/my/applications/new/submit" method="POST">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <!-- Personal Information -->
                    <div style="background:#fff;border-radius:12px;border:1px solid #dce3ec;margin-bottom:16px;overflow:hidden">
                        <div style="padding:14px 20px;background:#f7fafd;border-bottom:1px solid #dce3ec;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:#1a5276">
                            Personal Information
                        </div>
                        <div style="padding:20px;display:grid;grid-template-columns:1fr 1fr;gap:16px">

                            <div>
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Full Name</label>
                                <input type="text" style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px" readonly="1"
                                       t-att-value="partner.name"/>
                            </div>

                            <div>
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Date of Birth *</label>
                                <input type="date" name="date_of_birth" required="1"
                                       style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px"
                                       t-att-value="values.get('date_of_birth','')"/>
                            </div>

                            <div>
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Gender *</label>
                                <select name="gender" required="1" style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px">
                                    <option value="">Select…</option>
                                    <option value="male" t-att-selected="'selected' if values.get('gender')=='male' else None">Male</option>
                                    <option value="female" t-att-selected="'selected' if values.get('gender')=='female' else None">Female</option>
                                </select>
                            </div>

                            <div>
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Nationality *</label>
                                <select name="nationality_id" required="1" style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px">
                                    <option value="">Select…</option>
                                    <t t-foreach="countries" t-as="c">
                                        <option t-att-value="c.id" t-esc="c.name"
                                                t-att-selected="'selected' if str(c.id)==values.get('nationality_id','') else None"/>
                                    </t>
                                </select>
                            </div>

                            <div>
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Email *</label>
                                <input type="email" name="email" required="1"
                                       style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px"
                                       t-att-value="values.get('email') or partner.email or ''"/>
                            </div>

                            <div>
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Mobile *</label>
                                <input type="text" name="mobile" required="1"
                                       style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px"
                                        t-att-value="values.get('mobile', partner.phone if partner else '')"/>
                            </div>

                            <div>
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">ID Type *</label>
                                <select name="id_type" required="1" style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px">
                                    <option value="">Select…</option>
                                    <option value="national_id" t-att-selected="'selected' if values.get('id_type')=='national_id' else None">National ID</option>
                                    <option value="passport" t-att-selected="'selected' if values.get('id_type')=='passport' else None">Passport</option>
                                    <option value="residence_permit" t-att-selected="'selected' if values.get('id_type')=='residence_permit' else None">Residence Permit</option>
                                </select>
                            </div>

                            <div>
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">ID Number *</label>
                                <input type="text" name="id_number" required="1"
                                       style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px"
                                       t-att-value="values.get('id_number','')"/>
                            </div>

                        </div>
                    </div>

                    <!-- Employment -->
                    <div style="background:#fff;border-radius:12px;border:1px solid #dce3ec;margin-bottom:16px;overflow:hidden">
                        <div style="padding:14px 20px;background:#f7fafd;border-bottom:1px solid #dce3ec;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:#1a5276">
                            Employment Information
                        </div>
                        <div style="padding:20px;display:grid;grid-template-columns:1fr 1fr;gap:16px">

                            <div>
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Employment Status *</label>
                                <select name="employment_status" required="1" style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px">
                                    <option value="">Select…</option>
                                    <option value="employed" t-att-selected="'selected' if values.get('employment_status')=='employed' else None">Employed</option>
                                    <option value="self_employed" t-att-selected="'selected' if values.get('employment_status')=='self_employed' else None">Self Employed</option>
                                    <option value="retired" t-att-selected="'selected' if values.get('employment_status')=='retired' else None">Retired</option>
                                    <option value="unemployed" t-att-selected="'selected' if values.get('employment_status')=='unemployed' else None">Unemployed</option>
                                </select>
                            </div>

                            <div>
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Employer / Business *</label>
                                <input type="text" name="employer_name" required="1"
                                       style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px"
                                       t-att-value="values.get('employer_name','')"/>
                            </div>

                            <div>
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Monthly Income *</label>
                                <input type="number" name="monthly_income" required="1" min="0" step="any"
                                       style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px"
                                       t-att-value="values.get('monthly_income','')"/>
                            </div>

                            <div>
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Monthly Obligations</label>
                                <input type="number" name="monthly_obligations" min="0" step="any"
                                       style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px"
                                       t-att-value="values.get('monthly_obligations','0')"/>
                            </div>

                        </div>
                    </div>

                    <!-- Property & Financing -->
                    <div style="background:#fff;border-radius:12px;border:1px solid #dce3ec;margin-bottom:24px;overflow:hidden">
                        <div style="padding:14px 20px;background:#f7fafd;border-bottom:1px solid #dce3ec;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:#1a5276">
                            Property &amp; Financing
                        </div>
                        <div style="padding:20px;display:grid;grid-template-columns:1fr 1fr;gap:16px">

                            <div style="grid-column:1/-1">
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Select Property *</label>
                                <select name="property_id" required="1" style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px">
                                    <option value="">Choose an available property…</option>
                                    <t t-foreach="properties" t-as="prop">
                                        <option t-att-value="prop.id"
                                                t-att-selected="'selected' if str(prop.id)==values.get('property_id','') else None">
                                            <t t-esc="prop.name"/> — <t t-esc="prop.property_seq or ''"/>
                                            (<t t-esc="prop.type or ''"/>)
                                        </option>
                                    </t>
                                </select>
                            </div>

                            <!-- Payment / Financing Type — full width -->
                            <div style="grid-column:1/-1">
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Payment / Financing Type *</label>
                                <select name="financing_type" id="sre-fin-type" required="1"
                                        style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px"
                                        onchange="sreToggleCash(this.value)">
                                    <option value="">Select…</option>
                                    <option value="murabaha" t-att-selected="'selected' if values.get('financing_type')=='murabaha' else None">Murabaha (Islamic)</option>
                                    <option value="ijara" t-att-selected="'selected' if values.get('financing_type')=='ijara' else None">Ijara (Islamic Lease)</option>
                                    <option value="diminishing_musharaka" t-att-selected="'selected' if values.get('financing_type')=='diminishing_musharaka' else None">Diminishing Musharaka</option>
                                    <option value="conventional" t-att-selected="'selected' if values.get('financing_type')=='conventional' else None">Conventional Mortgage</option>
                                    <option value="cash" t-att-selected="'selected' if values.get('financing_type')=='cash' else None">&#x2713; Cash Purchase (No Bank Financing)</option>
                                </select>
                            </div>

                            <!-- Cash Purchase Banner -->
                            <div id="sre-cash-banner" style="grid-column:1/-1;display:none;background:#e8f8f5;border-left:4px solid #17a589;border-radius:0 8px 8px 0;padding:14px 16px">
                                <div style="font-size:14px;font-weight:700;color:#0d6b55;margin-bottom:4px">&#x2714; Cash Purchase — No Bank Financing Required</div>
                                <div style="font-size:13px;color:#0d6b55;line-height:1.6">
                                    Bank financing fields are hidden. Please enter the full purchase amount you will pay in cash in the <strong>Total Cash Amount</strong> field below.
                                </div>
                            </div>

                            <!-- Bank Financing Fields (hidden when cash) -->
                            <div id="sre-bank-fields" style="display:contents">
                                <div>
                                    <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Financing Amount Required *</label>
                                    <input type="number" name="financing_amount" id="sre-fin-amount" min="0"
                                           style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px"
                                           t-att-value="values.get('financing_amount','')"/>
                                </div>
                                <div>
                                    <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Down Payment</label>
                                    <input type="number" name="down_payment" id="sre-dp" min="0"
                                           style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px"
                                           t-att-value="values.get('down_payment','0')"/>
                                </div>
                                <div>
                                    <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Tenure (months)</label>
                                    <input type="number" name="tenure_months" min="12" max="360"
                                           style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px"
                                           t-att-value="values.get('tenure_months','240')"/>
                                </div>
                            </div>

                            <!-- Cash Total Amount (shown only when cash) -->
                            <div id="sre-cash-field" style="grid-column:1/-1;display:none">
                                <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#5d6d7e;margin-bottom:6px">Total Cash Amount *</label>
                                <input type="number" name="cash_amount_display" id="sre-cash-amount" min="0"
                                       style="width:100%;padding:9px 12px;border:1px solid #dce3ec;border-radius:8px;font-size:14px"
                                       t-att-value="values.get('cash_amount_display','')"/>
                                <div style="font-size:11px;color:#5d6d7e;margin-top:5px">Enter the full property purchase price you will pay in cash (DJF).</div>
                            </div>

                        </div>
                    </div>

                    <script>
                    function sreToggleCash(val) {
                        var isCash = (val === 'cash');
                        var banner   = document.getElementById('sre-cash-banner');
                        var bankFlds = document.getElementById('sre-bank-fields');
                        var cashFld  = document.getElementById('sre-cash-field');
                        var finAmt   = document.getElementById('sre-fin-amount');
                        var dp       = document.getElementById('sre-dp');

                        if (banner)   banner.style.display   = isCash ? '' : 'none';
                        if (cashFld)  cashFld.style.display   = isCash ? '' : 'none';

                        if (bankFlds) {
                            var kids = bankFlds.children;
                            for (var i = 0; i &lt; kids.length; i++) {
                                kids[i].style.display = isCash ? 'none' : '';
                            }
                        }
                        if (finAmt) {
                            finAmt.required = !isCash;
                            if (isCash) { finAmt.value = '0'; }
                        }
                        if (dp &amp;&amp; isCash) { dp.value = '0'; }
                    }
                    document.addEventListener('DOMContentLoaded', function() {
                        var sel = document.getElementById('sre-fin-type');
                        if (sel) sreToggleCash(sel.value);
                    });
                    </script>

                    <!-- Submit -->
                    <div style="display:flex;gap:12px;align-items:center">
                        <button type="submit"
                                style="padding:14px 32px;background:linear-gradient(135deg,#0d2b45,#1a5276);color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:700;cursor:pointer">
                            Submit Application
                        </button>
                        <a href="/my/applications"
                           style="padding:14px 20px;border:1px solid #dce3ec;border-radius:8px;font-size:14px;color:#5d6d7e;text-decoration:none">
                            Cancel
                        </a>
                    </div>

                </form>
            </div>
        </t>
    </template>

</odoo>
