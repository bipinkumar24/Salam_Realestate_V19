<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Document Attachment List -->
    <record id="view_document_attachment_list" model="ir.ui.view">
        <field name="name">bre.document.attachment.list</field>
        <field name="model">bre.document.attachment</field>
        <field name="arch" type="xml">
            <list string="Documents"
                  decoration-success="verification_status=='verified'"
                  decoration-danger="verification_status in ('rejected','expired')"
                  decoration-warning="verification_status=='pending'">
                <field name="application_id"/>
                <field name="document_type_id"/>
                <field name="document_category"/>
                <field name="name"/>
                <field name="submitted_by"/>
                <field name="submission_date"/>
                <field name="expiry_date"/>
                <field name="file_count"/>
                <field name="is_mandatory" widget="boolean"/>
                <field name="verification_status" widget="badge"
                       decoration-success="verification_status=='verified'"
                       decoration-danger="verification_status in ('rejected','expired')"
                       decoration-warning="verification_status=='pending'"/>
                <field name="verified_by"/>
                <button name="action_verify" string="Verify" type="object"
                        icon="fa-check-circle" class="btn-success btn-sm"
                    invisible="verification_status == 'verified'"
                        groups="bank_realestate_collab.group_bre_bank_officer"/>
                <button name="action_reject_doc" string="Reject" type="object"
                        icon="fa-times-circle" class="btn-danger btn-sm"
                    invisible="verification_status != 'pending'"
                        groups="bank_realestate_collab.group_bre_bank_officer"/>
            </list>
        </field>
    </record>

    <!-- Document Attachment Form -->
    <record id="view_document_attachment_form" model="ir.ui.view">
        <field name="name">bre.document.attachment.form</field>
        <field name="model">bre.document.attachment</field>
        <field name="arch" type="xml">
            <form string="Document">
                <header>
                    <button name="action_verify" string="Mark Verified" type="object"
                            class="btn-success"
                        invisible="verification_status == 'verified'"
                            groups="bank_realestate_collab.group_bre_bank_officer"/>
                    <button name="action_reject_doc" string="Mark Rejected" type="object"
                            class="btn-danger"
                        invisible="verification_status == 'rejected'"
                            groups="bank_realestate_collab.group_bre_bank_officer"/>
                    <button name="action_mark_expired" string="Mark Expired" type="object"
                        invisible="verification_status == 'expired'"
                            groups="bank_realestate_collab.group_bre_bank_officer"/>
                    <field name="verification_status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group string="Document Info">
                            <field name="application_id"/>
                            <field name="document_type_id"/>
                            <field name="document_category"/>
                            <field name="name"/>
                            <field name="is_mandatory" readonly="1"/>
                        </group>
                        <group string="Submission Details">
                            <field name="submitted_by"/>
                            <field name="submission_date"/>
                            <field name="expiry_date"/>
                        </group>
                    </group>
                    <group string="Uploaded Files">
                        <field name="attachment_ids" widget="many2many_binary" nolabel="1"/>
                    </group>
                    <group string="Verification" groups="bank_realestate_collab.group_bre_bank_officer">
                        <field name="verified_by" readonly="1"/>
                        <field name="verified_date" readonly="1"/>
                        <field name="rejection_reason"
                               invisible="verification_status != 'rejected'"/>
                        <field name="notes"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Document Action -->
    <record id="action_document_attachment" model="ir.actions.act_window">
        <field name="name">All Documents</field>
        <field name="res_model">bre.document.attachment</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
