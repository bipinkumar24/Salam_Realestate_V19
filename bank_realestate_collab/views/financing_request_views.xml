<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Financing Request List -->
    <record id="view_financing_request_list" model="ir.ui.view">
        <field name="name">bre.financing.request.list</field>
        <field name="model">bre.financing.request</field>
        <field name="arch" type="xml">
            <list string="Financing Requests"
                  decoration-success="status=='approved'"
                  decoration-danger="status=='rejected'"
                  decoration-info="status=='under_review'"
                  decoration-warning="status=='submitted'">
                <field name="name"/>
                <field name="customer_name" string="Customer"/>
                <field name="property_ref"/>
                <field name="financing_type"/>
                <field name="requested_amount" widget="monetary"/>
                <field name="currency_id" invisible="1"/>
                <field name="requested_tenure"/>
                <field name="monthly_income" widget="monetary"/>
                <field name="debt_burden_ratio" widget="percentage"/>
                <field name="bank_officer_id"/>
                <field name="submission_date"/>
                <field name="status" widget="badge"
                       decoration-success="status=='approved'"
                       decoration-danger="status=='rejected'"
                       decoration-info="status=='under_review'"
                       decoration-warning="status=='submitted'"/>
                <button name="action_start_review" string="Review" type="object" icon="fa-eye"
                    invisible="status != 'submitted'"
                        groups="bank_realestate_collab.group_bre_bank_officer"/>
                <button name="action_approve" string="Approve" type="object" icon="fa-check"
                    invisible="status != 'under_review'"
                        groups="bank_realestate_collab.group_bre_bank_officer"/>
                <button name="action_reject" string="Reject" type="object" icon="fa-times"
                    invisible="status not in ['submitted','under_review']"
                        groups="bank_realestate_collab.group_bre_bank_officer"/>
            </list>
        </field>
    </record>

    <!-- Financing Request Form -->
    <record id="view_financing_request_form" model="ir.ui.view">
        <field name="name">bre.financing.request.form</field>
        <field name="model">bre.financing.request</field>
        <field name="arch" type="xml">
            <form string="Financing Request">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary"
                        invisible="status != 'draft'"/>
                    <button name="action_start_review" string="Start Review" type="object" class="btn-primary"
                        invisible="status != 'submitted'"
                            groups="bank_realestate_collab.group_bre_bank_officer"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-success"
                        invisible="status != 'under_review'"
                            groups="bank_realestate_collab.group_bre_bank_officer"/>
                    <button name="action_conditional_approve" string="Conditional Approval"
                        type="object" invisible="status != 'under_review'"
                            groups="bank_realestate_collab.group_bre_bank_officer"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger"
                        invisible="status not in ['submitted','under_review']"
                            groups="bank_realestate_collab.group_bre_bank_officer"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,submitted,under_review,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Request Details">
                            <field name="application_id"/>
                            <field name="agent_id"/>
                            <field name="bank_officer_id"/>
                            <field name="financing_type"/>
                            <field name="is_sharia_compliant"/>
                        </group>
                        <group string="Amount &amp; Tenure">
                            <field name="currency_id"/>
                            <field name="requested_amount" widget="monetary"/>
                            <field name="requested_tenure"/>
                            <field name="processing_fee" widget="monetary"/>
                        </group>
                    </group>
                    <group string="Customer Financial Summary (Read-only)">
                        <group>
                            <field name="customer_name" readonly="1"/>
                            <field name="property_ref" readonly="1"/>
                        </group>
                        <group>
                            <field name="monthly_income" widget="monetary" readonly="1"/>
                            <field name="debt_burden_ratio" readonly="1" widget="percentage"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bank Decision" name="bank_decision" groups="bank_realestate_collab.group_bre_bank_officer">
                            <group>
                                <group string="Approved Terms">
                                    <field name="approved_amount" widget="monetary"/>
                                    <field name="approved_tenure"/>
                                    <field name="profit_rate"/>
                                    <field name="monthly_installment" readonly="1" widget="monetary"/>
                                    <field name="total_cost" readonly="1" widget="monetary"/>
                                    <field name="offer_expiry_date"/>
                                </group>
                                <group string="Sharia Approval">
                                    <field name="sharia_board_approval"/>
                                    <field name="sharia_approval_ref"/>
                                </group>
                            </group>
                            <group string="Conditions &amp; Remarks">
                                <field name="conditions" nolabel="1"/>
                                <field name="rejection_reason" nolabel="1"
                                       invisible="status != 'rejected'"/>
                                <field name="bank_remarks" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Timeline">
                            <group>
                                <field name="submission_date" readonly="1"/>
                                <field name="review_date" readonly="1"/>
                                <field name="decision_date" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Financing Request Search -->
    <record id="view_financing_request_search" model="ir.ui.view">
        <field name="name">bre.financing.request.search</field>
        <field name="model">bre.financing.request</field>
        <field name="arch" type="xml">
            <search string="Search Financing Requests">
                <field name="name"/>
                <field name="customer_name"/>
                <field name="bank_officer_id"/>
                <filter string="My Requests" name="my_requests" domain="[('bank_officer_id','=',uid)]"/>
                <separator/>
                <filter string="Submitted" name="submitted" domain="[('status','=','submitted')]"/>
                <filter string="Under Review" name="reviewing" domain="[('status','=','under_review')]"/>
                <filter string="Approved" name="approved" domain="[('status','=','approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('status','=','rejected')]"/>
                <filter string="Sharia Compliant" name="sharia" domain="[('is_sharia_compliant','=',True)]"/>
                <group>
                    <filter string="Status" name="grp_status" context="{'group_by': 'status'}"/>
                    <filter string="Financing Type" name="grp_type" context="{'group_by': 'financing_type'}"/>
                    <filter string="Bank Officer" name="grp_officer" context="{'group_by': 'bank_officer_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Document Type Views -->
    <record id="view_document_type_list" model="ir.ui.view">
        <field name="name">bre.document.type.list</field>
        <field name="model">bre.document.type</field>
        <field name="arch" type="xml">
            <list string="Document Types" editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="applicable_for"/>
                <field name="is_mandatory"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Financing Request Actions -->
    <record id="action_financing_request_bank" model="ir.actions.act_window">
        <field name="name">Financing Requests</field>
        <field name="res_model">bre.financing.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_financing_request_search"/>
        <field name="context">{'search_default_submitted': 1}</field>
    </record>

    <record id="action_document_types" model="ir.actions.act_window">
        <field name="name">Document Types</field>
        <field name="res_model">bre.document.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_application_stages" model="ir.actions.act_window">
        <field name="name">Application Stages</field>
        <field name="res_model">bre.application.stage</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
