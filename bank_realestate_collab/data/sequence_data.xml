<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_customer_application" model="ir.sequence">
            <field name="name">Customer Application Sequence</field>
            <field name="code">bre.customer.application</field>
            <field name="prefix">APP/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_financing_request" model="ir.sequence">
            <field name="name">Financing Request Sequence</field>
            <field name="code">bre.financing.request</field>
            <field name="prefix">FIN/%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

    </data>
</odoo>
