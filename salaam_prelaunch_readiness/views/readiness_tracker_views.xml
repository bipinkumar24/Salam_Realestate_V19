<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================== -->
    <!-- Readiness Tracker - List                                        -->
    <!-- ============================================================== -->
    <record id="view_readiness_tracker_list" model="ir.ui.view">
        <field name="name">salaam.readiness.tracker.list</field>
        <field name="model">salaam.readiness.tracker</field>
        <field name="arch" type="xml">
            <list string="Readiness Trackers"
                  decoration-success="readiness_status == 'ready'"
                  decoration-info="readiness_status == 'on_track'"
                  decoration-warning="readiness_status == 'at_risk'"
                  decoration-danger="readiness_status == 'blocked'">
                <field name="name"/>
                <field name="phase_label"/>
                <field name="lot_label"/>
                <field name="state"/>
                <field name="total_items"/>
                <field name="done_count"/>
                <field name="overall_pct" widget="progressbar"/>
                <field name="hard_gate_pct" widget="progressbar"/>
                <field name="parallel_pct" widget="progressbar"/>
                <field name="mob_pct" widget="progressbar"/>
                <field name="readiness_status" widget="badge"
                       decoration-success="readiness_status == 'ready'"
                       decoration-info="readiness_status == 'on_track'"
                       decoration-warning="readiness_status == 'at_risk'"
                       decoration-danger="readiness_status == 'blocked'"/>
                <field name="is_ready_to_mobilize" widget="boolean_toggle" readonly="1"/>
            </list>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Readiness Tracker - Form  (the IAFAO command screen)            -->
    <!-- ============================================================== -->
    <record id="view_readiness_tracker_form" model="ir.ui.view">
        <field name="name">salaam.readiness.tracker.form</field>
        <field name="model">salaam.readiness.tracker</field>
        <field name="arch" type="xml">
            <form string="Pre-Launch Readiness Tracker">
                <header>
                    <button name="action_activate" type="object"
                            string="Activate" class="oe_highlight"
                            invisible="state != 'draft'"
                            groups="salaam_prelaunch_readiness.group_readiness_manager"/>
                    <button name="action_lock_for_gate_review" type="object"
                            string="Lock for Gate Review" class="oe_highlight"
                            invisible="state != 'active'"
                            groups="salaam_prelaunch_readiness.group_readiness_manager"/>
                    <button name="action_close" type="object"
                            string="Close"
                            invisible="state == 'closed'"
                            groups="salaam_prelaunch_readiness.group_readiness_manager"/>
                    <button name="action_reset_to_draft" type="object"
                            string="Reset to Draft"
                            invisible="state in ('draft','closed')"
                            groups="salaam_prelaunch_readiness.group_readiness_manager"/>
                    <button name="action_open_excel_import" type="object"
                            string="Import from Excel"
                            invisible="state == 'closed'"
                            groups="salaam_prelaunch_readiness.group_readiness_officer"/>
                    <button name="action_open_clone_wizard" type="object"
                            string="Clone Tracker"
                            groups="salaam_prelaunch_readiness.group_readiness_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,locked,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_items" type="object"
                                class="oe_stat_button" icon="fa-list-ul">
                            <field name="total_items" widget="statinfo"
                                   string="Items"/>
                        </button>
                        <button name="action_open_items" type="object"
                                class="oe_stat_button" icon="fa-check"
                                context="{'search_default_filter_done': 1}">
                            <field name="done_count" widget="statinfo"
                                   string="Done"/>
                        </button>
                        <button name="action_open_items" type="object"
                                class="oe_stat_button" icon="fa-clock-o"
                                context="{'search_default_filter_in_progress': 1}">
                            <field name="in_progress_count" widget="statinfo"
                                   string="In Progress"/>
                        </button>
                        <button name="action_open_items" type="object"
                                class="oe_stat_button" icon="fa-ban"
                                context="{'search_default_filter_blocked': 1}">
                            <field name="blocked_count" widget="statinfo"
                                   string="Blocked"/>
                        </button>
                        <button name="action_open_items" type="object"
                                class="oe_stat_button" icon="fa-exclamation-triangle"
                                context="{'search_default_filter_overdue': 1}">
                            <field name="overdue_count" widget="statinfo"
                                   string="Overdue"/>
                        </button>
                        <button name="action_open_snapshots" type="object"
                                class="oe_stat_button" icon="fa-archive">
                            <field name="snapshot_count" widget="statinfo"
                                   string="Snapshots"/>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="READY TO MOBILIZE"
                            bg_color="bg-success"
                            invisible="not is_ready_to_mobilize"/>
                    <widget name="web_ribbon" title="BLOCKED"
                            bg_color="bg-danger"
                            invisible="readiness_status != 'blocked'"/>

                    <div class="oe_title">
                        <label for="name" string="Tracker"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Scope">
                            <field name="phase_label"/>
                            <field name="lot_label"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Decision Gate Link">
                            <field name="decision_gate_ref"/>
                            <field name="readiness_status" widget="badge"
                                   decoration-success="readiness_status == 'ready'"
                                   decoration-info="readiness_status == 'on_track'"
                                   decoration-warning="readiness_status == 'at_risk'"
                                   decoration-danger="readiness_status == 'blocked'"/>
                            <field name="is_ready_to_mobilize" readonly="1"/>
                        </group>
                    </group>

                    <separator string="Gate Readiness"/>
                    <group>
                        <group>
                            <label for="overall_pct" string="Overall Complete"/>
                            <div>
                                <field name="overall_pct" widget="progressbar" nolabel="1"/>
                            </div>
                            <label for="hard_gate_pct" string="Hard Gate (need 100%)"/>
                            <div>
                                <field name="hard_gate_pct" widget="progressbar" nolabel="1"/>
                            </div>
                        </group>
                        <group>
                            <label for="parallel_pct" string="Parallel (need 80%)"/>
                            <div>
                                <field name="parallel_pct" widget="progressbar" nolabel="1"/>
                            </div>
                            <label for="mob_pct" string="Mobilization (need 100%)"/>
                            <div>
                                <field name="mob_pct" widget="progressbar" nolabel="1"/>
                            </div>
                        </group>
                    </group>

                    <notebook>
                        <page string="Categories" name="categories">
                            <field name="category_ids" mode="kanban,list" readonly="1">
                                <kanban default_order="sequence,code"
                                        class="o_kanban_dashboard salaam_readiness_kanban_inner">
                                    <field name="status_color"/>
                                    <field name="gate_type"/>
                                    <field name="required_pct"/>
                                    <field name="total_count"/>
                                    <field name="done_count"/>
                                    <field name="blocked_count"/>
                                    <field name="pct_complete"/>
                                    <templates>
                                        <t t-name="card">
                                            <div t-attf-class="oe_kanban_card oe_kanban_global_click salaam_cat_card salaam_cat_{{record.status_color.raw_value}}">
                                                <strong>
                                                    <field name="display_name"/>
                                                </strong>
                                                <div class="mt-1 small">
                                                    <span t-attf-class="badge salaam_gate_{{record.gate_type.raw_value}}">
                                                        <field name="gate_type"/>
                                                    </span>
                                                    <span class="ms-2 text-muted">
                                                        <field name="done_count"/> / <field name="total_count"/>
                                                    </span>
                                                </div>
                                                <div class="mt-2">
                                                    <field name="pct_complete" widget="progressbar"/>
                                                </div>
                                                <div t-if="record.blocked_count.raw_value &gt; 0" class="mt-1">
                                                    <span class="badge text-bg-danger">
                                                        <field name="blocked_count"/> blocked
                                                    </span>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                                <list>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="gate_type"/>
                                    <field name="required_pct"/>
                                    <field name="total_count"/>
                                    <field name="done_count"/>
                                    <field name="pct_complete" widget="progressbar"/>
                                    <field name="status_color"/>
                                </list>
                            </field>
                        </page>
                        <page string="All Items" name="all_items">
                            <field name="item_ids" readonly="1">
                                <list decoration-success="status == 'done'"
                                      decoration-info="status == 'in_progress'"
                                      decoration-danger="status == 'blocked' or is_overdue"
                                      decoration-muted="status == 'na'">
                                    <field name="category_code"/>
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="owner_id" widget="many2one_avatar_user"/>
                                    <field name="due_date"/>
                                    <field name="status"/>
                                    <field name="pct_complete" widget="progressbar"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action ======================================================= -->
    <record id="action_readiness_tracker" model="ir.actions.act_window">
        <field name="name">Readiness Trackers</field>
        <field name="res_model">salaam.readiness.tracker</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Welcome to the Pre-Launch Readiness Tracker.
            </p>
            <p>
                The Phase-1 Lot-1 tracker is seeded automatically.
                Open it to see the 14 categories and 110 items, and
                monitor the Decision Gate 0 readiness signal.
            </p>
        </field>
    </record>

</odoo>
