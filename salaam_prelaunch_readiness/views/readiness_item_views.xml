<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================== -->
    <!-- Readiness Item - Search view                                    -->
    <!-- ============================================================== -->
    <record id="view_readiness_item_search" model="ir.ui.view">
        <field name="name">salaam.readiness.item.search</field>
        <field name="model">salaam.readiness.item</field>
        <field name="arch" type="xml">
            <search string="Search Readiness Items">
                <field name="name" string="Item"/>
                <field name="category_id"/>
                <field name="owner_id"/>
                <field name="tracker_id"/>
                <separator/>
                <filter name="filter_my_items" string="My Items"
                        domain="[('owner_id','=',uid)]"/>
                <filter name="filter_blocked" string="Blocked"
                        domain="[('status','=','blocked')]"/>
                <filter name="filter_overdue" string="Overdue"
                        domain="[('is_overdue','=',True)]"/>
                <filter name="filter_in_progress" string="In Progress"
                        domain="[('status','=','in_progress')]"/>
                <filter name="filter_not_started" string="Not Started"
                        domain="[('status','=','not_started')]"/>
                <filter name="filter_done" string="Done"
                        domain="[('status','=','done')]"/>
                <separator/>
                <filter name="filter_hard_gate" string="Hard Gate"
                        domain="[('gate_type','=','hard')]"/>
                <filter name="filter_parallel" string="Parallel"
                        domain="[('gate_type','=','parallel')]"/>
                <filter name="filter_mob" string="Mobilization"
                        domain="[('gate_type','=','mob')]"/>
                <separator/>
                <filter name="filter_due_this_week" string="Due This Week"
                        domain="[('due_date','&gt;=',(context_today()).strftime('%Y-%m-%d')),
                                 ('due_date','&lt;=',(context_today() + relativedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter name="group_category" string="Category"
                            context="{'group_by': 'category_id'}"/>
                    <filter name="group_status" string="Status"
                            context="{'group_by': 'status'}"/>
                    <filter name="group_gate" string="Gate Type"
                            context="{'group_by': 'gate_type'}"/>
                    <filter name="group_owner" string="Owner"
                            context="{'group_by': 'owner_id'}"/>
                    <filter name="group_due_month" string="Due Month"
                            context="{'group_by': 'due_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Action  (defined early so the form's stat button can ref it)    -->
    <!-- ============================================================== -->
    <record id="action_readiness_item" model="ir.actions.act_window">
        <field name="name">Readiness Items</field>
        <field name="res_model">salaam.readiness.item</field>
        <field name="view_mode">list,kanban,form,pivot,calendar</field>
        <field name="search_view_id" ref="view_readiness_item_search"/>
        <field name="context">{'search_default_group_category': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No readiness items found.
            </p>
            <p>
                Items are seeded automatically with the Phase-1 Lot-1 tracker.
                Open the tracker form to navigate by category.
            </p>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Readiness Item - List view                                      -->
    <!-- ============================================================== -->
    <record id="view_readiness_item_list" model="ir.ui.view">
        <field name="name">salaam.readiness.item.list</field>
        <field name="model">salaam.readiness.item</field>
        <field name="arch" type="xml">
            <list string="Readiness Items"
                  decoration-success="status == 'done'"
                  decoration-info="status == 'in_progress'"
                  decoration-danger="status == 'blocked' or is_overdue"
                  decoration-muted="status == 'na'"
                  multi_edit="1">
                <field name="category_code" string="Cat" optional="show"/>
                <field name="sequence" string="#" optional="show"/>
                <field name="name"/>
                <field name="gate_type" optional="show"/>
                <field name="owner_id" widget="many2one_avatar_user" optional="show"/>
                <field name="due_date" optional="show"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'done'"
                       decoration-info="status == 'in_progress'"
                       decoration-danger="status == 'blocked'"
                       decoration-muted="status == 'na'"/>
                <field name="pct_complete" widget="progressbar" optional="show"/>
                <field name="evidence_url" widget="url" optional="hide"/>
                <field name="evidence_count" string="Files" optional="show"/>
                <field name="is_overdue" string="OD" optional="hide"/>
                <field name="tracker_id" optional="hide"/>
                <field name="category_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Readiness Item - Form view                                      -->
    <!-- ============================================================== -->
    <record id="view_readiness_item_form" model="ir.ui.view">
        <field name="name">salaam.readiness.item.form</field>
        <field name="model">salaam.readiness.item</field>
        <field name="arch" type="xml">
            <form string="Readiness Item">
                <header>
                    <button name="action_mark_in_progress" type="object"
                            string="Start" class="oe_highlight"
                            invisible="status in ('in_progress','done','na')"/>
                    <button name="action_mark_done" type="object"
                            string="Mark Done" class="oe_highlight"
                            invisible="status == 'done'"/>
                    <button name="action_mark_blocked" type="object"
                            string="Block"
                            invisible="status in ('done','blocked','na')"/>
                    <button name="action_open_linked_record" type="object"
                            string="Open Linked Record"
                            invisible="not linked_record_ref"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="not_started,in_progress,done"
                           options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_readiness_item)d" type="action"
                                class="oe_stat_button" icon="fa-list">
                            <field name="evidence_count" widget="statinfo"
                                   string="Evidence"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Blocked" bg_color="bg-danger"
                            invisible="status != 'blocked'"/>
                    <widget name="web_ribbon" title="Overdue" bg_color="bg-warning"
                            invisible="status == 'done' or status == 'na' or not is_overdue"/>
                    <div class="oe_title">
                        <label for="name" string="Item"/>
                        <h1><field name="name" placeholder="Readiness item description..."/></h1>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="category_id" options="{'no_create': True}"/>
                            <field name="tracker_id" readonly="1"/>
                            <field name="category_code" readonly="1"/>
                            <field name="gate_type" readonly="1"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Ownership &amp; Timing">
                            <field name="owner_id" widget="many2one_avatar_user"/>
                            <field name="due_date"/>
                            <field name="is_overdue" readonly="1"/>
                            <field name="pct_complete" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Evidence" name="evidence">
                            <group>
                                <field name="evidence_url" widget="url" placeholder="https://..."/>
                                <field name="linked_record_ref"/>
                            </group>
                            <separator string="Files"/>
                            <field name="evidence_attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Context, blockers, decisions..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Readiness Item - Kanban view                                    -->
    <!-- ============================================================== -->
    <record id="view_readiness_item_kanban" model="ir.ui.view">
        <field name="name">salaam.readiness.item.kanban</field>
        <field name="model">salaam.readiness.item</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column"
                    quick_create="false" sample="1">
                <field name="color"/>
                <field name="category_code"/>
                <field name="gate_type"/>
                <field name="owner_id"/>
                <field name="due_date"/>
                <field name="pct_complete"/>
                <field name="is_overdue"/>
                <templates>
                    <t t-name="card">
                        <div t-att-class="'oe_kanban_card oe_kanban_global_click oe_kanban_color_' + record.color.raw_value">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <span class="badge text-bg-secondary me-1">
                                            <field name="category_code"/>.<field name="sequence"/>
                                        </span>
                                        <field name="name"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <span class="text-muted">Gate: </span>
                                    <field name="gate_type"/>
                                </div>
                                <div t-if="record.due_date.raw_value">
                                    <span class="text-muted">Due: </span>
                                    <field name="due_date"/>
                                    <span t-if="record.is_overdue.raw_value"
                                          class="badge text-bg-danger ms-1">Overdue</span>
                                </div>
                                <div class="mt-2">
                                    <field name="pct_complete" widget="progressbar"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left"/>
                                <div class="oe_kanban_bottom_right">
                                    <field name="owner_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Readiness Item - Pivot view                                     -->
    <!-- ============================================================== -->
    <record id="view_readiness_item_pivot" model="ir.ui.view">
        <field name="name">salaam.readiness.item.pivot</field>
        <field name="model">salaam.readiness.item</field>
        <field name="arch" type="xml">
            <pivot string="Readiness Items">
                <field name="category_id" type="row"/>
                <field name="status" type="col"/>
                <field name="pct_complete" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ============================================================== -->
    <!-- Readiness Item - Calendar view (by due date)                    -->
    <!-- ============================================================== -->
    <record id="view_readiness_item_calendar" model="ir.ui.view">
        <field name="name">salaam.readiness.item.calendar</field>
        <field name="model">salaam.readiness.item</field>
        <field name="arch" type="xml">
            <calendar string="Readiness - Due Dates"
                      date_start="due_date"
                      color="category_id"
                      mode="month">
                <field name="name"/>
                <field name="status"/>
                <field name="owner_id"/>
            </calendar>
        </field>
    </record>

</odoo>
