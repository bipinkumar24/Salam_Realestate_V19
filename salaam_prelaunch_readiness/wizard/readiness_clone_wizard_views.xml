<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_readiness_clone_wizard_form" model="ir.ui.view">
        <field name="name">salaam.readiness.clone.wizard.form</field>
        <field name="model">salaam.readiness.clone.wizard</field>
        <field name="arch" type="xml">
            <form string="Clone Tracker">
                <sheet>
                    <div class="oe_title">
                        <h1>Clone Pre-Launch Readiness Tracker</h1>
                        <p class="text-muted">
                            Replicate the 14 categories and 110 items into a
                            new (Phase, Lot) tracker. Owner, status, evidence,
                            and linked records are reset; due dates are
                            optional.
                        </p>
                    </div>
                    <group>
                        <field name="source_tracker_id" options="{'no_create': True}"/>
                        <field name="new_phase_label" placeholder="e.g. Phase 1"/>
                        <field name="new_lot_label" placeholder="e.g. Lot 2"/>
                        <field name="new_name"/>
                        <field name="copy_due_dates"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <strong>Reset on clone:</strong> status (Not Started),
                        % complete (0), owner, evidence link &amp; files,
                        linked record, notes.
                        <br/>
                        <strong>Preserved:</strong> category codes / names /
                        gate type, item sequence and item names.
                    </div>
                </sheet>
                <footer>
                    <button name="action_clone" type="object"
                            string="Clone" class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_readiness_clone_wizard" model="ir.actions.act_window">
        <field name="name">Clone Tracker</field>
        <field name="res_model">salaam.readiness.clone.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
