<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_readiness_excel_import_form" model="ir.ui.view">
        <field name="name">salaam.readiness.excel.import.form</field>
        <field name="model">salaam.readiness.excel.import</field>
        <field name="arch" type="xml">
            <form string="Import Tracker Status from Excel">
                <sheet>
                    <div class="oe_title">
                        <h1>Import from Excel</h1>
                        <p class="text-muted">
                            Upload a copy of the Salaam_City_PreLaunch_Tracker.xlsx
                            (or a sheet with the same A-N tab structure). Items
                            are matched to seeded records by category code +
                            sequence number. Idempotent: safe to re-run.
                        </p>
                    </div>
                    <group>
                        <field name="tracker_id" options="{'no_create': True}"
                               readonly="matched_count &gt; 0 or unmatched_count &gt; 0"/>
                        <field name="excel_file" filename="excel_filename"
                               readonly="matched_count &gt; 0 or unmatched_count &gt; 0"/>
                        <field name="excel_filename" invisible="1"/>
                        <field name="update_owner"
                               readonly="matched_count &gt; 0 or unmatched_count &gt; 0"/>
                        <field name="update_evidence_link"
                               readonly="matched_count &gt; 0 or unmatched_count &gt; 0"/>
                    </group>
                    <group string="Result"
                           invisible="matched_count == 0 and unmatched_count == 0">
                        <field name="matched_count" readonly="1"/>
                        <field name="unmatched_count" readonly="1"/>
                        <field name="result_log" readonly="1" widget="text"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_import" type="object"
                            string="Import" class="btn-primary"
                            invisible="matched_count &gt; 0 or unmatched_count &gt; 0"/>
                    <button special="cancel" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_readiness_excel_import" model="ir.actions.act_window">
        <field name="name">Import from Excel</field>
        <field name="res_model">salaam.readiness.excel.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
