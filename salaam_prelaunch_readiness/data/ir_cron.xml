<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Nightly recompute of readiness KPIs.
         Aligns with the existing salaam_iafao_dashboard cron chain. -->
    <record id="cron_readiness_recompute" model="ir.cron">
        <field name="name">Salaam: Pre-Launch Readiness - nightly recompute</field>
        <field name="model_id" ref="model_salaam_readiness_tracker"/>
        <field name="state">code</field>
        <field name="code">model._cron_recompute_readiness()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
