        <record id="demo_wo_concrete_l1" model="buruuj.workorder">
            <field name="title">Pour Floor Slab — Level 1</field>
            <field name="subcontract_id" ref="demo_sc_marina_concrete"/>
            <field name="date" eval="(DateTime.today() - relativedelta(months=4)).strftime('%Y-%m-%d')"/>
            <field name="start_date" eval="(DateTime.today() - relativedelta(months=4)).strftime('%Y-%m-%d')"/>
            <field name="end_date" eval="(DateTime.today() - relativedelta(months=3, days=15)).strftime('%Y-%m-%d')"/>
