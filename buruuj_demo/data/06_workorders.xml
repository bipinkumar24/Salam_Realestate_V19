            <field name="amount">285000.00</field>
            <field name="progress">100</field>
            <field name="state">signed_off</field>
            <field name="description"><![CDATA[<p>Cast 480 m³ of C30 concrete for Level 1 slab. Includes formwork, reinforcement, pour, and 28-day curing.</p>]]></field>
        </record>

