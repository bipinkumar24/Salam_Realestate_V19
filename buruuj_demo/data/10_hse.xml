<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="demo_tb_marina_height" model="buruuj.toolbox.talk">
            <field name="name">Working at Height — Refresher</field>
            <field name="project_id" ref="demo_project_marina"/>
            <field name="date" eval="(DateTime.today() - relativedelta(days=2)).strftime('%Y-%m-%d')"/>
            <field name="topic">Working at height: harness use, edge protection, dropped objects</field>
            <field name="attendee_count">68</field>
            <field name="state">done</field>
            <field name="notes"><![CDATA[<p>Reviewed harness inspection checklist; demonstrated correct anchor point selection. Three workers identified for additional training on rescue procedures.</p>]]></field>
        </record>

        <record id="demo_tb_hc7_traffic" model="buruuj.toolbox.talk">
            <field name="name">Traffic Management — Live Highway</field>
            <field name="project_id" ref="demo_project_hc7"/>
            <field name="date" eval="(DateTime.today() - relativedelta(days=4)).strftime('%Y-%m-%d')"/>
            <field name="topic">Traffic management when working adjacent to live lanes</field>
            <field name="attendee_count">35</field>
            <field name="state">done</field>
        </record>

        <record id="demo_ptw_marina_hot" model="buruuj.ptw">
            <field name="project_id" ref="demo_project_marina"/>
            <field name="type">hot_work</field>
            <field name="date" eval="DateTime.today().strftime('%Y-%m-%d')"/>
            <field name="valid_from" eval="DateTime.today().strftime('%Y-%m-%d 08:00:00')"/>
            <field name="valid_to" eval="DateTime.today().strftime('%Y-%m-%d 17:00:00')"/>
            <field name="location">L4 plant room — welding of HVAC supports</field>
            <field name="contractor_id" ref="demo_sub_climacool"/>
            <field name="state">active</field>
            <field name="ppe_required">Welding helmet, leather gloves, fire-retardant coveralls</field>
            <field name="hazards"><![CDATA[<ul><li>Sparks and hot slag</li><li>Combustible insulation in vicinity</li><li>Confined ventilation</li></ul>]]></field>
            <field name="controls"><![CDATA[<ul><li>Fire watch posted with extinguisher</li><li>Combustibles removed within 10m</li><li>Mechanical ventilation in place</li></ul>]]></field>
        </record>

        <record id="demo_inc_marina_1" model="buruuj.hse.incident">
            <field name="title">Worker slip on wet floor — first aid administered</field>
            <field name="project_id" ref="demo_project_marina"/>
            <field name="date" eval="(DateTime.today() - relativedelta(days=12)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="location">L2 stair core — east side</field>
            <field name="type">first_aid</field>
            <field name="severity">low</field>
            <field name="state">closed</field>
            <field name="closed_date" eval="(DateTime.today() - relativedelta(days=8)).strftime('%Y-%m-%d')"/>
            <field name="persons_involved">M. Khan (carpenter, ID 4421)</field>
            <field name="description"><![CDATA[<p>Worker slipped on wet concrete surface, sustained minor abrasion to elbow. First aid administered on site, returned to work.</p>]]></field>
            <field name="root_cause"><![CDATA[<p>Concrete curing water pooled without warning signage.</p>]]></field>
            <field name="corrective_action"><![CDATA[<p>Mandatory wet-floor signage during curing. Cleaning crew briefed.</p>]]></field>
        </record>

    </data>
</odoo>
