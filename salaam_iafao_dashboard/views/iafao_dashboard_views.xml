<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_iafao_dashboard" model="ir.actions.act_window">
        <field name="name">IAFAO Dashboard</field>
        <field name="res_model">salaam.iafao.dashboard</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_iafao_dashboard_list" model="ir.ui.view">
        <field name="name">salaam.iafao.dashboard.list</field>
        <field name="model">salaam.iafao.dashboard</field>
        <field name="arch" type="xml">
            <list string="IAFAO Dashboards">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_iafao_dashboard_form" model="ir.ui.view">
        <field name="name">salaam.iafao.dashboard.form</field>
        <field name="model">salaam.iafao.dashboard</field>
        <field name="arch" type="xml">
            <form string="IAFAO Dashboard">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <group string="Notes">
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
