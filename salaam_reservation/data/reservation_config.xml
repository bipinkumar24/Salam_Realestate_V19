<?xml version="1.0" encoding="utf-8"?>
<odoo><data noupdate="1">
  <!-- Daily cron to auto-expire reservations past conversion deadline -->
  <record id="cron_expire_reservations" model="ir.cron">
    <field name="name">Salaam: Auto-Expire Reservations</field>
    <field name="model_id" ref="model_salaam_reservation"/>
    <field name="state">code</field>
    <field name="code">model.cron_expire_reservations()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">days</field>
    <field name="active">True</field>
  </record>
</data></odoo>