<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <!-- Priority Number sequence — monthly reset, 4-digit padding -->
    <record id="seq_crm_priority" model="ir.sequence">
      <field name="name">CRM Priority Number</field>
      <field name="code">salaam.crm.priority</field>
      <field name="prefix">PRI/%(day)s%(month)s%(year)s/</field>
      <field name="padding">4</field>
      <field name="number_increment">1</field>
      <field name="number_next">1</field>
    </record>

    <!-- File Number sequence — monthly reset, 4-digit padding -->
    <record id="seq_crm_file" model="ir.sequence">
      <field name="name">CRM File Number</field>
      <field name="code">salaam.crm.file</field>
      <field name="prefix">FILE/%(day)s%(month)s%(year)s/</field>
      <field name="padding">4</field>
      <field name="number_increment">1</field>
      <field name="number_next">1</field>
    </record>

  </data>
</odoo>
