<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rfq_list" model="ir.ui.view">
        <field name="name">buruuj.rfq.list</field>
        <field name="model">buruuj.rfq</field>
        <field name="arch" type="xml">
            <list decoration-success="state in ('selected','po_raised')"
                  decoration-info="state == 'evaluating'"
                  decoration-warning="state == 'issued'">
                <field name="name"/>
                <field name="mr_id"/>
                <field name="project_id"/>
                <field name="date"/>
                <field name="response_due"/>
                <field name="quote_count" string="# Quotes"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_rfq_form" model="ir.ui.view">
        <field name="name">buruuj.rfq.form</field>
        <field name="model">buruuj.rfq</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_issue" string="Issue to Vendors"
                            type="object" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_evaluate" string="Start Evaluation"
                            type="object" class="oe_highlight"
                            invisible="state != 'issued'"/>
                    <button name="action_select_vendor" string="Confirm Selection"
                            type="object" class="oe_highlight"
                            invisible="state != 'evaluating'"/>
                    <button name="action_raise_po" string="Raise PO"
                            type="object" class="oe_highlight"
                            invisible="state != 'selected'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state in ('po_raised','cancelled')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="mr_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="response_due"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Materials Requested">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="material_id"/>
                                    <field name="specification"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                        <page string="Vendor Quotes">
                            <field name="quote_ids">
                                <list decoration-success="is_selected">
                                    <field name="vendor_id"/>
                                    <field name="quote_ref"/>
                                    <field name="quote_date"/>
                                    <field name="validity_date"/>
                                    <field name="lead_time_days"/>
                                    <field name="total_amount" sum="Total"/>
                                    <field name="is_selected" widget="boolean_favorite"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="vendor_id"/>
                                                <field name="quote_ref"/>
                                                <field name="quote_date"/>
                                                <field name="validity_date"/>
                                            </group>
                                            <group>
                                                <field name="delivery_terms"/>
                                                <field name="payment_terms"/>
                                                <field name="lead_time_days"/>
                                                <field name="total_amount"/>
                                                <field name="currency_id" invisible="1"/>
                                            </group>
                                        </group>
                                        <field name="line_ids">
                                            <list editable="bottom">
                                                <field name="rfq_line_id"/>
                                                <field name="material_id"/>
                                                <field name="quantity"/>
                                                <field name="uom_id"/>
                                                <field name="unit_price"/>
                                                <field name="line_total" sum="Total"/>
                                                <field name="notes"/>
                                                <field name="currency_id" column_invisible="1"/>
                                            </list>
                                        </field>
                                        <field name="notes"/>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Selection" invisible="state in ('draft','issued')">
                            <field name="selected_quote_id"
                                   domain="[('rfq_id','=',id)]"/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_rfq" model="ir.actions.act_window">
        <field name="name">Requests for Quotation</field>
        <field name="res_model">buruuj.rfq</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
