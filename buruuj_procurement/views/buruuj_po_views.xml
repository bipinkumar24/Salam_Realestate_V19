<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_po_list" model="ir.ui.view">
        <field name="name">buruuj.po.list</field>
        <field name="model">buruuj.po</field>
        <field name="arch" type="xml">
            <list decoration-success="state in ('received','closed')"
                  decoration-info="state in ('issued','partial')"
                  decoration-warning="state in ('qs_approved','pm_approved')"
                  decoration-danger="state == 'cancelled'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="vendor_id"/>
                <field name="date"/>
                <field name="expected_delivery"/>
                <field name="total_amount" sum="Total"/>
                <field name="director_required" widget="boolean_toggle"
                       optional="hide"/>
                <field name="state" widget="badge"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_po_form" model="ir.ui.view">
        <field name="name">buruuj.po.form</field>
        <field name="model">buruuj.po</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_qs_approve" string="QS Approve"
                            type="object" class="oe_highlight"
                            invisible="state != 'draft'"
                            groups="buruuj_base.group_buruuj_qs"/>
                    <button name="action_pm_approve" string="PM Approve"
                            type="object" class="oe_highlight"
                            invisible="state != 'qs_approved'"
                            groups="buruuj_base.group_buruuj_pm"/>
                    <button name="action_director_approve"
                            string="Director Approve"
                            type="object" class="oe_highlight"
                            invisible="state != 'pm_approved' or not director_required"
                            groups="buruuj_base.group_buruuj_director"/>
                    <button name="action_issue" string="Issue to Vendor"
                            type="object" class="oe_highlight"
                            invisible="state != 'approved'"/>
                    <button name="action_create_grn" string="Receive Goods (GRN)"
                            type="object"
                            invisible="state not in ('issued','partial')"/>
                    <button name="action_close" string="Close"
                            type="object"
                            invisible="state not in ('received','partial')"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state in ('received','closed','cancelled')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_grns" type="object"
                                class="oe_stat_button" icon="fa-truck">
                            <field name="grn_count" widget="statinfo"
                                   string="GRNs"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="vendor_id"/>
                            <field name="rfq_id"/>
                            <field name="mr_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="expected_delivery"/>
                            <field name="director_required"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="material_id"/>
                                    <field name="specification"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="unit_price"/>
                                    <field name="line_total" sum="Subtotal"/>
                                    <field name="received_qty"/>
                                    <field name="outstanding_qty"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="subtotal"/>
                                <field name="vat_rate"/>
                                <field name="vat_amount"/>
                                <field name="total_amount"
                                       class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page string="Terms">
                            <group>
                                <group>
                                    <field name="delivery_address"/>
                                    <field name="delivery_terms"/>
                                </group>
                                <group>
                                    <field name="payment_terms"/>
                                    <field name="incoterm"/>
                                </group>
                            </group>
                        </page>
                        <page string="Approvals">
                            <group>
                                <group string="QS Approval">
                                    <field name="qs_approved_by" readonly="1"/>
                                    <field name="qs_approved_date" readonly="1"/>
                                </group>
                                <group string="PM Approval">
                                    <field name="pm_approved_by" readonly="1"/>
                                    <field name="pm_approved_date" readonly="1"/>
                                </group>
                                <group string="Director Approval"
                                       invisible="not director_required">
                                    <field name="director_approved_by"
                                           readonly="1"/>
                                    <field name="director_approved_date"
                                           readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_po" model="ir.actions.act_window">
        <field name="name">Purchase Orders</field>
        <field name="res_model">buruuj.po</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_po_pending" model="ir.actions.act_window">
        <field name="name">POs Pending Approval</field>
        <field name="res_model">buruuj.po</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','in',('draft','qs_approved','pm_approved'))]</field>
    </record>
</odoo>
