<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_issuance_list" model="ir.ui.view">
        <field name="name">buruuj.material.issuance.list</field>
        <field name="model">buruuj.material.issuance</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'issued'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="phase_id"/>
                <field name="subcontract_id" optional="show"/>
                <field name="date"/>
                <field name="total_value" sum="Total"/>
                <field name="state" widget="badge"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_issuance_form" model="ir.ui.view">
        <field name="name">buruuj.material.issuance.form</field>
        <field name="model">buruuj.material.issuance</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_issue" string="Issue Materials"
                            type="object" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="phase_id"/>
                            <field name="subcontract_id"/>
                            <field name="boq_line_ref"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="issued_by"/>
                            <field name="received_by_name"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="material_id"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                            <field name="unit_value"/>
                            <field name="line_value" sum="Total"/>
                            <field name="notes"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>
                    <field name="purpose"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_issuance" model="ir.actions.act_window">
        <field name="name">Material Issuances</field>
        <field name="res_model">buruuj.material.issuance</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
