<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_grn_list" model="ir.ui.view">
        <field name="name">buruuj.grn.list</field>
        <field name="model">buruuj.grn</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'accepted'"
                  decoration-warning="state == 'partial'"
                  decoration-danger="state == 'rejected'"
                  decoration-info="state == 'inspected'">
                <field name="name"/>
                <field name="po_id"/>
                <field name="vendor_id"/>
                <field name="project_id"/>
                <field name="date"/>
                <field name="delivery_note_ref"/>
                <field name="overall_quality"/>
                <field name="has_rejection" optional="show"/>
                <field name="has_short_supply" optional="show"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_grn_form" model="ir.ui.view">
        <field name="name">buruuj.grn.form</field>
        <field name="model">buruuj.grn</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_inspect" string="Mark Inspected"
                            type="object" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_accept" string="Accept &amp; Stock"
                            type="object" class="oe_highlight"
                            invisible="state != 'inspected'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="po_id"/>
                            <field name="vendor_id"/>
                            <field name="project_id"/>
                            <field name="delivery_note_ref"/>
                            <field name="delivery_vehicle"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="received_by"/>
                            <field name="inspected_by" readonly="1"/>
                            <field name="inspection_date" readonly="1"/>
                            <field name="overall_quality"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="material_id"/>
                                    <field name="ordered_qty"/>
                                    <field name="previously_received"/>
                                    <field name="received_qty"/>
                                    <field name="accepted_qty"/>
                                    <field name="rejected_qty"/>
                                    <field name="rejection_reason"/>
                                    <field name="uom_id"/>
                                    <field name="unit_price"/>
                                    <field name="accepted_value" sum="Value"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Quality Notes">
                            <field name="quality_notes"
                                   placeholder="Inspection observations, conditions of acceptance..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_grn" model="ir.actions.act_window">
        <field name="name">Goods Receipt Notes</field>
        <field name="res_model">buruuj.grn</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
