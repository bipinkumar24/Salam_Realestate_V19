<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="rental_management.SaleContractDashboard">
        <div class="o_rental_contract_dashboard container-fluid d-flex flex-column py-4 border-bottom bg-view overflow-auto tk-dash" t-on-click="onDashboardClick">
            <div class="d-flex flex-column gap-3">
                <div class="row g-4">
                    <div class="col-lg-12 col-xl-6 col-xxl-5">
                        <div class="bg-gray p-4 d-flex flex-column">
                            <div class="">
                                <h5 class="tk-primary">Status</h5>
                                <hr class="tk-hr-border" />
                            </div>
                            <div class="d-flex justify-content-between gap-3 w-100">
                                <div class="d-flex flex-column gap-2 w-100">
                                    <div class="card py-4 px-2 text-center custom-sale-card bg-total prop-cursor w-100 o_sale_contract_action"
                                        title="Booked" data-field="stage" data-value="booked">
                                        <h4 class="bg-total mb-1">
                                            <t t-out="state.values['booked_count']" />
                                        </h4>
                                        <div class="fw-bold">Booked</div>
                                    </div>
                                </div>
                                <div class="d-flex flex-column gap-2 w-100">
                                    <div class="card py-4 px-2 text-center custom-sale-card bg-draft prop-cursor w-100 o_sale_contract_action"
                                        title="Sold" data-field="stage" data-value="sold">
                                        <h4 class="bg-draft mb-1">
                                            <t t-out="state.values['sold_count']" />
                                        </h4>
                                        <div class="fw-bold">Sold</div>
                                    </div>
                                </div>
                                <div class="d-flex flex-column gap-2 w-100">
                                    <div class="card py-4 px-2 text-center custom-sale-card bg-available prop-cursor w-100 o_sale_contract_action"
                                        title="Refund" data-field="stage" data-value="refund">
                                        <h4 class="bg-available mb-1">
                                            <t t-out="state.values['refund_count']" />
                                        </h4>
                                        <div class="fw-bold">Refund</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-12 col-xl-6 col-xxl-7">
                        <div class="bg-gray p-4 d-flex flex-column">
                            <div class="">
                                <h5 class="tk-primary">Property Types</h5>
                                <hr class="tk-hr-border" />
                            </div>
                            <div class="row -mx-2">
                                <div class="col-6 col-sm-6 col-md-3 col-xl-3 mb-3 px-2">
                                    <div class="card py-4 px-2 text-center bg-sale custom-sale-card prop-cursor w-100 o_sale_contract_action"
                                        data-field="type" data-value="land"
                                        title="Land Properties Contracts">
                                        <h4 class="bg-sale mb-1">
                                            <t t-out="state.values['land_count']" />
                                        </h4>
                                        <div class="fw-bold">Land</div>
                                    </div>
                                </div>
                                <div class="col-6 col-sm-6 col-md-3 col-xl-3 mb-3 px-2">
                                    <div class="card py-4 px-2 text-center custom-sale-card bg-booked prop-cursor w-100 o_sale_contract_action"
                                        data-field="type" data-value="residential"
                                        title="Residential Properties Contracts">
                                        <h4 class="bg-booked mb-1">
                                            <t t-out="state.values['residential_count']" />
                                        </h4>
                                        <div class="fw-bold">Residential</div>
                                    </div>
                                </div>
                                <div class="col-6 col-sm-6 col-md-3 col-xl-3 mb-3 px-2">
                                    <div class="card py-4 px-2 text-center custom-sale-card bg-sold prop-cursor w-100 o_sale_contract_action"
                                        data-field="type" data-value="commercial"
                                        title="Commercial Properties Contracts">
                                        <h4 class="bg-sold mb-1">
                                            <t t-out="state.values['commercial_count']" />
                                        </h4>
                                        <div class="fw-bold bg-sold">Commercial</div>
                                    </div>
                                </div>
                                <div class="col-6 col-sm-6 col-md-3 col-xl-3 mb-3 px-2">
                                    <div class="card py-4 px-2 text-center custom-sale-card bg-available prop-cursor w-100 o_sale_contract_action"
                                        data-field="type" data-value="industrial"
                                        title="Industrial Properties Contracts">
                                        <h4 class="bg-available mb-1">
                                            <t t-out="state.values['industrial_count']" />
                                        </h4>
                                        <div class="fw-bold">Industrial</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
