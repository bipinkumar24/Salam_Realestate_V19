<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="property_amenities_form_view" model="ir.ui.view">
            <field name="name">property.amenities.form.view</field>
            <field name="model">property.amenities</field>
            <field name="arch" type="xml">
                <form duplicate="false">
                    <sheet>
                        <field name="image" widget="image" class="oe_avatar"/>
                        <div class="oe_title">
                            <label for="title"/>
                            <h1>
                                <field name="title" required="1" placeholder="Title"/>
                            </h1>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="property_amenities_tree_view" model="ir.ui.view">
            <field name="name">property.amenities.tree.view</field>
            <field name="model">property.amenities</field>
            <field name="arch" type="xml">
                <list duplicate="false">
                    <field name="sequence" widget="handle"/>
                    <field name="title"/>
                </list>
            </field>
        </record>
        <record id="property_amenities_kanban_view" model="ir.ui.view">
            <field name="name">property.amenities.kanban.view</field>
            <field name="model">property.amenities</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="id"/>
                    <field name="title"/>
                    <field name="image"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click d-flex flex-row"
                                 style="gap:8px; align-items:flex-start;">
                                <t t-if="record.image.value">
                                    <img alt="Avatar"
                                         t-attf-src="/web/image/property.amenities/{{ record.id.raw_value }}/image"
                                         style="width:100px; height:100px; object-fit:cover; flex-shrink:0;"/>
                                </t>
                                <t t-else="">
                                    <img alt="Image"
                                         src="/rental_management/static/src/img/category-placeholder.png"
                                         style="width:100px; height:100px; object-fit:cover; flex-shrink:0;"/>
                                </t>
                                <div class="d-flex flex-column w-100" style="align-items:flex-start;">
                                    <strong style="color:#714B67; font-size:15px; text-align:right;">
                                        <field name="title"/>
                                    </strong>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        <record id="property_amenities_action" model="ir.actions.act_window">
            <field name="name">Property Amenities</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">property.amenities</field>
            <field name="view_mode">kanban,list,form</field>
        </record>
    </data>
</odoo>
