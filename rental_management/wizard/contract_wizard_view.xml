<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="contract_wizard_form_view" model="ir.ui.view">
            <field name="name">contract.wizard.form.view</field>
            <field name="model">contract.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <!-- Lead Details -->
                    <group string="Lead Details">
                        <group>
                            <field name="from_inquiry"/>
                        </group>
                        <group>
                            <field name="lead_id" options="{'no_create':True}"
                                   invisible="from_inquiry == False"
                                   readonly="is_contract_extend == True"
                                   required="from_inquiry == True"/>
                        </group>
                    </group>
                    <!-- Customer &amp; Property Details -->
                    <group>
                        <group string="Customer Details">
                            <field name="customer_id" required="1"
                                   readonly="is_contract_extend == True"
                                   options="{'no_quick_create':True}"/>
                            <field name="customer_phone" widget="phone"/>
                            <field name="customer_email" widget="email"/>
                        </group>
                        <group string="Property Details">
                            <field name="is_contract_extend" invisible="1"/>
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="is_extra_service" invisible="1"/>
                            <field name="is_any_maintenance" invisible="1"/>
                            <field name="is_contract_available" invisible="1"/>
                            <field name="contract_desc" invisible="1"/>
                            <field name="property_id" readonly="1" force_save="1"/>
                            <label for="total_rent" string="Rent"/>
                            <div>
                                <field name="total_rent" required="1" class="oe_inline"/>
                                /
                                <field
                                        name="rent_unit" class="oe_inline" required="1"
                                        readonly="duration_type == 'by_date'"
                                        force_save="1"/>
                                <div
                                        class="font-italic text-muted"
                                        invisible="duration_type != 'by_date'">
                                    * Rent unit must be a "Day" when the duration type is "By Date".
                                </div>
                            </div>
                        </group>
                    </group>
                    <!-- Contract Details -->
                    <group string="Contract Details">
                        <group>
                            <field name="duration_type" widget="radio" options="{'horizontal':True}"
                                   required="1"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="start_date" required="1"/>
                            <label for="payment_term"/>
                            <div>
                                <field name="payment_term" required="1"
                                       force_save="1"/>
                                <div class="font-italic text-muted"
                                     invisible="payment_term != 'quarterly'">
                                    * 3 Month Quarter
                                </div>
                                <div class="font-italic text-muted"
                                     invisible="available_payment_term == False">
                                    <field name="available_payment_term"/>
                                </div>
                            </div>
                        </group>
                        <group>
                            <field name="end_date" required="1"
                                   invisible="duration_type != 'by_duration' or duration_id == False"/>
                            <field name="duration_end_date"
                                   invisible="duration_type != 'by_date'"
                                   required="duration_type == 'by_date'"
                                   string="End Date"/>
                            <field name="total_days"
                                   invisible="duration_type != 'by_date'"/>
                            <field name="duration_ids" invisible="1"/>
                            <field name="duration_id"
                                   required="duration_type == 'by_duration'"
                                   invisible="payment_term == False or duration_type != 'by_duration'"
                                   options="{'no_create':True,'no_create_edit':True,'no_open':True}"/>
                        </group>
                    </group>
                    <!-- Contract Period Notification -->
                    <div class="alert alert-warning text-center mb-0" role="alert"
                         invisible="is_contract_available == False or contract_desc == False">
                        <span class="fw-bold">Selected contract period is available.</span>
                        <br/>
                        <span invisible="contract_desc == False">with following
                            draft contract
                        </span>
                        <field name="contract_desc"
                               invisible="contract_desc == False" readonly="1"
                               force_save="1"/>
                    </div>
                    <div class="alert alert-success text-center mb-0" role="alert"
                         invisible="contract_desc != False or is_contract_available == False">
                        Selected contract time period is available.
                    </div>
                    <div class="alert alert-danger text-center" role="alert"
                         invisible="start_date == False or end_date == False or is_contract_available == True">
                        Selected contract time period is not available.
                    </div>
                    <!-- Rent Increment when extend contract -->
                    <group string="Rent Increment"
                           invisible="is_contract_extend == False">
                        <group>
                            <field name="is_rent_increment"/>
                        </group>
                    </group>
                    <group
                            invisible="is_contract_extend == False or is_rent_increment == False">
                        <group string="Current Rent">
                            <label for="current_rent_type"/>
                            <div>
                                <field name="current_rent_type" widget="radio"
                                       options="{'horizontal':True}"/>
                                <div class="font-italic text-muted"
                                     invisible="current_rent_type != 'area_wise'">
                                    In area-wise pricing types, the incremental rent is calculated
                                    based on the rent per
                                    area.
                                </div>
                            </div>
                            <label for="current_area" class="mt-1"/>
                            <div name="current_area">
                                <field name="current_area" class="oe_inline" force_save="1"/>
                                /
                                <field
                                        name="measure_unit" class="oe_inline"/>
                            </div>
                            <field name="price_per_area"
                                   invisible="current_rent_type != 'area_wise'"/>
                            <label for="total_rent" string="Rent"/>
                            <div>
                                <field name="total_rent" required="1" class="oe_inline"/>/
                                <field
                                        name="rent_unit" class="oe_inline" required="1"/>
                            </div>
                        </group>
                        <group string="Increment Rent">
                            <field name="rent_increment_type" widget="radio"
                                   options="{'horizontal':True}"/>
                            <field name="increment_percentage"
                                   invisible="rent_increment_type != 'percentage'"/>
                            <field name="increment_amount"
                                   invisible="rent_increment_type != 'fix'"/>
                            <field name="incremented_rent_area"
                                   invisible="current_rent_type != 'area_wise'"/>
                            <label for="incremented_rent" string="Final Rent"/>
                            <div>
                                <field name="incremented_rent" required="1" class="oe_inline"/>/
                                <field
                                        name="rent_unit" class="oe_inline"/>
                            </div>
                        </group>
                    </group>
                    <!-- Deposit -->
                    <group string="Security Deposit">
                        <group>
                            <field name="is_any_deposit"/>
                        </group>
                        <group>
                            <field name="deposit_amount"
                                   invisible="is_any_deposit == False"
                                   required="is_any_deposit == True"/>
                        </group>
                    </group>
                    <group
                            invisible="is_extra_service == False and is_any_maintenance == False">
                        <group invisible="is_extra_service == False"
                               string="Utility Services">
                            <field name="is_extra_service" invisible="1" string="Utility Services"/>
                            <field name="extra_service_invoice"
                                   widget="radio" string="Invoice" options="{'horizontal':True}"/>
                            <field name="extra_service_ids" nolabel="1" colspan="2">
                                <list>
                                    <field name="service_id"/>
                                    <field name="service_type"/>
                                    <field name="price"/>
                                </list>
                            </field>
                        </group>
                        <group invisible="is_any_maintenance == False"
                               string="Maintenance">
                            <field name="maintenance_service_invoice"
                                   widget="radio" string="Invoice" options="{'horizontal':True}"/>
                            <field name="maintenance_rent_type"/>
                            <field name="total_maintenance"/>
                        </group>
                    </group>
                    <group string="Extra Services">
                        <group>
                            <field name="is_added_services" string="Extra Service ?"/>
                            <field name="added_service_invoice"
                                   invisible="is_added_services == False"
                                   widget="radio" string="Invoice"/>
                        </group>
                        <group invisible="is_added_services == False">
                            <field name="added_service_ids" nolabel="1" colspan="2">
                                <list editable="bottom">
                                    <field name="service_id" required="1"
                                           options="{'no_quick_create':True}"/>
                                    <field name="price"/>
                                    <field name="company_id" invisible="1"/>
                                    <field name="currency_id" invisible="1"/>
                                </list>
                            </field>
                        </group>
                    </group>
                    <group string="Broker Details">
                        <group>
                            <field name="is_any_broker"/>
                        </group>
                    </group>
                    <group invisible="is_any_broker == False">
                        <group>
                            <field name="broker_id"
                                   options="{'no_create':True,'no_create_edit':True}"
                                   required="is_any_broker == True"/>
                            <field name="commission_from" widget="radio"
                                   options="{'horizontal': true}"
                                   required="is_any_broker == True"/>
                            <field name="rent_type"
                                   required="is_any_broker == True"
                                   widget="radio"
                                   options="{'horizontal': true}"/>
                        </group>
                        <group>
                            <field name="commission_type"
                                   required="is_any_broker == True"
                                   widget="radio" options="{'horizontal': true}"/>
                            <field name="broker_commission_percentage"
                                   invisible="commission_type != 'p'"
                                   required="commission_type == 'p'"/>
                            <field name="broker_commission" widget="monetary"
                                   invisible="commission_type != 'f'"
                                   required="commission_type == 'f'"/>
                        </group>
                    </group>
                    <group string="Taxes">
                        <group>
                            <field name="instalment_tax"/>
                            <field name="deposit_tax"
                                   invisible="is_any_deposit == False"/>
                            <field name="service_tax"
                                   invisible="is_extra_service == False"/>
                        </group>
                        <group
                                invisible="instalment_tax == False and deposit_tax == False and service_tax == False">
                            <field name="tax_ids" widget="many2many_tags"
                                   required="instalment_tax == True or deposit_tax == True or service_tax == True"/>
                        </group>
                    </group>
                    <group string="Penalty Details" invisible="is_penalty_visible == False">
                        <group>
                            <field name="is_penalty_visible" invisible="1"/>
                            <field name="is_penalty_applied"/>
                            <field name="penalty_percentage" invisible="is_penalty_applied == False" required="is_penalty_applied != False"/>
                        </group>
                        <group>
                            <field name="penalty_days_after_due" invisible="is_penalty_applied == False" required="is_penalty_applied != False"/>
                        </group>
                    </group>
                    <group string="Installment Item">
                        <group>
                            <field name="installment_item_id" required="1"/>
                            <field name="deposit_item_id"
                                   invisible="is_any_deposit == False"
                                   required="is_any_deposit == True"/>
                        </group>
                        <group>
                            <field name="broker_item_id"
                                   invisible="is_any_broker == False"
                                   required="is_any_broker == True"/>
                            <field name="maintenance_item_id"
                                   invisible="is_any_maintenance == False"
                                   required="is_any_maintenance == True"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Lead Note" invisible="lead_id == False">
                            <field name="note" widget="html" readonly="1" placeholder="Lead Notes"/>
                        </page>
                        <page string="Agreement">
                            <group string="Template">
                                <group>
                                    <field name="agreement_template_id"/>
                                </group>
                            </group>
                            <field name="agreement" placeholder="Rental Agreement."/>
                        </page>
                        <page string="Terms &amp; Conditions">
                            <field name="term_condition" placeholder="Terms &amp; Conditions"
                                   widget="html"/>
                        </page>
                    </notebook>
                    <footer>
                        <button string="Create Contract" type="object"
                                class="btn btn-outline-success"
                                name="contract_action"
                                invisible="is_contract_available == False or payment_term == 'full_payment'"/>
                        <button string="Create Invoice" type="object"
                                class="btn btn-outline-success"
                                name="contract_action"
                                invisible="is_contract_available == False or payment_term != 'full_payment'"/>
                        <button string="Cancel" special="cancel" class="btn btn-outline-danger"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="contract_wizard_action" model="ir.actions.act_window">
            <field name="name">Contract</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">contract.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
