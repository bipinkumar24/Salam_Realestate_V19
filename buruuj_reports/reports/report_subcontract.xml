<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_subcontract_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <style>
                            .buruuj-title { color: #0B2545; }
                            .buruuj-accent { color: #C9A227; }
                            .buruuj-bar { border-top: 4px solid #C9A227; margin: 8px 0; }
                            .buruuj-bar-thin { border-top: 1px solid #0B2545; margin: 4px 0; }
                            .buruuj-section {
                                background: #0B2545; color: white;
                                padding: 4px 8px; margin: 12px 0 6px 0;
                                font-weight: bold; font-size: 10pt;
                            }
                            .buruuj-box {
                                border: 1px solid #ccc; padding: 8px;
                                background: #f9f9f9; border-radius: 3px;
                            }
                            table.kv td { padding: 3px 6px; font-size: 9.5pt; }
                            table.kv td.label { font-weight: bold; width: 35%; color: #0B2545; }
                            table.lines th {
                                background: #0B2545; color: white;
                                padding: 5px; font-size: 9pt;
                            }
                            table.lines td {
                                padding: 4px; font-size: 9pt;
                                border-bottom: 1px solid #eee;
                            }
                            .signature-box {
                                border-top: 1px solid #333;
                                padding-top: 6px; margin-top: 50px;
                                font-size: 9pt;
                            }
                        </style>

                        <!-- HEADER -->
                        <div class="text-center mb-3">
                            <h2 class="buruuj-title mb-0">SUBCONTRACT AGREEMENT</h2>
                            <div class="buruuj-accent">
                                <span t-field="o.name"/> / <span t-field="o.title"/>
                            </div>
                        </div>
                        <div class="buruuj-bar"/>

                        <!-- PARTIES -->
                        <div class="buruuj-section">PARTIES TO THIS AGREEMENT</div>
                        <div class="row">
                            <div class="col-6">
                                <div class="buruuj-box">
                                    <strong class="buruuj-title">The Contractor</strong><br/>
                                    <span t-field="o.company_id.name"/><br/>
                                    <span t-field="o.company_id.street"/><br/>
                                    <span t-field="o.company_id.city"/>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="buruuj-box">
                                    <strong class="buruuj-title">The Subcontractor</strong><br/>
                                    <span t-field="o.partner_id.name"/><br/>
                                    <span t-field="o.partner_id.street"/><br/>
                                    <span t-field="o.partner_id.city"/><br/>
                                    <small>License:
                                        <span t-field="o.partner_id.trade_license_no"/>
                                    </small>
                                </div>
                            </div>
                        </div>

                        <!-- KEY TERMS -->
                        <div class="buruuj-section">KEY TERMS</div>
                        <table class="kv" style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td class="label">Project</td>
                                <td><span t-field="o.project_id.name"/>
                                    (<span t-field="o.project_id.buruuj_project_code"/>)</td>
                                <td class="label">Trade</td>
                                <td><span t-field="o.trade_id.name"/></td>
                            </tr>
                            <tr>
                                <td class="label">Subcontract Date</td>
                                <td><span t-field="o.date"/></td>
                                <td class="label">Payment Terms</td>
                                <td><span t-field="o.payment_terms"/></td>
                            </tr>
                            <tr>
                                <td class="label">Start Date</td>
                                <td><span t-field="o.start_date"/></td>
                                <td class="label">Completion Date</td>
                                <td><span t-field="o.end_date"/></td>
                            </tr>
                            <tr>
                                <td class="label">DLP (months)</td>
                                <td><span t-field="o.dlp_months"/></td>
                                <td class="label">DLP End Date</td>
                                <td><span t-field="o.dlp_end"/></td>
                            </tr>
                        </table>

                        <!-- FINANCIAL TERMS -->
                        <div class="buruuj-section">FINANCIAL TERMS</div>
                        <table class="kv" style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td class="label">Contract Value</td>
                                <td>
                                    <span t-field="o.contract_value"
                                          t-options="{'widget': 'monetary',
                                                      'display_currency': o.currency_id}"/>
                                </td>
                                <td class="label">Currency</td>
                                <td><span t-field="o.currency_id.name"/></td>
                            </tr>
                            <tr>
                                <td class="label">Advance Payment</td>
                                <td>
                                    <span t-field="o.advance_percent"/>% (=
                                    <span t-field="o.advance_amount"
                                          t-options="{'widget': 'monetary',
                                                      'display_currency': o.currency_id}"/>)
                                </td>
                                <td class="label">Retention</td>
                                <td>
                                    <span t-field="o.retention_percent"/>% (=
                                    <span t-field="o.retention_amount"
                                          t-options="{'widget': 'monetary',
                                                      'display_currency': o.currency_id}"/>)
                                </td>
                            </tr>
                            <tr>
                                <td class="label">LD per Day</td>
                                <td><span t-field="o.ld_percent_per_day"/>%</td>
                                <td class="label">LD Cap</td>
                                <td><span t-field="o.ld_cap_percent"/>%</td>
                            </tr>
                        </table>

                        <!-- BONDS & INSURANCE -->
                        <div class="buruuj-section">BONDS &amp; INSURANCE</div>
                        <table class="kv" style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td class="label">Performance Bond</td>
                                <td>
                                    <span t-field="o.performance_bond_amount"
                                          t-options="{'widget': 'monetary',
                                                      'display_currency': o.currency_id}"/>
                                </td>
                                <td class="label">Bond Expiry</td>
                                <td><span t-field="o.performance_bond_expiry"/></td>
                            </tr>
                            <tr>
                                <td class="label">Insurance Expiry</td>
                                <td colspan="3"><span t-field="o.insurance_expiry"/></td>
                            </tr>
                        </table>

                        <!-- SCOPE OF WORK -->
                        <div class="buruuj-section">SCOPE OF WORK</div>
                        <div t-field="o.scope_of_work"/>

                        <!-- BOQ LINES -->
                        <div t-if="o.line_ids" class="buruuj-section">BILL OF QUANTITIES</div>
                        <table t-if="o.line_ids" class="lines"
                               style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr>
                                    <th style="width: 8%;">Item</th>
                                    <th style="width: 50%;">Description</th>
                                    <th style="width: 8%;">UoM</th>
                                    <th class="text-end" style="width: 10%;">Qty</th>
                                    <th class="text-end" style="width: 12%;">Rate</th>
                                    <th class="text-end" style="width: 12%;">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.line_ids" t-as="line">
                                    <td><span t-field="line.item_no"/></td>
                                    <td><span t-field="line.description"/></td>
                                    <td><span t-field="line.uom_id.name"/></td>
                                    <td class="text-end"><span t-field="line.quantity"/></td>
                                    <td class="text-end">
                                        <span t-field="line.unit_rate"
                                              t-options="{'widget': 'monetary',
                                                          'display_currency': o.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.amount"
                                              t-options="{'widget': 'monetary',
                                                          'display_currency': o.currency_id}"/>
                                    </td>
                                </tr>
                                <tr style="background: #f4f7fa; font-weight: bold;">
                                    <td colspan="5" class="text-end">TOTAL</td>
                                    <td class="text-end">
                                        <span t-field="o.contract_value"
                                              t-options="{'widget': 'monetary',
                                                          'display_currency': o.currency_id}"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- STANDARD TERMS -->
                        <div class="buruuj-section">STANDARD TERMS</div>
                        <ol style="font-size: 9pt; line-height: 1.5;">
                            <li>The Subcontractor shall execute the works in accordance with the
                                drawings, specifications, and main contract documents.</li>
                            <li>Payment shall be made against approved Interim Payment Certificates
                                (IPCs) submitted in line with the agreed payment terms.</li>
                            <li>Retention shall be released 50% on Practical Completion and 50% on
                                expiry of the Defects Liability Period (DLP).</li>
                            <li>The Subcontractor shall maintain valid insurance covering workmen's
                                compensation and third-party liability throughout the contract period.</li>
                            <li>Liquidated Damages apply for delays attributable to the Subcontractor,
                                as stated in the Key Terms section above.</li>
                            <li>Variations require written approval before execution. Unauthorised
                                changes are not reimbursable.</li>
                            <li>The Subcontractor shall comply with the Contractor's HSE plan and
                                attend mandatory toolbox talks.</li>
                        </ol>

                        <!-- SIGNATURES -->
                        <div class="row mt-5">
                            <div class="col-6 text-center">
                                <div class="signature-box">
                                    <strong>For and on behalf of</strong><br/>
                                    <span t-field="o.company_id.name"/><br/><br/>
                                    Name: ____________________________<br/><br/>
                                    Title: ____________________________<br/><br/>
                                    Date: ____________________________
                                </div>
                            </div>
                            <div class="col-6 text-center">
                                <div class="signature-box">
                                    <strong>For and on behalf of</strong><br/>
                                    <span t-field="o.partner_id.name"/><br/><br/>
                                    Name: ____________________________<br/><br/>
                                    Title: ____________________________<br/><br/>
                                    Date: ____________________________
                                </div>
                            </div>
                        </div>

                        <div class="buruuj-bar-thin mt-4"/>
                        <div class="text-center" style="font-size: 8pt; color: #777;">
                            Document reference: <span t-field="o.name"/>
                            — generated by Buruuj Construction ERP
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
